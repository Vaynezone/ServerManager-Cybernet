TransferGuildFunds.OnServerEvent:Connect(function(player, action, source, amount)
	local userId = player.UserId
	local data = PlayerData[userId]
	if not data then return end

	if not data.Guild then
		NotifyPlayer:FireClient(player, "Error", "You are not in a guild!")
		return
	end

	local guild = Guilds[data.Guild]
	if not guild then
		NotifyPlayer:FireClient(player, "Error", "Guild not found!")
		return
	end

	if not isValidNumber(amount) then
		NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	amount = math.floor(amount)
	if amount <= 0 then
		NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	if amount > RC_LIMIT then
		NotifyPlayer:FireClient(player, "Error", "Amount too large!")
		return
	end

	local playerRank = getGuildRank(guild, userId)

	if action == "deposit" then
		if source == "personal" then
			if data.Money < amount then
				NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin!")
				return
			end
			data.Money = data.Money - amount
			guild.Funds = (guild.Funds or 0) + amount
			checkAndResetGuildRC(guild.Id)
			UpdateMoney:FireClient(player, data.Money)
			pcall(function()
				DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
			end)
			NotifyPlayer:FireClient(player, "Success", "Deposited " .. amount .. " RC to guild funds!")
			if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, amount, "GuildDeposit", "Deposited to guild " .. guild.Name) end
		elseif source == "bank" then
			if (data.BankBalance or 0) < amount then
				NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin in bank!")
				return
			end
			data.BankBalance = data.BankBalance - amount
			guild.Funds = (guild.Funds or 0) + amount
			checkAndResetGuildRC(guild.Id)
			SendBankData:FireClient(player, data.BankBalance, 2)
			NotifyPlayer:FireClient(player, "Success", "Deposited " .. amount .. " RC from bank to guild funds!")
			if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, amount, "GuildDeposit", "Deposited from bank to guild " .. guild.Name) end
		end
	elseif action == "withdraw" then
		if not playerRank or playerRank < GuildManager.Ranks.Owner then
			NotifyPlayer:FireClient(player, "Error", "Only the guild owner can withdraw funds!")
			return
		end
		if (guild.Funds or 0) < amount then
			NotifyPlayer:FireClient(player, "Error", "Not enough guild funds!")
			return
		end
		guild.Funds = guild.Funds - amount
		if source == "personal" then
			data.Money = data.Money + amount
			checkAndResetPlayerRC(player.UserId)
			UpdateMoney:FireClient(player, data.Money)
			pcall(function()
				DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
			end)
			NotifyPlayer:FireClient(player, "Success", "Withdrew " .. amount .. " RC to wallet!")
			if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, amount, "GuildWithdraw", "Withdrew from guild " .. guild.Name) end
		elseif source == "bank" then
			local fee = math.floor(amount * 0.025)
			local withdrawAmount = amount - fee
			data.BankBalance = (data.BankBalance or 0) + withdrawAmount
			checkAndResetPlayerRC(player.UserId)
			SendBankData:FireClient(player, data.BankBalance, 2)
			NotifyPlayer:FireClient(player, "Success", "Withdrew " .. withdrawAmount .. " RC to bank! (Fee: " .. fee .. " RC)")
			if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, amount, "GuildWithdraw", "Withdrew from guild " .. guild.Name .. " to bank") end
		end
	end

	saveGuildData(guild.Id, true) -- Force save to ensure funds are saved immediately
	queuePlayerSave(userId)

	local allGuilds = getAllGuilds()
	local serverGuilds = getServerGuilds()
	local updatedReputation = calculateGuildReputation(guild)
	local playerGuild = {
		Id = guild.Id,
		Name = guild.Name,
		Reputation = updatedReputation,
		Funds = guild.Funds,
		Members = guild.Members,
		InviteOnly = guild.InviteOnly,
		NetworkIP = guild.NetworkIP
	}
	for _, member in ipairs(guild.Members) do
		if type(member.UserId) == "number" then
			local memberPlayer = Players:GetPlayerByUserId(member.UserId)
			if memberPlayer then
				SendGuildData:FireClient(memberPlayer, playerGuild, allGuilds, serverGuilds)
			end
		end
	end
end)

