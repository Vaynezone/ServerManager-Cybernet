BypassFirewall.OnServerEvent:Connect(function(player, networkId, deviceId, exploitData)
	local data = PlayerData[player.UserId]
	if not data then return end

	if not data.EquippedParts.CPU then
		NotifyPlayer:FireClient(player, "Error", "Cannot bypass! No CPU equipped.")
		return
	end

	if not canStartOperation(player) then
		local maxOps = getMaxOperations(player)
		NotifyPlayer:FireClient(player, "Error", "Too many operations running! Maximum: " .. maxOps)
		return
	end

	local targetFirewall = nil
	local network = getNetwork(networkId, player.UserId)
	if not network then return end

	if deviceId then
		for _, device in ipairs(network.Devices) do
			if device.Id == deviceId and device.Firewall then
				targetFirewall = sanitizeFirewall(device.Firewall)
				break
			end
		end
	else
		if network.Firewall then
			targetFirewall = sanitizeFirewall(network.Firewall)
		end
	end

	if not targetFirewall then
		NotifyPlayer:FireClient(player, "Error", "No firewall detected!")
		return
	end

	if not exploitData or exploitData.Library ~= targetFirewall.Library or exploitData.Version ~= targetFirewall.Version then
		NotifyPlayer:FireClient(player, "Error", "Exploit does not match firewall!")
		return
	end

	local effectiveSecurity = deviceId and 4 or getEffectiveSecurity(networkId, player.UserId)
	local difficulty = GameData.HackDifficulty[effectiveSecurity]
	local duration = difficulty.Duration * getHackSpeed(player)

	incrementOperations(player)
	local operationId = registerOperation(player.UserId, deviceId or networkId, "BypassFirewall", effectiveSecurity)
	StartProgressBar:FireClient(player, deviceId or networkId, duration, deviceId ~= nil)
	task.wait(duration)

	if not isOperationActive(player.UserId, operationId) then
		unregisterOperation(player.UserId, operationId)
		decrementOperations(player)
		return
	end

	if deviceId then
		for _, device in ipairs(network.Devices) do
			if device.Id == deviceId then
				device.FirewallBypassed = true
				NotifyPlayer:FireClient(player, "Success", "Firewall bypassed! You can now hack the device.")
				break
			end
		end
	else
		network.FirewallBypassed = true
		NotifyPlayer:FireClient(player, "Success", "Firewall bypassed! You can now hack the network.")
	end

	local clientNetworks = prepareNetworksForClient(data.Networks, player.UserId)
	SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)

	unregisterOperation(player.UserId, operationId)
	decrementOperations(player)
end)


