SaveMotherboard.OnServerEvent:Connect(function(player, motherboardData)
	local data = PlayerData[player.UserId]
	if not data then return end

	if not motherboardData or type(motherboardData) ~= "table" then
		NotifyPlayer:FireClient(player, "Error", "Invalid motherboard data!")
		if ExploitLogger then ExploitLogger.Log(player.UserId, "InvalidMotherboard", "motherboardData is nil or not a table", "Warning") end
		return
	end

	if SecurityValidator then
		local valid, reason = SecurityValidator.ValidateMotherboard(motherboardData, data.OwnedParts)
		if not valid then
			NotifyPlayer:FireClient(player, "Error", "Invalid motherboard: " .. tostring(reason))
			ExploitLogger.Log(player.UserId, "InvalidMotherboard", "Validation failed: " .. tostring(reason), "Critical")
			return
		end
	end

	local foundMotherboard = nil
	for _, part in ipairs(data.OwnedParts) do
		if part.PartId == motherboardData.PartId and (part.Type == "MOBO" or not part.Type) then
			foundMotherboard = part
			break
		end
	end

	if not foundMotherboard then
		NotifyPlayer:FireClient(player, "Error", "Motherboard not found in inventory!")
		if ExploitLogger then ExploitLogger.Log(player.UserId, "MotherboardNotOwned", "Attempted to equip unowned motherboard: " .. tostring(motherboardData.PartId), "Critical") end
		return
	end

	if data.Motherboard then
		if not data.Motherboard.PartId then
			data.Motherboard.PartId = HttpService:GenerateGUID(false)
		end
		if not data.Motherboard.Type then
			data.Motherboard.Type = "MOBO"
		end

		local alreadyInOwnedParts = false
		for _, part in ipairs(data.OwnedParts) do
			if part.PartId == data.Motherboard.PartId then
				alreadyInOwnedParts = true
				break
			end
		end
		if not alreadyInOwnedParts then
			ensurePartHasId(data.Motherboard, player.UserId)
			table.insert(data.OwnedParts, data.Motherboard)
		end
	end

	data.Motherboard = foundMotherboard
	data.EquippedParts = {CPU = nil, GPU = nil, RAM1 = nil, RAM2 = nil, RAM3 = nil, RAM4 = nil, PSU = nil, HDD = nil, NET = nil}
	queuePlayerSave(player.UserId)
