				if not network then return 0 end
				return network.Balance or 0
			elseif action == "TraceIntruder" then
				-- extra contains the intruder's UserId
				local intruderUserId = extra
				if not intruderUserId then return false end

				-- Check if intruder has spoof protection
				if SpoofedOperations[intruderUserId] and time() < SpoofedOperations[intruderUserId] then
					return false -- Intruder is protected from trace
				end

				local intruderPlayer = Players:GetPlayerByUserId(intruderUserId)
				if not intruderPlayer then return false end

				local data = PlayerData[player.UserId]
				if not data then return false end

				-- Find player's home network
				local homeNetwork = nil
				for _, net in ipairs(data.Networks) do
					if net.IsPlayerHome then
						homeNetwork = net
						break
					end
				end
				if not homeNetwork then return false end

				-- Start a player trace on the intruder from our home network
				local traceHelpers = {
					getPlayerData = function(uid) return PlayerData[uid] end,
					getNetwork = getNetwork,
					getEffectiveSecurity = getEffectiveSecurity,
					canStartOperation = canStartOperation,
					getMaxOperations = getMaxOperations,
					getScanSpeed = getScanSpeed,
					incrementOperations = incrementOperations,
					decrementOperations = decrementOperations,
					registerOperation = registerOperation,
					unregisterOperation = unregisterOperation,
					isOperationActive = isOperationActive,
					prepareNetworksForClient = prepareNetworksForClient,
					markPlayerDirty = markPlayerDirty,
				}

				-- Simulate being on home network for trace
				local originalNetwork = data.CurrentNetwork
				data.CurrentNetwork = homeNetwork.Id

				local success, result = TraceManager.StartPlayerTrace(player, intruderUserId, traceHelpers)

				data.CurrentNetwork = originalNetwork
				return success and result == "success"
			elseif action == "ForceLogoutPlayer" then
				-- extra contains the intruder's UserId
				local intruderUserId = extra
				if not intruderUserId then return false end

				local intruderData = PlayerData[intruderUserId]
				if not intruderData then return false end

				local data = PlayerData[player.UserId]
				if not data then return false end

				-- Find player's home network
				local homeNetworkId = nil
				for _, net in ipairs(data.Networks) do
					if net.IsPlayerHome then
						homeNetworkId = net.Id
						break
					end
				end
				if not homeNetworkId then return false end

				-- Check if intruder is logged into our home network
				if intruderData.LoggedInNetwork == homeNetworkId then
					-- Force logout
					intruderData.LoggedInNetwork = nil
					intruderData.LoggedInDevice = nil
					AccessCodeSystem.LogoutFromAllDevicesOnNetwork(intruderUserId, homeNetworkId)

					-- Notify intruder
					local intruderPlayer = Players:GetPlayerByUserId(intruderUserId)
					if intruderPlayer then
						local clientNetworks = prepareNetworksForClient(intruderData.Networks, intruderUserId)
						SendNetworkData:FireClient(intruderPlayer, clientNetworks, intruderData.CurrentNetwork, intruderData.LoggedInNetwork, intruderData.LoggedInDevice)
					end

					return true
				end
				return false
			elseif action == "CancelOperations" then
				-- extra contains the target player's name
				local targetName = extra
				if not targetName then return 0 end

				local targetPlayer = nil
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Name == targetName then
						targetPlayer = p
						break
					end
				end
				if not targetPlayer then return 0 end

				local targetUserId = targetPlayer.UserId

				-- Check if target has spoof protection
				if SpoofedOperations[targetUserId] and time() < SpoofedOperations[targetUserId] then
					return 0 -- Operations are spoofed/protected
				end

				-- Cancel all operations for the target by setting Cancelled flag
				local cancelled = 0
				if ActiveOperations[targetUserId] then
					for opId, operation in pairs(ActiveOperations[targetUserId]) do
						if not operation.Cancelled then
							operation.Cancelled = true
							cancelled = cancelled + 1
							-- Cancel the specific progress bar for this operation
							if operation.NodeId then
								CancelProgressBar:FireClient(targetPlayer, operation.NodeId)
							end
						end
					end
					if cancelled > 0 then
						NotifyPlayer:FireClient(targetPlayer, "Warning", "Your operations were cancelled!")
					end
				end
				return cancelled
			elseif action == "SpoofOperation" then
				-- extra contains the duration in seconds
				local duration = tonumber(extra) or 5
				duration = math.min(duration, 5) -- Cap at 5 seconds
				SpoofedOperations[player.UserId] = time() + duration
				return true
			end
			return false
		end
	end

