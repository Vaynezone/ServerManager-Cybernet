		if not data.LoggedInNetwork then
			TerminalResponse:FireClient(player, "ERROR: Not logged into any network or device")
			return
		end

		local logoutNetworkId = data.LoggedInNetwork
		local loggedNet = getNetwork(logoutNetworkId, userId)
		if data.LoggedInDevice then
			AccessCodeSystem.SetLoggedIn(player.UserId, data.LoggedInNetwork, data.LoggedInDevice, false)
			TerminalResponse:FireClient(player, "✓ Logged out from device")
			data.LoggedInDevice = nil
			-- Stay logged into network when logging out of device only
		else
			AccessCodeSystem.LogoutFromAllDevicesOnNetwork(player.UserId, data.LoggedInNetwork)
			TerminalResponse:FireClient(player, "✓ Logged out from network " .. (loggedNet and loggedNet.IP or "unknown") .. " and all its devices")
			data.LoggedInNetwork = nil
			data.LoggedInDevice = nil
		end

		local clientNetworks = prepareNetworksForClient(data.Networks, player.UserId)
		SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)

		if logoutNetworkId then
			local traceHelpers = {
				getPlayerData = function(uid) return PlayerData[uid] end,
				getNetwork = getNetwork,
				getEffectiveSecurity = getEffectiveSecurity,
				updateNetworkAwareness = updateNetworkAwareness
			}
			local escaped, escapeType = TraceManager.HandlePlayerLogout(player, logoutNetworkId, traceHelpers)
			if escaped then
				if escapeType == "admin_escaped" then
					TerminalResponse:FireClient(player, "✓ You escaped the trace by logging out.")
				elseif escapeType == "player_escaped" then
					TerminalResponse:FireClient(player, "✓ You escaped the player trace by logging out.")
				end
			elseif escapeType == "still_on_network" then
				TerminalResponse:FireClient(player, "⚠ Player trace still active! Move off the network to escape.")
			end
		end
	elseif commandLower == "steal" then
		if #args == 0 then
			TerminalResponse:FireClient(player, "ERROR: Usage: steal [IP] <LAN_IP>\nExamples:\n  steal 192.168.1.10 - Steal from device on current network\n  steal 192.168.1.5 192.168.1.10 - Steal from specific device")
			return
		end

		local targetIP, targetLANIP
		local networkId, deviceId

		if #args >= 2 then
			targetIP = args[1]
			targetLANIP = args[2]
		elseif #args == 1 then
			if not data.CurrentNetwork then
				TerminalResponse:FireClient(player, "ERROR: Not connected to any network")
				return
			end
			local currentNet = getNetwork(data.CurrentNetwork, userId)
			if currentNet then
				targetIP = currentNet.IP
				targetLANIP = args[1]
			end
		end

		local targetNetwork = nil
		for _, network in ipairs(data.Networks) do
			if network.IP == targetIP then
				targetNetwork = network
				networkId = network.Id
				break
			end
		end

		if not targetNetwork then
			TerminalResponse:FireClient(player, "ERROR: Network " .. targetIP .. " not found")
			return
		end

		local targetDevice = nil
		for _, dev in ipairs(targetNetwork.Devices) do
			if dev.LANIP == targetLANIP then
				targetDevice = dev
				deviceId = dev.Id
				break
			end
		end

		if not targetDevice then
			TerminalResponse:FireClient(player, "ERROR: Device " .. targetLANIP .. " not found on network " .. targetIP)
			return
		end

		if not targetNetwork.Hacked then
			TerminalResponse:FireClient(player, "ERROR: Network not hacked! Hack it first.")
			return
		end

		if not targetDevice.Hacked then
			TerminalResponse:FireClient(player, "ERROR: Device not hacked! Hack it first.")
			return
		end

		local isLoggedIn = AccessCodeSystem.IsLoggedIn(player.UserId, networkId, deviceId)
		if not isLoggedIn then
			TerminalResponse:FireClient(player, "ERROR: Not logged into this device!")
			return
		end

		local stealTimerKey = networkId .. "_" .. (deviceId or "network")
		local currentTime = time()
		if AccessCodeSystem.StealTimers[player.UserId] and AccessCodeSystem.StealTimers[player.UserId][stealTimerKey] then
			local remainingTime = AccessCodeSystem.StealTimers[player.UserId][stealTimerKey] - currentTime
			if remainingTime > 0 then
				TerminalResponse:FireClient(player, string.format("ERROR: Steal cooldown active. Wait %d seconds.", math.ceil(remainingTime)))
				return
			end
		end

		AccessCodeSystem.SetStealTimer(player.UserId, networkId, deviceId)

		-- Use typing minigame instead of automatic steal
		local network = getNetwork(networkId, userId)
		if not network then
			TerminalResponse:FireClient(player, "ERROR: Network not found")
			return
		end

		local device
		for _, d in ipairs(network.Devices or {}) do
			if d.Id == deviceId then
				device = d
				break
			end
		end

		if not device then
			TerminalResponse:FireClient(player, "ERROR: Device not found")
			return
		end

		-- Get effective security level
		local securityLevel = device.Security or network.Security or 3
		securityLevel = math.clamp(securityLevel, 1, 5)

		-- Generate typing challenge
		local challengeWords = generateStealChallenge(securityLevel)
		local challengeId = HttpService:GenerateGUID(false)

		-- Adjust time limit based on word count
		local baseTimePerWord
		if securityLevel <= 2 then
			baseTimePerWord = 12
		elseif securityLevel == 3 then
			baseTimePerWord = 10
		else
			baseTimePerWord = 8
		end

		local timeLimit = math.ceil(#challengeWords * baseTimePerWord)
		timeLimit = math.min(timeLimit :: number, 120)
		timeLimit = math.max(timeLimit :: number, 30)

		-- Store challenge with metadata (mark as terminal challenge)
		PendingStealChallenges[challengeId] = {
			Player = player,
			UserId = player.UserId,
			NetworkId = networkId,
			DeviceId = deviceId,
			ChallengeWords = challengeWords,
			CurrentWordIndex = 1,
			TotalAttempts = 0,
			MaxTotalAttempts = 3,
			TimeLimit = timeLimit,
			CreatedAt = time(),
			ExpiresAt = time() + timeLimit,
			IsTerminal = true -- Flag to indicate this is a terminal challenge
		}

		-- Send challenge to terminal client
		SendStealChallenge:FireClient(player, challengeId, challengeWords, 1, 3, timeLimit, false)

		-- Return here - the actual steal will be completed by SubmitStealAnswer handler when challenge succeeds
		-- The reward calculation and distribution is handled by GameActions.StealFromNode when the challenge completes
		return
	elseif commandLower == "transactionlogs" then
		if #args == 0 then
			if not data.LoggedInDevice then
				TerminalResponse:FireClient(player, "ERROR: Usage: transactionlogs <IP> <LAN_IP>\nOr: transactionlogs <LAN_IP> (on current network)\nYou must be logged into a device to view transaction logs")
