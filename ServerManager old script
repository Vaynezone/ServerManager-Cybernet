LeaveGuild.OnServerEvent:Connect(function(player)
	local userId = player.UserId
	local data = PlayerData[userId]
	if not data then return end

	if not data.Guild then
		NotifyPlayer:FireClient(player, "Error", "You are not in a guild!")
		return
	end

	local guild = Guilds[data.Guild]
	if not guild then
		NotifyPlayer:FireClient(player, "Error", "Guild not found!")
		return
	end

	local isOwner = guild.OwnerId == userId

	if isOwner then
		local guildId = guild.Id

		if GuildNetworks[guild.Id] then
			local guildNetwork = GuildNetworks[guild.Id]
			GuildNetworks[guild.Id] = nil
		end

		for _, member in ipairs(guild.Members) do
			if type(member.UserId) == "number" then
				local memberPlayer = Players:GetPlayerByUserId(member.UserId)
				if memberPlayer and PlayerData[member.UserId] then
					PlayerData[member.UserId].Guild = nil

					for i = #PlayerData[member.UserId].Networks, 1, -1 do
						local net = PlayerData[member.UserId].Networks[i]
						if type(net) == "table" and net.IsGuildNetwork and net.GuildId == guildId then
							table.remove(PlayerData[member.UserId].Networks, i)
						end
					end

					local clientNetworks = prepareNetworksForClient(PlayerData[member.UserId].Networks, member.UserId)
					SendNetworkData:FireClient(memberPlayer, clientNetworks, PlayerData[member.UserId].CurrentNetwork, PlayerData[member.UserId].LoggedInNetwork, PlayerData[member.UserId].LoggedInDevice)
					NotifyPlayer:FireClient(memberPlayer, "Info", "Your guild has been disbanded")
					queuePlayerSave(member.UserId)
				else
					local offlineData = loadPlayerData(member.UserId)
					if offlineData then
						offlineData.Guild = nil
						pcall(function()
							DataStoreManager.Stores.PlayerData:SetAsync("Data_" .. member.UserId, HttpService:JSONEncode(offlineData))
						end)
					end
				end
			end
		end

		Guilds[guildId] = nil
		cachedGuildList[guildId] = nil
		pcall(function()
			DataStoreManager.Stores.GuildData:RemoveAsync("Guild_" .. guildId)

			local guildList = DataStoreManager.Stores.GuildData:GetAsync("GuildList") or {}
			local newList = {}
			for _, id in ipairs(guildList) do
				if id ~= guildId then
					table.insert(newList, id)
				end
			end
			DataStoreManager.Stores.GuildData:SetAsync("GuildList", newList)
		end)

		NotifyPlayer:FireClient(player, "Success", "Guild disbanded")

		-- Broadcast updated guild lists to all players
		local allGuilds = getAllGuilds()
		local serverGuilds = getServerGuilds()
		for _, p in ipairs(Players:GetPlayers()) do
			local pData = PlayerData[p.UserId]
			if pData then
				local playerGuild = nil
				if pData.Guild and Guilds[pData.Guild] then
					playerGuild = {
						Id = Guilds[pData.Guild].Id,
						Name = Guilds[pData.Guild].Name,
						Reputation = Guilds[pData.Guild].Reputation,
						Funds = Guilds[pData.Guild].Funds,
						Members = Guilds[pData.Guild].Members,
						InviteOnly = Guilds[pData.Guild].InviteOnly,
						NetworkIP = Guilds[pData.Guild].NetworkIP
					}
				end
				SendGuildData:FireClient(p, playerGuild, allGuilds, serverGuilds)
			end
		end
		return
	else
		for i = #guild.Members, 1, -1 do
			if guild.Members[i].UserId == userId then
				table.remove(guild.Members, i)
				break
			end
		end

		if GuildNetworks[guild.Id] then
			for i = #data.Networks, 1, -1 do
				local net = data.Networks[i]
				if type(net) == "table" and net.IsGuildNetwork and net.GuildId == guild.Id then
					table.remove(data.Networks, i)
				end
			end

			local clientNetworks = prepareNetworksForClient(data.Networks, player.UserId)
			SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		end

		data.Guild = nil
		queuePlayerSave(userId)
		saveGuildData(guild.Id)
		NotifyPlayer:FireClient(player, "Success", "Left guild '" .. guild.Name .. "'")
	end

	SendGuildData:FireClient(player, nil, getAllGuilds(), getServerGuilds())
end)

