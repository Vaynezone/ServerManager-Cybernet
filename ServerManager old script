-- Generate a single random hacking word
-- Changed from local function to regular function to avoid local register limit
function generateRandomWord(excludeWords)
	excludeWords = excludeWords or {}
	local allWords = {
		"Firewall", "Encryption", "Decryption", "Protocol", "Network", "Security",
		"Access", "Bypass", "Exploit", "Vulnerability", "Authentication", "Authorization",
		"Intrusion", "Detection", "Prevention", "Malware", "Virus", "Trojan",
		"Backdoor", "Rootkit", "Phishing", "Spyware", "Adware", "ZeroDay",
		"Payload", "Cipher", "Algorithm", "Hash", "Salt", "Token",
		"Session", "Cookie", "Certificate", "Breach", "Penetration", "Keylogger",
		"Ransomware", "Botnet", "Dictionary", "Rainbow", "Keygen", "Cracker",
		"ScriptKiddie", "WhiteHat", "BlackHat", "GreyHat", "Ethical", "Unethical",
		"NULLBYTE", "BUFFER", "STACK", "HEAP", "REGISTER",
		"SHELLCODE", "PAYLOAD", "EXPLOIT", "VULN", "PATCH",
		"NoSQLi", "Kerberos", "HTTPS", "TLS", "SSL", "AES", "RSA", "SHA256",
		"MD5", "SHA1", "BCrypt", "PBKDF2", "Scrypt",
		"APIKey", "AuthToken", "SessionID", "CookieID", "CSRFToken"
	}

	-- Create a set of excluded words for faster lookup
	local excludeSet = {}
	for _, word in ipairs(excludeWords) do
		excludeSet[word] = true
	end

	-- Try to find a word not in exclude list
	local attempts = 0
	local maxAttempts = 100
	repeat
		local index = math.random(1, #allWords)
		local word = allWords[index]
		if not excludeSet[word] then
			return word
		end
		attempts = attempts + 1
	until attempts >= maxAttempts

	-- Fallback: return any random word if all are excluded
	return allWords[math.random(1, #allWords)]
end

-- Generate multiple separate words for typing minigame (3-10 words)
-- Security level affects difficulty: 1-2 stars = easy, 3 = medium, 4-5 = hard
-- Changed from local function to regular function to avoid local register limit
function generateStealChallenge(securityLevel)
	securityLevel = securityLevel or 3
	securityLevel = math.clamp(securityLevel, 1, 5)

	-- Adjust word count based on security level (3-10 words total)
	-- Lower security = fewer words (easier), Higher security = more words (harder)
	local wordCount
	if securityLevel <= 2 then
		-- 1-2 stars: Easy (3-5 words)
		wordCount = math.random(3, 5)
	elseif securityLevel == 3 then
		-- 3 stars: Medium (5-7 words)
		wordCount = math.random(5, 7)
	else
		-- 4-5 stars: Hard (7-10 words)
		wordCount = math.random(7, 10)
	end

	local challengeWords = {}
	local usedWords = {}

	-- Select random unique words
	for i = 1, wordCount do
		local word = generateRandomWord(usedWords)
		table.insert(usedWords, word)
		table.insert(challengeWords, word)
	end

	return challengeWords
end

