function updatePlayerResourceUsage(userId)
	if not PlayerResourceUsage[userId] then
		PlayerResourceUsage[userId] = {CPU = 0, RAM = 0, NET = 0}
	end

	local player = Players:GetPlayerByUserId(userId)
	if not player then return end

	local data = PlayerData[userId]
	if not data then return end

	local psuEfficiency = getPSUEfficiency(player)
	local base = data.BaseResourceUsage or {CPU = 5, RAM = 10, NET = 1}
	base = {
		CPU = math.floor(base.CPU * psuEfficiency),
		RAM = math.floor(base.RAM * psuEfficiency),
		NET = math.floor(base.NET * psuEfficiency)
	}
	local cpuVariation = math.random(-2, 2)
	local ramVariation = math.random(-2, 1.5)
	local netVariation = math.random(-2, 1.5)
	local usage = {
		CPU = math.max(0, base.CPU + cpuVariation),
		RAM = math.max(0, base.RAM + ramVariation),
		NET = math.max(0, base.NET + netVariation)
	}

	if ActiveOperations[userId] then
		for operationId, operation in pairs(ActiveOperations[userId]) do
			if not operation.Cancelled then
				local cost = operation.ResourceCost or {CPU = 0, RAM = 0, NET = 0}
				usage.CPU = usage.CPU + cost.CPU
				usage.RAM = usage.RAM + cost.RAM
				usage.NET = usage.NET + cost.NET
			end
		end
	end

	if data.Networks then
		local networkCount = 0
		for _, network in ipairs(data.Networks) do
			if network.Visible then
				networkCount = networkCount + 1
			end
		end
		usage.RAM = usage.RAM + (networkCount * 0.5)
		usage.NET = usage.NET + (networkCount * 0.2)
	end

	PlayerResourceUsage[userId] = usage

	local maxCPU = getMaxCPUPoints(player)
	local maxRAM = getMaxRAMPoints(player)
	local maxNET = getMaxNETPoints(player)
	local maxStorage = getMaxStoredNetworks(player)

	local SendResourceUsage = RemoteEvents:FindFirstChild("SendResourceUsage")
	if SendResourceUsage then
		SendResourceUsage:FireClient(player, usage, {CPU = maxCPU, RAM = maxRAM, NET = maxNET, STORAGE = maxStorage})
	end
end

