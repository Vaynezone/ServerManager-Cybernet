function awardExperience(player, amount, reason)
	local data = PlayerData[player.UserId]
	if not data then return end

	local expWithMultiplier = math.floor(amount * getXPMultiplier(player.UserId))
	data.Experience = data.Experience + expWithMultiplier

	local expNeeded = (data.Level + 1) * 100
	local levelsGained = 0
	while data.Experience >= expNeeded do
		data.Experience = data.Experience - expNeeded
		data.Level = data.Level + 1
		levelsGained = levelsGained + 1
		expNeeded = (data.Level + 1) * 100
	end

	-- Award skill points for leveling up
	if levelsGained > 0 then
		local skillPointsPerLevel = GameData.SkillTree.SkillPointsPerLevel or 0.5
		-- Track partial skill points
		if not data.PendingSkillPoints then
			data.PendingSkillPoints = 0
		end
		data.PendingSkillPoints = data.PendingSkillPoints + (levelsGained * skillPointsPerLevel)

		-- Award full skill points when accumulated
		local skillPointsAwarded = math.floor(data.PendingSkillPoints)
		data.PendingSkillPoints = data.PendingSkillPoints - skillPointsAwarded

		if skillPointsAwarded > 0 then
			data.SkillPoints = (data.SkillPoints or 0) + skillPointsAwarded

			-- Cap skill points at max
			local maxSkillPoints = GameData.SkillTree.MaxSkillPoints or 50
			if data.SkillPoints > maxSkillPoints then
				data.SkillPoints = maxSkillPoints
			end

			NotifyPlayer:FireClient(player, "Success", "LEVEL UP! You are now level " .. data.Level .. "! +" .. skillPointsAwarded .. " Skill Points!")

			-- Update skill tree data
			if SendSkillTree then
				SendSkillTree:FireClient(player, {
					SkillPoints = data.SkillPoints,
					UnlockedSkills = data.UnlockedSkills or {}
				})
			end
		else
			NotifyPlayer:FireClient(player, "Success", "LEVEL UP! You are now level " .. data.Level .. "!")
		end

		-- Check level milestones
		checkMilestoneRewards(player, "Level15", data.Level)
		checkMilestoneRewards(player, "Level30", data.Level)
		checkMilestoneRewards(player, "Level60", data.Level)

		-- Check level rewards
		checkLevelRewards(player, data.Level)

		queuePlayerSave(player.UserId)
	end

	UpdateExperience:FireClient(player, data.Level, data.Experience)
end

-- Award skill points for milestones/achievements
-- Changed from local function to regular function to avoid local register limit
function checkMilestoneRewards(player, milestoneType, value)
	local data = PlayerData[player.UserId]
	if not data then return end

	-- Track which milestones have been awarded
	if not data.MilestoneRewards then
		data.MilestoneRewards = {}
	end

	local milestones = {
		FirstScan = {value = 1, reward = 0, key = "FirstScan"}, -- No reward for first scan
		FirstHack = {value = 1, reward = 0, key = "FirstHack"}, -- No reward for first hack
		Scans25 = {value = 25, reward = 0.1, key = "Scans25"}, -- Super reduced: 0.1 SP (was 1)
		Scans100 = {value = 100, reward = 0.1, key = "Scans100"}, -- Super reduced: 0.1 SP (was 1)
		Scans250 = {value = 250, reward = 0.2, key = "Scans250"}, -- Super reduced: 0.2 SP (was 2)
		Scans1000 = {value = 1000, reward = 0.3, key = "Scans1000"}, -- Super reduced: 0.3 SP (was 3)
		Hacks25 = {value = 25, reward = 0.1, key = "Hacks25"}, -- Super reduced: 0.1 SP (was 1)
		Hacks100 = {value = 100, reward = 0.1, key = "Hacks100"}, -- Super reduced: 0.1 SP (was 1)
		Hacks250 = {value = 250, reward = 0.2, key = "Hacks250"}, -- Super reduced: 0.2 SP (was 2)
		Hacks1000 = {value = 1000, reward = 0.3, key = "Hacks1000"}, -- Super reduced: 0.3 SP (was 3)
		PlayersHacked25 = {value = 25, reward = 0.1, key = "PlayersHacked25"}, -- Super reduced: 0.1 SP (was 1)
		PlayersHacked100 = {value = 100, reward = 0.2, key = "PlayersHacked100"}, -- Super reduced: 0.2 SP (was 2)
		Level15 = {value = 15, reward = 0.1, key = "Level15"}, -- Super reduced: 0.1 SP (was 1)
		Level30 = {value = 30, reward = 0.2, key = "Level30"}, -- Super reduced: 0.2 SP (was 2)
		Level60 = {value = 60, reward = 0.3, key = "Level60"} -- Super reduced: 0.3 SP (was 3)
	}

	local milestone = milestones[milestoneType]
	if not milestone then return end

	-- Check if already awarded
	if data.MilestoneRewards[milestone.key] then return end

	-- Check if milestone reached
	local currentValue = 0
	if milestoneType == "FirstScan" or milestoneType:find("Scans") then
		currentValue = data.Stats.ScansCompleted or 0
	elseif milestoneType == "FirstHack" or milestoneType:find("Hacks") then
		currentValue = data.Stats.HacksCompleted or 0
	elseif milestoneType:find("PlayersHacked") then
		currentValue = data.Stats.PlayersHacked or 0
	elseif milestoneType:find("Level") then
		currentValue = data.Level or 0
	end

	-- Only award if current value actually meets or exceeds the milestone requirement
	-- CRITICAL: For milestones like Scans100/Hacks100, we must ensure the value is >= the milestone threshold
	-- This prevents awarding high milestones (like 100) when you only have 1 scan/hack
	-- Example: Scans100 requires currentValue >= 100, so if currentValue is 1, it won't award
	-- The check ensures: currentValue must be >= milestone.value (e.g., 100 scans for Scans100)
	if currentValue >= milestone.value and currentValue > 0 and milestone.value > 0 then
		data.MilestoneRewards[milestone.key] = true

		-- Track partial skill points (like leveling system)
		if not data.PendingSkillPoints then
			data.PendingSkillPoints = 0
		end
		data.PendingSkillPoints = data.PendingSkillPoints + milestone.reward

		-- Award full skill points when accumulated
		local skillPointsAwarded = math.floor(data.PendingSkillPoints)
		data.PendingSkillPoints = data.PendingSkillPoints - skillPointsAwarded

		if skillPointsAwarded > 0 then
			data.SkillPoints = (data.SkillPoints or 0) + skillPointsAwarded

			-- Cap skill points
			local maxSkillPoints = GameData.SkillTree.MaxSkillPoints or 50
			if data.SkillPoints > maxSkillPoints then
				data.SkillPoints = maxSkillPoints
			end
		end

		-- Fix: Always show pending SP amount when milestone reward is fractional
		local milestoneName = milestoneType:gsub("([A-Z])", " %1"):gsub("^%l", string.upper)
		local rewardText
		if skillPointsAwarded > 0 then
			rewardText = "+" .. skillPointsAwarded .. " Skill Point" .. (skillPointsAwarded > 1 and "s" or "")
		else
			-- Show pending amount (not 0.0) when fractional SP is pending
			local pendingAmount = data.PendingSkillPoints or 0
			if pendingAmount > 0 then
				rewardText = string.format("+%.1f SP (pending)", pendingAmount)
			else
				rewardText = string.format("+%.1f SP (pending)", milestone.reward)
			end
		end
		NotifyPlayer:FireClient(player, "Success", "Milestone: " .. milestoneName .. "! " .. rewardText .. "!")

		-- Update skill tree data
		if SendSkillTree then
			SendSkillTree:FireClient(player, {
				SkillPoints = data.SkillPoints,
				UnlockedSkills = data.UnlockedSkills or {}
			})
		end

		queuePlayerSave(player.UserId)
	end
end

