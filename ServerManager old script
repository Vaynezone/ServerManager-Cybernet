local function trimString(s)
	if type(s) ~= "string" then return s end
	return (s:gsub("^%s*(.-)%s*$", "%1"))
end


-- Ensure a part has a valid, unique PartId. Regenerates on collision and records attempts.
local function isPartIdCollision(partId, ownerUserId)
	if not partId then return false end
	for uid, pdata in pairs(PlayerData) do
		if pdata and pdata.OwnedParts then
			for _, p in ipairs(pdata.OwnedParts) do
				if p and p.PartId == partId then
					return true
				end
			end
		end
	end
	return false
end

local function ensurePartHasId(part, ownerUserId)
	if not part then return end
	if not part.PartId or type(part.PartId) ~= "string" or part.PartId == "" then
		part.PartId = HttpService:GenerateGUID(false)
	end
	local attempts = 0
	while isPartIdCollision(part.PartId, ownerUserId) and attempts < 10 do
		part.PartId = HttpService:GenerateGUID(false)
		attempts = attempts + 1
	end
	if attempts > 0 then
		if ExploitLogger then
			ExploitLogger.Log(ownerUserId, "PartIdCollision", "Regenerated PartId after " .. attempts .. " attempts for part: " .. tostring(part.Name), "Warning")
		end
	end
	if TraceManager and TraceManager.RecordPartOperation then
		TraceManager.RecordPartOperation(ownerUserId, "AssignId", part.PartId, {Name = part.Name, Attempts = attempts})
	end
end


local function triggerSecurityDetection(ownerUserId, detectionType, networkId, attackerName, extraData)
	local programs = ActiveSecurityPrograms[ownerUserId]
	if not programs then 
		return false 
	end


	local hasHandler = false
	for blockId, handler in pairs(programs) do
		if handler.type == detectionType then

			if not handler.networkId or handler.networkId == networkId then
				hasHandler = true
				break
			end
		end
	end

	if hasHandler and SecurityDetectionEvent then

		SecurityDetectionEvent:Fire(ownerUserId, detectionType, networkId, attackerName, extraData)
		return true
	end
	return false
end


local function registerSecurityDetection(ownerUserId, blockId, detectionType, networkId)
	if not ActiveSecurityPrograms[ownerUserId] then
		ActiveSecurityPrograms[ownerUserId] = {}
	end
	ActiveSecurityPrograms[ownerUserId][blockId] = {
		type = detectionType,
		networkId = networkId
	}
end


local function unregisterSecurityDetection(ownerUserId, blockId)
	if ActiveSecurityPrograms[ownerUserId] then
		ActiveSecurityPrograms[ownerUserId][blockId] = nil
		if not next(ActiveSecurityPrograms[ownerUserId]) then
			ActiveSecurityPrograms[ownerUserId] = nil
		end
	end
end


local function unregisterAllSecurityDetections(ownerUserId)
	ActiveSecurityPrograms[ownerUserId] = nil
end

function filterText(text, fromUserId)
	if not text or text == "" then return text end
	local success, result = pcall(function()
		local filterResult = TextService:FilterStringAsync(text, fromUserId)
		return filterResult:GetNonChatStringForBroadcastAsync()
	end)
	return success and result or text
end

function filterMailData(mail, viewerId)
	for _, m in ipairs(mail) do
		if m.Type == "PlayerMail" then
			m.Subject = filterText(m.Subject, viewerId)
			m.Message = filterText(m.Message, viewerId)
		end
	end
	return mail
end

RC_LIMIT = 1000000000000 -- 1 Trillion
BOUNTY_LIMIT = 100000000

function isValidNumber(value)
	if type(value) ~= "number" then return false end
	if value ~= value then return false end -- NaN check
	if value == math.huge or value == -math.huge then return false end
	return true
end

function sanitizeNumber(value, default)
	default = default or 0
	if not isValidNumber(value) then return default end
	return value
end

function checkAndResetPlayerRC(userId)
	local data = PlayerData[userId]
	if not data then return false end


	if not isValidNumber(data.Money) then
		local oldMoney = tostring(data.Money)
		data.Money = 0
		if ExploitLogger then
			ExploitLogger.Log(userId, "AutoMod_InvalidRC", "Player Money was invalid (" .. oldMoney .. "), reset to 0", "Critical")
		end
	end

	if not isValidNumber(data.BankBalance) then
		local oldBank = tostring(data.BankBalance)
		data.BankBalance = 0
		if ExploitLogger then
			ExploitLogger.Log(userId, "AutoMod_InvalidRC", "Player BankBalance was invalid (" .. oldBank .. "), reset to 0", "Critical")
		end
	end

	local totalRC = (data.Money or 0) + (data.BankBalance or 0)
	if totalRC >= RC_LIMIT then
		local oldTotal = totalRC
		data.Money = 0
		data.BankBalance = 0

		local player = Players:GetPlayerByUserId(userId)
		if player then
			-- Use cached events if available, otherwise fallback to lookup
			local eventsFolder = RemoteEvents or ReplicatedStorage:FindFirstChild("RemoteEvents")
			if eventsFolder then
				local UpdateMoneyEvent = eventsFolder:FindFirstChild("UpdateMoney")
				local SendBankDataEvent = eventsFolder:FindFirstChild("SendBankData")
				local NotifyPlayerEvent = eventsFolder:FindFirstChild("NotifyPlayer")
				if UpdateMoneyEvent then UpdateMoneyEvent:FireClient(player, 0) end
				if SendBankDataEvent then SendBankDataEvent:FireClient(player, 0, 2) end
				if NotifyPlayerEvent then NotifyPlayerEvent:FireClient(player, "Warning", "RC limit exceeded! Your balance has been reset.") end
			end
		end

		if ExploitLogger then
			ExploitLogger.Log(userId, "AutoMod_RCReset", "Player RC reset from " .. oldTotal .. " to 0 (exceeded 1T limit)", "Critical")
		end
		return true
	end
	return false
end

function checkAndResetGuildRC(guildId)
	local guild = Guilds[guildId]
	if not guild then return false end

	if (guild.Funds or 0) >= RC_LIMIT then
		local oldFunds = guild.Funds
		guild.Funds = 0

		if ExploitLogger then
			ExploitLogger.Log(guild.OwnerId or 0, "AutoMod_GuildRCReset", "Guild '" .. (guild.Name or guildId) .. "' funds reset from " .. oldFunds .. " to 0 (exceeded 1T limit)", "Critical")
		end

		for _, member in ipairs(guild.Members or {}) do
			if type(member.UserId) == "number" then
				local memberPlayer = Players:GetPlayerByUserId(member.UserId)
				if memberPlayer then
					-- Use cached events if available, otherwise fallback to lookup
					local eventsFolder = RemoteEvents or ReplicatedStorage:FindFirstChild("RemoteEvents")
					if eventsFolder then
						local NotifyPlayerEvent = eventsFolder:FindFirstChild("NotifyPlayer")
						if NotifyPlayerEvent then
							NotifyPlayerEvent:FireClient(memberPlayer, "Warning", "Guild funds limit exceeded! Guild balance has been reset.")
						end
					end
				end
			end
		end
		return true
	end
	return false
end

