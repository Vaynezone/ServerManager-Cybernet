			if guildData then
				-- Initialize guild with loaded data, but recalculate reputation
				Guilds[playerGuildId] = guildData
				-- Always recalculate reputation on load (don't trust saved value)
				-- Use pcall to safely calculate reputation (BountyManager might not be loaded yet)
				local repSuccess, calculatedRep = pcall(function()
					return calculateGuildReputation(Guilds[playerGuildId])
				end)
				if repSuccess and calculatedRep then
					Guilds[playerGuildId].Reputation = calculatedRep
				else
					Guilds[playerGuildId].Reputation = guildData.Reputation or 0
				end
				cachedGuildList[playerGuildId] = true
				-- Create guild network if it doesn't exist
				if not GuildNetworks[playerGuildId] then
					local networkSuccess, _ = pcall(function()
						createGuildNetwork(guildData)
					end)
					if not networkSuccess then
						warn("Failed to create guild network for guild " .. playerGuildId)
					end
				end
			else
				-- Guild no longer exists, clear player's guild membership
				PlayerData[player.UserId].Guild = nil
				queuePlayerSave(player.UserId)
			end
		else
			-- Guild already in memory - merge any missing fields from DataStore to prevent data loss
			-- Always load Funds from DataStore to ensure game-wide persistence (not just server-wide)
			local savedData = DataStoreManager.LoadGuildData(playerGuildId)
			if savedData then
				-- Only merge fields that are nil or missing, preserve existing values for critical fields
				if not Guilds[playerGuildId].Name then Guilds[playerGuildId].Name = savedData.Name end
				if not Guilds[playerGuildId].OwnerId then Guilds[playerGuildId].OwnerId = savedData.OwnerId end
				if not Guilds[playerGuildId].NetworkIP then Guilds[playerGuildId].NetworkIP = savedData.NetworkIP end
