-- Calculate guild reputation from member bounties (moved earlier to avoid local register limit)
function calculateGuildReputation(guild)
	local rep = 0
	if BountyManager and guild and guild.Members then
		for _, member in ipairs(guild.Members) do
			if type(member.UserId) == "number" then
				local policeBounty = BountyManager.FindPoliceBounty(member.UserId)
				if policeBounty and type(policeBounty.Bounty) == "number" then
					rep = rep + policeBounty.Bounty
				end
				local pName = member.Name
				local onlinePlayer = Players:GetPlayerByUserId(member.UserId)
				if onlinePlayer then
					pName = onlinePlayer.Name
				end
				if pName then
					local criminalBounty = BountyManager.FindCriminalBounty(pName, false)
					if criminalBounty and type(criminalBounty.Bounty) == "number" then
						rep = rep + criminalBounty.Bounty
					end
				end
			end
		end
	end
	if rep ~= rep then
		rep = 0
	end
	return math.floor(rep)
end

