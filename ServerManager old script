StealFromNode.OnServerEvent:Connect(function(player, networkId, deviceId)
	-- Get device and network to determine security level
	local data = PlayerData[player.UserId]
	if not data then return end

	local network = getNetwork(networkId, player.UserId)
	if not network then return end

	local device
	for _, d in ipairs(network.Devices or {}) do
		if d.Id == deviceId then
			device = d
			break
		end
	end

	if not device then return end

	-- Get effective security level (device security or network security)
	local securityLevel = device.Security or network.Security or 3
	securityLevel = math.clamp(securityLevel, 1, 5)

	-- Generate typing challenge based on security level (3-10 separate words)
	local challengeWords = generateStealChallenge(securityLevel)
	local challengeId = HttpService:GenerateGUID(false)

	-- Adjust time limit based on word count (more words = more time needed)
	-- Base time per word: 8-12 seconds depending on security
	local baseTimePerWord
	if securityLevel <= 2 then
		baseTimePerWord = 12 -- Easier: more time per word
	elseif securityLevel == 3 then
		baseTimePerWord = 10 -- Medium
	else
		baseTimePerWord = 8 -- Harder: less time per word
	end

	local timeLimit = math.ceil(#challengeWords * baseTimePerWord)
	-- Cap at reasonable limits
	timeLimit = math.min(timeLimit, 120) -- Max 2 minutes
	timeLimit = math.max(timeLimit, 30) -- Min 30 seconds

	-- Store challenge with metadata
	PendingStealChallenges[challengeId] = {
		Player = player,
		UserId = player.UserId,
		NetworkId = networkId,
		DeviceId = deviceId,
		ChallengeWords = challengeWords, -- Array of words to type in sequence
		CurrentWordIndex = 1, -- Track which word they're on
		TotalAttempts = 0, -- Total failed attempts across entire steal
		MaxTotalAttempts = 3, -- Max total attempts before failing entire steal
		TimeLimit = timeLimit,
		CreatedAt = time(),
		ExpiresAt = time() + timeLimit
	}

	-- Send challenge to client with first word
	SendStealChallenge:FireClient(player, challengeId, challengeWords, 1, 3, timeLimit, false)
end)

-- Handle typing challenge answer submission
SubmitStealAnswer.OnServerEvent:Connect(function(player, challengeId, answer)
	local challenge = PendingStealChallenges[challengeId]
	if not challenge then
		NotifyPlayer:FireClient(player, "Error", "Invalid challenge!")
		return
	end

	if challenge.UserId ~= player.UserId then
		NotifyPlayer:FireClient(player, "Error", "Challenge not for you!")
		return
	end

	-- Check if challenge expired (time limit)
	if time() > challenge.ExpiresAt then
		PendingStealChallenges[challengeId] = nil
		SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) -- Close UI
		NotifyPlayer:FireClient(player, "Error", "Time's up! Steal failed.")
		return
	end

	-- Get current word they should be typing
	local currentWordIndex = challenge.CurrentWordIndex
	local currentWord = challenge.ChallengeWords[currentWordIndex]

	if not currentWord then
		-- All words completed somehow, complete the steal
		PendingStealChallenges[challengeId] = nil
		SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) -- Close UI
		if GameActions then
			GameActions.StealFromNode(buildActionParams(player, {
				networkId = challenge.NetworkId,
				deviceId = challenge.DeviceId
			}))
		end
		return
	end

	-- Case-sensitive comparison of current word
	if answer == currentWord then
		-- Correct! Move to next word
		challenge.CurrentWordIndex = challenge.CurrentWordIndex + 1

		-- Check if all words completed
		if challenge.CurrentWordIndex > #challenge.ChallengeWords then
			-- Success! All words typed correctly - Complete the steal
			PendingStealChallenges[challengeId] = nil
			SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) -- Close UI
			if GameActions then
				GameActions.StealFromNode(buildActionParams(player, {
					networkId = challenge.NetworkId,
					deviceId = challenge.DeviceId
				}))
			end
		else
			-- Send next word with updated progress
			local remainingTime = math.max(0, challenge.ExpiresAt - time())
			local remainingAttempts = challenge.MaxTotalAttempts - challenge.TotalAttempts
			SendStealChallenge:FireClient(player, challengeId, challenge.ChallengeWords, challenge.CurrentWordIndex, remainingAttempts, remainingTime, false)
		end
	else
		-- Wrong answer - increment total attempts and change word immediately
		challenge.TotalAttempts = challenge.TotalAttempts + 1

		-- Check if exceeded max total attempts
		if challenge.TotalAttempts >= challenge.MaxTotalAttempts then
			-- Failed entire steal - Close UI
			PendingStealChallenges[challengeId] = nil
			SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) -- Close UI
			NotifyPlayer:FireClient(player, "Error", "Steal failed! Too many incorrect attempts.")
		else
			-- Generate a new word for this position (exclude already used words)
			local usedWords = {}
			for i, word in ipairs(challenge.ChallengeWords) do
				if i ~= currentWordIndex then
					table.insert(usedWords, word)
				end
			end
			local newWord = generateRandomWord(usedWords)
			challenge.ChallengeWords[currentWordIndex] = newWord

			-- Send updated challenge with new word
			local remainingTime = math.max(0, challenge.ExpiresAt - time())
			local remainingAttempts = challenge.MaxTotalAttempts - challenge.TotalAttempts
			SendStealChallenge:FireClient(player, challengeId, challenge.ChallengeWords, challenge.CurrentWordIndex, remainingAttempts, remainingTime, false)

			-- Send notification (works for both UI and terminal)
			if challenge.IsTerminal then
				-- Terminal will handle display via SendStealChallenge
			else
				NotifyPlayer:FireClient(player, "Error", "Incorrect! Word changed. " .. remainingAttempts .. " attempt(s) remaining.")
			end
		end
	end
end)

GetTransactionLogs.OnServerEvent:Connect(function(player, networkId, deviceId)
	local data = PlayerData[player.UserId]
	if not data then return end

	local isLoggedIn = AccessCodeSystem.IsLoggedIn(player.UserId, networkId, deviceId)

	if not isLoggedIn then
		TerminalResponse:FireClient(player, "ERROR: You must be logged in to view logs!")
		return
	end

	local transactionLogs = AccessCodeSystem.GetTransactionLogs(networkId, deviceId)
	local connectionLogs = AccessCodeSystem.GetConnectionLogs(networkId, deviceId)

	local logText = "=== SYSTEM LOGS ===\n\n"

	logText = logText .. "-- Connection Logs --\n"
	if #connectionLogs == 0 then
		logText = logText .. "No connection activity recorded.\n"
	else
		for i = math.max(1, #connectionLogs - 9), #connectionLogs do
			local log = connectionLogs[i]
			local timeAgo = math.floor(os.time() - log.Time)
			local status = log.Success and "SUCCESS" or "FAILED"
			logText = logText .. string.format("[%s] %s from %s (%ds ago)\n", 
				status, log.Action, log.UserIP, timeAgo)
		end
	end

	logText = logText .. "\n-- Transaction Logs --\n"
	if #transactionLogs == 0 then
		logText = logText .. "No transactions recorded.\n"
	else
		for i = math.max(1, #transactionLogs - 9), #transactionLogs do
			local log = transactionLogs[i]
			local timeAgo = math.floor(os.time() - log.Time)
			logText = logText .. string.format("%s %d RC from %s (%ds ago)\n", 
				log.Type, log.Amount, log.SourceIP, timeAgo)
		end
	end

	TerminalResponse:FireClient(player, logText)
end)

GetConnectionLogs.OnServerEvent:Connect(function(player, networkId, deviceId)
