function registerOperation(userId, nodeId, operationType, security, isDevice)
	if not ActiveOperations[userId] then
		ActiveOperations[userId] = {}
	end
	local operationId = nodeId .. "_" .. time()
	local resourceCost = getOperationResourceCost(operationType, security)
	local usesNET = operationType == "ScanNetwork" or operationType == "ScanDevice" or operationType == "ScanForNetworks"
	local netShare = usesNET and (1 / (countActiveNETOperations(userId) + 1)) or nil

	ActiveOperations[userId][operationId] = {
		NodeId = nodeId,
		Type = operationType,
		Cancelled = false,
		ResourceCost = resourceCost,
		StartTime = time(),
		UsesNET = usesNET,
		NETShare = netShare,
		Progress = usesNET and 0 or nil,
		IsDevice = isDevice
	}
	updatePlayerResourceUsage(userId)
	if usesNET then
		recalculateNETShares(userId)
	end
	return operationId
end

function isOperationActive(userId, operationId)
	return ActiveOperations[userId] and 
		ActiveOperations[userId][operationId] and 
		not ActiveOperations[userId][operationId].Cancelled
end

function unregisterOperation(userId, operationId)
	if ActiveOperations[userId] then
		ActiveOperations[userId][operationId] = nil
		updatePlayerResourceUsage(userId)
		recalculateNETShares(userId)
	end
end

function getActiveNETOperations(userId)
	if not ActiveOperations[userId] then return {} end
	local netOps = {}
	for opId, operation in pairs(ActiveOperations[userId]) do
		if not operation.Cancelled and operation.UsesNET then
			netOps[opId] = operation
		end
	end
	return netOps
end

function countActiveNETOperations(userId)
	local count = 0
	if ActiveOperations[userId] then
		for _, operation in pairs(ActiveOperations[userId]) do
			if not operation.Cancelled and operation.UsesNET then
				count = count + 1
			end
		end
	end
	return count
end

function recalculateNETShares(userId)
	local player = Players:GetPlayerByUserId(userId)
	if not player then return end

	local netOps = getActiveNETOperations(userId)
	local opCount = 0
	for _ in pairs(netOps) do opCount = opCount + 1 end
	if opCount == 0 then return end

	local share = 1 / opCount
	for opId, operation in pairs(netOps) do
		local oldShare = operation.NETShare or 1
		operation.NETShare = share
		if oldShare ~= share and operation.Progress then
			UpdateScanProgress:FireClient(player, operation.NodeId, operation.Progress, share, operation.IsDevice)
		end
	end
end

function safeUnregisterOperation(userId, operationId)
	pcall(function()
		unregisterOperation(userId, operationId)
	end)
end

function safeDecrementOperations(player)
	pcall(function()
		if PlayerData[player.UserId] then
			decrementOperations(player)
		end
	end)
end
function cleanupOperation(player, operationId)
	if player and player.UserId and operationId then
		safeUnregisterOperation(player.UserId, operationId)
		safeDecrementOperations(player)
	end
end

function cleanupStaleOperations(userId)
	if not ActiveOperations[userId] then return end

	local currentTime = time()
	local staleTime = 300
	local cleaned = false

	for operationId, operation in pairs(ActiveOperations[userId]) do
		if operation.StartTime and (currentTime - operation.StartTime) > staleTime then
			ActiveOperations[userId][operationId] = nil
			cleaned = true
		end
	end

	if cleaned then
		if PlayerData[userId] then
			local actualCount = 0
			for _ in pairs(ActiveOperations[userId]) do
				actualCount = actualCount + 1
			end
			PlayerData[userId].ActiveOperationsCount = actualCount
		end
		updatePlayerResourceUsage(userId)
	end
end

function cleanupAllStaleOperations()
	for userId, _ in pairs(ActiveOperations) do
		cleanupStaleOperations(userId)
	end
end

function cancelAllPlayerOperations(player)
	local userId = player.UserId
	if ActiveOperations[userId] then
		for operationId, operation in pairs(ActiveOperations[userId]) do
			operation.Cancelled = true
			if operation.Type == "ScanForNetworks" then
				CancelScanForNetworks:FireClient(player)
			else
				CancelProgressBar:FireClient(player, operation.NodeId)
			end
		end
		ActiveOperations[userId] = {}
		if PlayerData[userId] then
			PlayerData[userId].ActiveOperationsCount = 0
		end
		updatePlayerResourceUsage(userId)
	end
end

