BankDeposit.OnServerEvent:Connect(function(player, amount)
	local data = PlayerData[player.UserId]
	if not data then return end

	if not isValidNumber(amount) then
		NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	-- Round to 3 decimal places and allow amounts >= 0.001
	amount = math.floor(amount * 1000 + 0.5) / 1000

	if amount < 0.001 then
		NotifyPlayer:FireClient(player, "Error", "Minimum deposit amount is 0.001 RC!")
		return
	end

	if amount > RC_LIMIT then
		NotifyPlayer:FireClient(player, "Error", "Amount too large!")
		return
	end

	-- Round player's money to 3 decimal places for consistent comparison
	local playerMoney = math.floor((data.Money or 0) * 1000 + 0.5) / 1000

	-- Use epsilon comparison to handle floating point precision issues
	if playerMoney < amount - 0.0001 then
		NotifyPlayer:FireClient(player, "Error", "Not enough RC to deposit!")
		return
	end

	local fee = math.floor(amount * 0.025 * 1000 + 0.5) / 1000
	local depositAmount = math.floor((amount - fee) * 1000 + 0.5) / 1000

	data.Money = data.Money - amount
	data.BankBalance = (data.BankBalance or 0) + depositAmount
	checkAndResetPlayerRC(player.UserId)

	UpdateMoney:FireClient(player, data.Money)

	-- CRITICAL FIX: Save money and bank balance synchronously using buildSaveData
	-- This ensures we save the current PlayerData values, not stale loaded data
	pcall(function()
		-- Use buildSaveData to get current PlayerData values (includes Money and BankBalance)
		local saveData = buildSaveData(player.UserId)
		if saveData then
			-- Ensure Money and BankBalance are set correctly from current PlayerData
			saveData.Money = data.Money
			saveData.BankBalance = data.BankBalance
			DataStoreManager.SaveAllPlayerData(player.UserId, saveData, true) -- force = true for synchronous save
		end
	end)

	SendBankData:FireClient(player, data.BankBalance, 2)

	-- CRITICAL FIX: Update ProgramStoreServer cache to keep it in sync
	-- This prevents the store from using stale wallet amounts after bank deposits
	if _G.ProgramStoreServerUpdateMoneyCache then
		_G.ProgramStoreServerUpdateMoneyCache(player.UserId, data.Money, data.BankBalance)
	end

	-- Mark player data as dirty to ensure it gets saved
	markPlayerDirty(player.UserId)

	NotifyPlayer:FireClient(player, "Success", "Deposited " .. depositAmount .. " RC! (Fee: " .. fee .. " RC)")
	if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, amount, "BankDeposit", "Deposited " .. depositAmount .. " RC") end
end)

