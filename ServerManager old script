-- NEW FEATURE: Black Market Selling
local SellSpecialItem = RemoteEvents:FindFirstChild("SellSpecialItem")
if SellSpecialItem then
	SellSpecialItem.OnServerEvent:Connect(function(player, itemIndex)
		local data = PlayerData[player.UserId]
		if not data then return end

		-- Check if player is on a black market network
		local currentNet = getNetwork(data.CurrentNetwork, player.UserId)
		if not currentNet then
			NotifyPlayer:FireClient(player, "Error", "You must be on a Black Market Hub to sell items!")
			return
		end

		local networkTypeData = GameData.NetworkTypes[currentNet.Type]
		if not networkTypeData or not networkTypeData.CanSellTopSecret then
			NotifyPlayer:FireClient(player, "Error", "You must be on a Black Market Hub to sell items!")
			return
		end

		-- Get special items from PlayerData or datastore
		local specialItems = data.SpecialItems or {}
		if #specialItems == 0 then
			local UnifiedStore = DataStoreService:GetDataStore("UnifiedPlayerData" .. ver)
			local success, savedString = pcall(function()
				return UnifiedStore:GetAsync("Player_" .. player.UserId)
			end)

			if success and savedString then
				local decodeSuccess, savedData = pcall(function()
					return HttpService:JSONDecode(savedString)
				end)
				if decodeSuccess and savedData and savedData.SpecialItems then
					specialItems = savedData.SpecialItems
					data.SpecialItems = specialItems
				end
			end
		end

		-- Check if player has special items
		if #specialItems == 0 then
			NotifyPlayer:FireClient(player, "Error", "You have no special items to sell!")
			return
		end

		if itemIndex < 1 or itemIndex > #specialItems then
			NotifyPlayer:FireClient(player, "Error", "Invalid item index!")
			return
		end

		local item = specialItems[itemIndex]
		local itemValue = item.Value or 0

		-- Remove item and give money
		table.remove(specialItems, itemIndex)
		data.SpecialItems = specialItems
		data.Money = (data.Money or 0) + itemValue

		-- Save to datastore
		local UnifiedStore = DataStoreService:GetDataStore("UnifiedPlayerData" .. ver)
		pcall(function()
			local savedString = UnifiedStore:GetAsync("Player_" .. player.UserId)
			if savedString then
				local savedData = HttpService:JSONDecode(savedString)
				if savedData then
					savedData.SpecialItems = specialItems
					savedData.Money = data.Money
					UnifiedStore:SetAsync("Player_" .. player.UserId, HttpService:JSONEncode(savedData))
				end
			end
		end)

		UpdateMoney:FireClient(player, data.Money)
		SendSpecialItems:FireClient(player, specialItems)
		NotifyPlayer:FireClient(player, "Success", "Sold " .. (item.Type == "NuclearLaunchCodes" and "Nuclear Launch Codes" or "Police Database") .. " for " .. itemValue .. " RC!")
		markPlayerDirty(player.UserId)
		pcall(function()
			DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
		end)
	end)
end

