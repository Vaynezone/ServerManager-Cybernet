AcceptMission.OnServerEvent:Connect(function(player, missionId, faction)
	local userId = player.UserId
	local data = PlayerData[userId]
	if not data then return end

	local success, mission = MissionsConfig.AcceptMission(userId, missionId, faction)

	if not success then
		NotifyPlayer:FireClient(player, "Error", "Mission not found!")
		return
	end

	local function ensureNetworkAccess(networkId)
		if not networkId then return end

		local alreadyHas = false
		for _, playerNet in ipairs(data.Networks) do
			if playerNet.Id == networkId then
				alreadyHas = true
				break
			end
		end

		if not alreadyHas then
			for _, globalNet in ipairs(GlobalNetworks) do
				if globalNet.Id == networkId then
					local netCopy = {
						Id = globalNet.Id,
						IP = globalNet.IP,
						Name = globalNet.Name,
						Type = globalNet.Type,
						Security = globalNet.Security,
						AdminTier = globalNet.AdminTier,
						HasAdmin = globalNet.HasAdmin,
						Scanned = false,
						Hacked = false,
						Owner = globalNet.Owner,
						Locked = false,
						LockExpiry = 0,
						TracesReceived = 0,
						Devices = {},
						ConnectedNetworks = {},
						Position = Vector2.new(math.random(-200, 200), math.random(-200, 200)),
						Visible = true,
						AccessCode = globalNet.AccessCode,
						Firewall = sanitizeFirewall(globalNet.Firewall),
						FirewallBypassed = false
					}

					for _, dev in ipairs(globalNet.Devices) do
						table.insert(netCopy.Devices, {
							Id = dev.Id,
							Type = dev.Type,
							Name = dev.Name,
							Security = dev.Security,
							Icon = dev.Icon,
							Scanned = false,
							Hacked = false,
							IsPlayerComputer = false,
							LANIP = dev.LANIP,
							AccessCode = dev.AccessCode,
							Firewall = sanitizeFirewall(dev.Firewall),
							FirewallBypassed = false,
							ParentMainframe = dev.ParentMainframe,
							SubDevices = dev.SubDevices,
							IsMainframe = dev.IsMainframe,
							IsSpecialDevice = dev.IsSpecialDevice
						})
					end

					table.insert(data.Networks, netCopy)
					break
				end
			end
		end
	end

	if mission.TargetNetworkId then
		ensureNetworkAccess(mission.TargetNetworkId)
	end
	if mission.BaseNetworkId then
		ensureNetworkAccess(mission.BaseNetworkId)
	end
	if mission.StartNetworkId then
		ensureNetworkAccess(mission.StartNetworkId)
	end

	local clientNetworks = prepareNetworksForClient(data.Networks, userId)
	SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)

	local factionName = faction == "NetSec" and "NetSec Authority" or "The Void Network"
	local mailId = HttpService:GenerateGUID(false)
	local mail = {
		Id = mailId,
		From = factionName,
		Subject = "Mission Assignment - " .. mission.TypeName .. " - " .. mission.Stars .. " Stars",
		Message = mission.Description .. "\n\nReward: " .. mission.Reward .. " RC\nDifficulty: " .. string.rep("⭐", mission.Stars) .. "\n\nComplete this mission and reply to this message with your findings.",
		Timestamp = os.time(),
		Read = false,
		Type = "MissionMail",
		MissionId = missionId,
		Faction = faction,
		Responded = false
	}

	saveMail(userId, mail)

	local userMail = loadMail(userId)
	SendMailData:FireClient(player, filterMailData(userMail, userId))

	NotifyPlayer:FireClient(player, "Success", "Mission accepted! Check your mail.")

	local missions = MissionsConfig.GetMissions(faction, GlobalNetworks)
	local playerMissions = MissionsConfig.PlayerMissions[userId] or {}
	local acceptedMissionIds = {}
	for _, pm in ipairs(playerMissions) do
		acceptedMissionIds[pm.MissionId] = true
	end

	local filteredMissions = {}
	for _, m in ipairs(missions) do
		if not acceptedMissionIds[m.Id] then
			table.insert(filteredMissions, m)
		end
	end

	SendMissions:FireClient(player, faction, filteredMissions)
end)

ReplyToMail.OnServerEvent:Connect(function(player, mailId, replyText)
	local userId = player.UserId
	local data = PlayerData[userId]
	if not data then return end

	local mail = loadMail(userId)
	local targetMail = nil

	for _, m in ipairs(mail) do
		if m.Id == mailId then
			targetMail = m
			break
		end
	end

	if not targetMail then
		NotifyPlayer:FireClient(player, "Error", "Mail not found!")
		return
	end

	if targetMail.Type == "MissionMail" then
		local mission = MissionsConfig.GetAcceptedMission(userId, targetMail.MissionId)

		if not mission then
			for _, m in ipairs(MissionsConfig.ActiveMissions[targetMail.Faction] or {}) do
				if m.Id == targetMail.MissionId then
					mission = m
					break
				end
			end
		end

		if not mission then
			updateMailById(userId, mailId, {
				Expired = true,
				Subject = targetMail.Subject .. " [EXPIRED]"
			})

			local userMail = loadMail(userId)
			SendMailData:FireClient(player, filterMailData(userMail, userId))

			NotifyPlayer:FireClient(player, "Error", "Mission expired - not available on this server!")
			return
		end

		if mission.Type == "GetConnectedIPs" then
			if not mission.ConnectedNetworks then
				local targetNet = nil
				for _, network in ipairs(GlobalNetworks) do
					if network.Id == mission.TargetNetworkId then
						targetNet = network
						break
					end
				end

				if targetNet and targetNet.ConnectedNetworks then
					mission.ConnectedNetworks = {}
					for _, connId in ipairs(targetNet.ConnectedNetworks) do
						for _, network in ipairs(GlobalNetworks) do
							if network.Id == connId then
								table.insert(mission.ConnectedNetworks, {IP = network.IP})
								break
							end
						end
					end
				end
			end
		elseif mission.Type == "StealFromDevice" then
			local hasStolen = false
			local targetNet = nil
			for _, network in ipairs(GlobalNetworks) do
				if network.Id == mission.TargetNetworkId then
					targetNet = network
					break
				end
			end

			if targetNet and AccessCodeSystem.ConnectionLogs then
				for _, device in ipairs(targetNet.Devices) do
					local logId = mission.TargetNetworkId .. "_" .. device.Id
					local logs = AccessCodeSystem.ConnectionLogs[logId]
					if logs then
						for _, log in ipairs(logs) do
							if log.Action == "Steal" and log.User == player.Name then
								hasStolen = true
								break
							end
						end
					end
					if hasStolen then break end
				end
			end

			if not hasStolen then
				local factionName = targetMail.Faction == "NetSec" and "NetSec Authority" or "The Void Network"

				if not targetMail.Replies then
					targetMail.Replies = {}
				end

				local reply = {
					From = factionName,
					Message = "We have no record of a theft from the target network yet. Complete the mission and reply again.",
					Timestamp = os.time()
				}

				table.insert(targetMail.Replies, reply)
				updateMailById(userId, mailId, {Replies = targetMail.Replies})

				local userMail = loadMail(userId)
				SendMailData:FireClient(player, filterMailData(userMail, userId))

				NotifyPlayer:FireClient(player, "Info", "Mission not complete yet")
				return
			end
		end

		-- Fix: Ensure mission validation has access to complete mission data
		local isComplete = MissionsConfig.ValidateMissionCompletion(mission, replyText)

		local factionName = targetMail.Faction == "NetSec" and "NetSec Authority" or "The Void Network"

		if isComplete then
			-- Fix: Verify mission completion was properly recorded
			local completionSuccess = MissionsConfig.CompleteMission(userId, mission.Id)
			if not completionSuccess then
				warn("[MISSIONS] Failed to mark mission as complete for user " .. userId .. ", mission " .. (mission.Id or "unknown"))
			end

			-- `mission.Reward` is already scaled by `MissionsConfig.calculateReward()`
			-- which applies `GameData.MoneyMultiplier`. Do not apply the multiplier again.
			local missionReward = mission.Reward or 0
			data.Money = data.Money + missionReward
			checkAndResetPlayerRC(player.UserId)
			UpdateMoney:FireClient(player, data.Money)
			pcall(function()
				DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
			end)

			if not targetMail.Replies then
				targetMail.Replies = {}
			end

			local reply = {
				From = factionName,
				Message = "Excellent work! Mission completed successfully.\n\nReward: " .. mission.Reward .. " RC has been deposited to your account.",
				Timestamp = os.time()
			}

			table.insert(targetMail.Replies, reply)
			updateMailById(userId, mailId, {
				Responded = true,
				Replies = targetMail.Replies
			})

			local userMail = loadMail(userId)
			SendMailData:FireClient(player, filterMailData(userMail, userId))

			NotifyPlayer:FireClient(player, "Success", "Mission completed! +" .. mission.Reward .. " RC")

			local isCriminal = targetMail.Faction == "Void"
			if isCriminal then
				adjustReputation(player, -(mission.Stars * 2), "Completed Criminal Mission")
			else
				adjustReputation(player, mission.Stars * 2, "Completed Police Mission")
			end
		else
			if not targetMail.Replies then
				targetMail.Replies = {}
			end

			local reply = {
				From = factionName,
				Message = "The information provided does not match our requirements. Please verify and submit again.",
				Timestamp = os.time()
			}

			table.insert(targetMail.Replies, reply)
			updateMailById(userId, mailId, {Replies = targetMail.Replies})

			local userMail = loadMail(userId)
			SendMailData:FireClient(player, filterMailData(userMail, userId))

			NotifyPlayer:FireClient(player, "Info", "Mission not complete yet")
		end
	end
end)


