function applyBankInterest(userId)
	local data = PlayerData[userId]
	if not data then return end

	local savedData = loadPlayerData(userId)
	if not savedData or not savedData.LastLoginTime then return end

	local lastLogin = savedData.LastLoginTime
	local currentTime = os.time()
	local daysPassed = math.floor((currentTime - lastLogin) / 86400)

	if daysPassed > 0 and data.BankBalance > 0 then
		local interestRate = 0.02
		local totalInterest = 0

		for day = 1, daysPassed do
			local dailyInterest = math.floor(data.BankBalance * interestRate)
			data.BankBalance = data.BankBalance + dailyInterest
			totalInterest = totalInterest + dailyInterest
		end

		if totalInterest > 0 then
			NotifyPlayer:FireClient(Players:GetPlayerByUserId(userId), "Success", "Earned " .. totalInterest .. " RC from " .. daysPassed .. " day(s) of bank interest!")
		end
	end
end

function generateStartingParts()
	local parts = {}

	local startingMotherboard = PCPartsData.GetMotherboard(1)
	local cpuSocket = startingMotherboard.Slots.CPUType
	local ramType = startingMotherboard.Slots.RAMType

	local cpu = PCPartsData.GeneratePart("CPU", 1, cpuSocket)
	cpu.IsStartingPart = true
	table.insert(parts, cpu)

