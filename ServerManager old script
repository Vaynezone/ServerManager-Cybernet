						return
					end
				end
			end

			local connectionLogs = AccessCodeSystem.GetConnectionLogs(targetNet.Id, targetDevice and targetDevice.Id or nil)

			local logText = "=== CONNECTION LOGS ===\n\n"

			if #connectionLogs == 0 then
				logText = logText .. "No connection activity recorded.\n"
			else
				for i = math.max(1, #connectionLogs - 9), #connectionLogs do
					local log = connectionLogs[i]
					local timeAgo = math.floor(os.time() - log.Time)
					local status = log.Success and "SUCCESS" or "FAILED"
					logText = logText .. string.format("[%s] %s from %s (%ds ago)\n", 
						status, log.Action, log.UserIP, timeAgo)
				end
			end

			TerminalResponse:FireClient(player, logText)
		end
	elseif commandLower == "reset_protocol" or commandLower == "reset" then

		ResetNetworks:FireServer(player)
	elseif commandLower == "program" then
		if #args == 0 then
			TerminalResponse:FireClient(player, "Usage: program <action> [name] [target]\n  Actions:\n    list    - List all programs\n    running - List running programs\n    start <name> [target_ip] - Start a program\n    stop <name> - Stop a running program")
			return
		end

		local action = args[1]:lower()
		local programName = args[2]
		local targetIP = args[3]

		local progBindables = ReplicatedStorage:FindFirstChild("ProgramBindables")

		if action == "list" then
			local programList = "=== PROGRAMS ===\n\n"
			local count = 0

			local ProgramsStore = DataStoreService:GetDataStore("PlayerPrograms")
			local success, encoded = pcall(function()
				return ProgramsStore:GetAsync("Programs_" .. userId)
			end)

			local userPrograms = {}
			if success and encoded then
				local decoded = game:GetService("HttpService"):JSONDecode(encoded)
				if decoded then
					userPrograms = decoded
				end
			end

			for _, prog in ipairs(PrebuiltPrograms.GetAll()) do
				userPrograms[prog.Id] = game:GetService("HttpService"):JSONEncode(prog)
			end

			for id, serialized in pairs(userPrograms) do
				local program = ProgramManagerModule.DeserializeProgram(serialized)
				if program then
					count = count + 1
					local prebuilt = program.IsPrebuilt and " [Prebuilt]" or ""
					programList = programList .. "  " .. program.Name .. prebuilt .. "\n"
				end
			end

			if count == 0 then
				programList = programList .. "  No programs found.\n"
			end

			TerminalResponse:FireClient(player, programList)

		elseif action == "running" then
			if progBindables then
				local getRunning = progBindables:FindFirstChild("GetRunningPrograms")
				if getRunning then
					local running = getRunning:Invoke(player)
					local runningList = "=== RUNNING PROGRAMS ===\n\n"
					if running and #running > 0 then
						for _, info in ipairs(running) do
							local elapsed = os.time() - (info.StartTime or 0)
							runningList = runningList .. "  " .. info.Name .. " (running for " .. elapsed .. "s)\n"
						end
					else
						runningList = runningList .. "  No programs running.\n"
					end
					TerminalResponse:FireClient(player, runningList)
				end
			end

		elseif action == "start" then
			if not programName then
				TerminalResponse:FireClient(player, "ERROR: Usage: program start <name> [target_ip]")
				return
			end

			local contextType = "None"
			local targetId = nil

			if targetIP then
				for _, network in ipairs(data.Networks) do
					if network.IP == targetIP then
						contextType = "Network"
						targetId = network.Id
						break
					end
				end

				if not targetId then
					TerminalResponse:FireClient(player, "ERROR: Network " .. targetIP .. " not found")
					return
				end
			end

			if progBindables then
				local startProg = progBindables:FindFirstChild("StartProgram")
				if startProg then
					local success, result = startProg:Invoke(player, programName, contextType, targetId, nil)
					if not success then
						TerminalResponse:FireClient(player, "ERROR: " .. (result or "Failed to start program"))
					end
				end
			end

		elseif action == "stop" then
			if not programName then
				TerminalResponse:FireClient(player, "ERROR: Usage: program stop <name>")
				return
			end

			if progBindables then
				local stopProg = progBindables:FindFirstChild("StopProgramByName")
				if stopProg then
					local success, result = stopProg:Invoke(player, programName)
					if not success then
						TerminalResponse:FireClient(player, "ERROR: " .. (result or "Failed to stop program"))
					end
				end
			end
		else
			TerminalResponse:FireClient(player, "ERROR: Unknown action '" .. action .. "'. Use: list, running, start, stop")
		end
	else

		warn("[TerminalCommand] Unknown command received: '" .. tostring(command) .. "' (lowercase: '" .. tostring(commandLower) .. "')")
		TerminalResponse:FireClient(player, "ERROR: Unknown command '" .. (command or "") .. "'. Type 'help' for a list of commands.")
	end
end)

