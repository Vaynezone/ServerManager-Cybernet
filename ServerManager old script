-- Return a minimal, safe firewall description or nil. Prevents passing unexpected objects to clients
local function sanitizeFirewall(fw)
	if type(fw) ~= "table" then return nil end
	local ok, lib = pcall(function() return fw.Library end)
	local ok2, ver = pcall(function() return fw.Version end)
	local ok3, has = pcall(function() return fw.HasFirewall end)
	return {
		Library = tostring(lib or ""),
		Version = tostring(ver or ""),
		HasFirewall = (has == true) or (fw.HasFirewall == true) or false,
	}
end


