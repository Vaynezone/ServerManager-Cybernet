				for i = math.max(1, #transactionLogs - 9), #transactionLogs do
					local log = transactionLogs[i]
					local timeAgo = math.floor(os.time() - log.Time)
					logText = logText .. string.format("%s %d RC from %s (%ds ago)\n", 
						log.Type, log.Amount, log.SourceIP, timeAgo)
				end
			end

			TerminalResponse:FireClient(player, logText)
		end
	elseif commandLower == "connectionlogs" then
		if #args == 0 then
			if not data.LoggedInNetwork then
				TerminalResponse:FireClient(player, "ERROR: Usage: connectionlogs <IP> [LAN_IP]\nOr: connectionlogs <LAN_IP> (on current network)\nYou must be logged into a network or device to view connection logs")
				return
			end

			local connectionLogs = AccessCodeSystem.GetConnectionLogs(data.LoggedInNetwork, data.LoggedInDevice)

			local logText = "=== CONNECTION LOGS ===\n\n"

			if #connectionLogs == 0 then
				logText = logText .. "No connection activity recorded.\n"
			else
				for i = math.max(1, #connectionLogs - 9), #connectionLogs do
					local log = connectionLogs[i]
					local timeAgo = math.floor(os.time() - log.Time)
					local status = log.Success and "SUCCESS" or "FAILED"
					logText = logText .. string.format("[%s] %s from %s (%ds ago)\n", 
						status, log.Action, log.UserIP, timeAgo)
				end
			end

			TerminalResponse:FireClient(player, logText)
		else
			local arg1 = args[1]
			local arg2 = args[2]
			local targetNet = nil
			local targetDevice = nil

			if arg2 then
				for _, network in ipairs(data.Networks) do
					if network.IP == arg1 then
						targetNet = network
						break
					end
				end

				if not targetNet then
					TerminalResponse:FireClient(player, "ERROR: Network " .. arg1 .. " not found")
					return
				end

				for _, dev in ipairs(targetNet.Devices) do
					if dev.LANIP == arg2 then
						targetDevice = dev
						break
					end
				end

				if not targetDevice then
					TerminalResponse:FireClient(player, "ERROR: Device " .. arg2 .. " not found on network " .. arg1)
					return
				end

				if not AccessCodeSystem.IsLoggedIn(player.UserId, targetNet.Id, targetDevice.Id) then
					TerminalResponse:FireClient(player, "ERROR: You must be logged into device " .. targetDevice.LANIP .. " to view logs")
					return
				end
			else
				if not data.CurrentNetwork then
					TerminalResponse:FireClient(player, "ERROR: Not connected to any network. Usage: connectionlogs <IP> [LAN_IP]")
