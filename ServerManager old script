					-- Restore other important data
					if legacyData.Level and legacyData.Level > 0 and (not savedData.Level or savedData.Level == 0) then
						savedData.Level = legacyData.Level
						savedData.Experience = legacyData.Experience or savedData.Experience or 0
						warn("[DATA RESTORE] Restored Level: " .. legacyData.Level .. " for player: " .. player.Name)
					end

					if legacyData.Reputation and (not savedData.Reputation or savedData.Reputation == 0) then
						savedData.Reputation = legacyData.Reputation
					end

					-- Save the restored data
					if DataStoreManager and DataStoreManager.SaveAllPlayerData then
