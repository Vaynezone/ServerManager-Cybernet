function addNetworkConnection(network1, network2)
	if not network1.ConnectedNetworks then
		network1.ConnectedNetworks = {}
	end
	if not network2.ConnectedNetworks then
		network2.ConnectedNetworks = {}
	end

	local alreadyConnected1 = false
	for _, connId in ipairs(network1.ConnectedNetworks) do
		if connId == network2.Id then
			alreadyConnected1 = true
			break
		end
	end

	if not alreadyConnected1 then
		-- NEW FEATURE: Maximum connections limit on home networks
		if network1.IsPlayerHome then
			local maxConnections = GameData.MaxHomeNetworkConnections or 50
			if #network1.ConnectedNetworks >= maxConnections then
				-- Find the player who owns this home network
				for userId, data in pairs(PlayerData) do
					if data.HomeNetwork == network1.Id then
						local player = Players:GetPlayerByUserId(userId)
						if player then
							NotifyPlayer:FireClient(player, "Error", "Home network connection limit reached (" .. maxConnections .. ")! Remove some connections first.")
						end
						break
					end
				end
				return
			end
		end
		table.insert(network1.ConnectedNetworks, network2.Id)
	end

	local alreadyConnected2 = false
	for _, connId in ipairs(network2.ConnectedNetworks) do
		if connId == network1.Id then
			alreadyConnected2 = true
			break
		end
	end

	if not alreadyConnected2 then
		table.insert(network2.ConnectedNetworks, network1.Id)
	end
end

-- Changed from local function to regular function to avoid local register limit
function removeNetworkConnection(network1, network2)
	if network1.ConnectedNetworks then
		for i, connId in ipairs(network1.ConnectedNetworks) do
			if connId == network2.Id then
				table.remove(network1.ConnectedNetworks, i)
				break
			end
		end
	end

	if network2.ConnectedNetworks then
		for i, connId in ipairs(network2.ConnectedNetworks) do
			if connId == network1.Id then
				table.remove(network2.ConnectedNetworks, i)
				break
			end
		end
	end
end

function getNetwork(networkId, userId)
