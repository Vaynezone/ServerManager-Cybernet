BankTransfer.OnServerEvent:Connect(function(player, targetUsername, amount)
	local data = PlayerData[player.UserId]
	if not data then return end

	if not targetUsername or targetUsername == "" then
		NotifyPlayer:FireClient(player, "Error", "Invalid username!")
		return
	end

	if not isValidNumber(amount) then
		NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	amount = math.floor(amount)
	if amount <= 0 then
		NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	if amount > RC_LIMIT then
		NotifyPlayer:FireClient(player, "Error", "Amount too large!")
		return
	end

	local fee = math.floor(amount * 0.025)
	local transferAmount = amount - fee

	local targetUserId
	local success, result = pcall(function()
		return Players:GetUserIdFromNameAsync(targetUsername)
	end)

	if not success or not result then
		NotifyPlayer:FireClient(player, "Error", "Player '" .. targetUsername .. "' not found!")
		return
	end

	targetUserId = result

	if targetUserId == player.UserId then
		NotifyPlayer:FireClient(player, "Error", "Cannot transfer to yourself!")
		return
	end

	-- Calculate available funds: on-hand money + bank balance
	local currentMoney = data.Money or 0
	local currentBankBalance = data.BankBalance or 0
	local totalAvailable = currentMoney + currentBankBalance

	if totalAvailable < amount then
		NotifyPlayer:FireClient(player, "Error", "Insufficient funds! You have " .. currentMoney .. " RC on-hand and " .. currentBankBalance .. " RC in bank.")
		return
	end

	-- Deduct from on-hand money first, then from bank if needed
	local remainingAmount = amount
	local fromMoney = math.min(remainingAmount, currentMoney)
	remainingAmount = remainingAmount - fromMoney
	local fromBank = remainingAmount

	-- Deduct from on-hand money
	if fromMoney > 0 then
		data.Money = currentMoney - fromMoney
	end

	-- Deduct remainder from bank balance
	if fromBank > 0 then
		data.BankBalance = currentBankBalance - fromBank
	end

	markPlayerDirty(player.UserId)

	-- Check RC limits after deduction
	checkAndResetPlayerRC(player.UserId)

	-- Force immediate save to ensure changes are persisted
	saveAllPlayerData(player.UserId, true)

	-- Update client with the new balances
	UpdateMoney:FireClient(player, data.Money or 0)
	SendBankData:FireClient(player, data.BankBalance or 0, 2)

	local targetPlayer = Players:GetPlayerByUserId(targetUserId)
	if targetPlayer and PlayerData[targetUserId] then
		PlayerData[targetUserId].BankBalance = (PlayerData[targetUserId].BankBalance or 0) + transferAmount
		markPlayerDirty(targetUserId)
		checkAndResetPlayerRC(targetUserId)
		SendBankData:FireClient(targetPlayer, PlayerData[targetUserId].BankBalance, 2)
		NotifyPlayer:FireClient(targetPlayer, "Success", "Received " .. transferAmount .. " RC from " .. player.Name .. "!")
	else
		local targetData = DataStoreManager.LoadAllPlayerData(targetUserId)
		if targetData and type(targetData.BankBalance) == "number" then
			targetData.BankBalance = (targetData.BankBalance or 0) + transferAmount
			DataStoreManager.SaveAllPlayerData(targetUserId, targetData, true)
		else
			-- Revert the deduction if target player data failed to load or is invalid
			data.Money = currentMoney
			data.BankBalance = currentBankBalance
			markPlayerDirty(player.UserId)
			checkAndResetPlayerRC(player.UserId)
			UpdateMoney:FireClient(player, data.Money)
			pcall(function()
				DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
			end)
			SendBankData:FireClient(player, data.BankBalance, 2)
			NotifyPlayer:FireClient(player, "Error", "Failed to transfer: target player data not found!")
			return
		end
	end

	NotifyPlayer:FireClient(player, "Success", "Transferred " .. transferAmount .. " RC to " .. targetUsername .. "! (Fee: " .. fee .. " RC)")
	if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, amount, "BankTransfer", "Transferred to " .. targetUsername) end
end)

