	end

	if targetMail.Claimed then
		NotifyPlayer:FireClient(player, "Error", "This reward has already been claimed!")
		return
	end

	if not targetMail.Money or targetMail.Money <= 0 then
		NotifyPlayer:FireClient(player, "Error", "This mail does not contain any money!")
		return
	end

	-- Only allow claiming from mail types that support money
	if targetMail.Type ~= "BountyReward" and targetMail.Type ~= "BountyRefund" and targetMail.Type ~= "PlayerMail" then
		NotifyPlayer:FireClient(player, "Error", "Invalid mail type!")
		return
	end

	local rewardAmount = math.floor(targetMail.Money)

	-- Add money to player
	data.Money = (data.Money or 0) + rewardAmount
	checkAndResetPlayerRC(userId)
	UpdateMoney:FireClient(player, data.Money)
	pcall(function()
		DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
	end)
	markPlayerDirty(userId)

	-- Mark mail as claimed
	updateMailById(userId, mailId, {
		Claimed = true,
		Money = 0  -- Remove money from mail after claiming
	})

	-- Update mail display
	local userMail = loadMail(userId)
	SendMailData:FireClient(player, filterMailData(userMail, userId))

	NotifyPlayer:FireClient(player, "Success", "Claimed " .. rewardAmount .. " RC!")
end)

