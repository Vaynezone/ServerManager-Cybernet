SendMail.OnServerEvent:Connect(function(player, toPlayerName, subject, message, moneyAmount)
	local userId = player.UserId
	local data = PlayerData[userId]
	if not data then return end

	-- Validate money amount
	moneyAmount = moneyAmount or 0
	if type(moneyAmount) ~= "number" or moneyAmount ~= moneyAmount or moneyAmount == math.huge or moneyAmount == -math.huge then
		moneyAmount = 0
	end
	moneyAmount = math.floor(math.abs(moneyAmount))

	-- Check if player has enough money
	if moneyAmount > 0 then
		if data.Money < moneyAmount then
			NotifyPlayer:FireClient(player, "Error", "Insufficient funds! You need " .. moneyAmount .. " RC.")
			return
		end

		if moneyAmount > 100000000 then
			NotifyPlayer:FireClient(player, "Error", "Cannot send more than 100,000,000 RC!")
			return
		end
	end

	local targetUserId
	local success, result = pcall(function()
		return Players:GetUserIdFromNameAsync(toPlayerName)
	end)

	if not success or not result then
		NotifyPlayer:FireClient(player, "Error", "Player '" .. toPlayerName .. "' not found!")
		return
	end

	targetUserId = result

	-- Prevent sending mail to yourself
	if targetUserId == userId then
		NotifyPlayer:FireClient(player, "Error", "You cannot send mail to yourself!")
		return
	end

	subject = filterText(subject, userId)
	message = filterText(message, userId)

	-- Deduct money from sender if sending money
	if moneyAmount > 0 then
		local oldMoney = data.Money or 0
		local newMoney = oldMoney - moneyAmount

		-- Verify deduction is valid
		if newMoney < 0 then
			NotifyPlayer:FireClient(player, "Error", "Insufficient funds! You need " .. moneyAmount .. " RC.")
			return
		end

		-- Apply deduction directly (same pattern as ClaimMailMoney)
		data.Money = newMoney
		checkAndResetPlayerRC(userId)
		UpdateMoney:FireClient(player, data.Money)
		pcall(function()
			DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
		end)
		markPlayerDirty(userId)

		-- Add money info to message
		message = message .. "\n\n💰 Money attached: " .. moneyAmount .. " RC\nClick 'CLAIM' below to receive it."
	end

	local mailId = HttpService:GenerateGUID(false)
	local mail = {
		Id = mailId,
		From = player.Name,
		Subject = subject,
		Message = message,
		Timestamp = os.time(),
		Read = false,
		Type = "PlayerMail",
		Responded = false,
		Money = moneyAmount > 0 and moneyAmount or nil,
		Claimed = false
	}

	saveMail(targetUserId, mail)

	local targetPlayer = Players:GetPlayerByUserId(targetUserId)
	if targetPlayer then
		local targetMail = loadMail(targetUserId)
		SendMailData:FireClient(targetPlayer, filterMailData(targetMail, targetUserId))
	end

	local successMsg = "Mail sent to " .. toPlayerName .. (targetPlayer and " (online)" or " (offline)")
	if moneyAmount > 0 then
		successMsg = successMsg .. " with " .. moneyAmount .. " RC"
	end
	NotifyPlayer:FireClient(player, "Success", successMsg)
end)

