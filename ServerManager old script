function buildSaveData(userId)
	local data = PlayerData[userId]
	if not data then return nil end

	local homeNetworkData = nil
	for _, network in ipairs(data.Networks or {}) do
		if network.IsPlayerHome then
			local devicesData = {}
			for _, device in ipairs(network.Devices or {}) do
				table.insert(devicesData, {
					Id = device.Id,
					Type = device.Type,
					Name = device.Name,
					Security = device.Security,
					Icon = device.Icon,
					LANIP = device.LANIP,
					IsPlayerComputer = device.IsPlayerComputer,
					Firewall = device.Firewall,
					AccessCode = device.AccessCode
				})
			end
			homeNetworkData = {
				Security = network.Security,
				AdminTier = network.AdminTier,
				Devices = devicesData,
				Firewall = network.Firewall,
				AccessCode = network.AccessCode
			}
			if AccessCodeSystem.StealTimers and AccessCodeSystem.StealTimers[userId] then
				homeNetworkData.StealCooldowns = {}
				for key, expiry in pairs(AccessCodeSystem.StealTimers[userId]) do
					if key:find(network.Id, 1, true) then
						local remaining = math.max(0, expiry - time())
						if remaining > 0 then
							homeNetworkData.StealCooldowns[key] = remaining
						end
					end
				end
			end
			break
		end
	end

	return {
		IP = data.IP,
		Settings = data.Settings,
		OwnedParts = data.OwnedParts,
		EquippedParts = data.EquippedParts,
		Motherboard = data.Motherboard,
		Money = data.Money,
		Level = data.Level,
		Experience = data.Experience,
		Reputation = data.Reputation,
		BankBalance = data.BankBalance or 0,
		Stats = data.Stats,
		Guild = data.Guild,
		TutorialCompleted = data.TutorialCompleted,
		PCSecurityLevel = data.PCSecurityLevel or 1,
		HomeNetwork = homeNetworkData,
		OwnedExploits = data.OwnedExploits or {},
		ScriptingAreaUnlocked = data.ScriptingAreaUnlocked or false,
		UnlockedScriptBlocks = data.UnlockedScriptBlocks or {},
		ShopLastRefresh = data.ShopLastRefresh or 0,
		DarkMarketLastRefresh = data.DarkMarketLastRefresh or 0,
		StolenFromGoodNetworks = data.StolenFromGoodNetworks or 0,
		SkillPoints = data.SkillPoints or 0,
		UnlockedSkills = data.UnlockedSkills or {},
		MilestoneRewards = data.MilestoneRewards or {},
		PendingSkillPoints = data.PendingSkillPoints or 0,
		GroupRewardClaimed = data.GroupRewardClaimed or nil,
		LevelRewards = data.LevelRewards or {}
	}
end

