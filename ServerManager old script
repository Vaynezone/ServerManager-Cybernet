function getAllGuilds()
	local allGuilds = {}
	for guildId, guild in pairs(Guilds) do
		table.insert(allGuilds, {
			Id = guild.Id,
			Name = guild.Name,
			Reputation = calculateGuildReputation(guild),
			Funds = guild.Funds,
			Members = guild.Members,
			InviteOnly = guild.InviteOnly,
			NetworkIP = guild.NetworkIP
		})
	end
	table.sort(allGuilds, function(a, b)
		if a.Reputation ~= b.Reputation then
			return a.Reputation > b.Reputation
		end
		return #a.Members > #b.Members
	end)
	return allGuilds
end

