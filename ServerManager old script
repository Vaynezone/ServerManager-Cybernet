ResetNetworks.OnServerEvent:Connect(function(player)
	local data = PlayerData[player.UserId]
	if not data then return end

	local playerNetworks = data.Networks
	if not playerNetworks then return end

	local oldNetworkId = data.CurrentNetwork

	for i = #playerNetworks, 1, -1 do
		if not playerNetworks[i].IsPlayerHome and not playerNetworks[i].IsPlayerTestingHub and not playerNetworks[i].IsGuildNetwork and not playerNetworks[i].IsTutorialNetwork then
			table.remove(playerNetworks, i)
		end
	end

	for _, network in ipairs(playerNetworks) do
		if network.ConnectedNetworks then
			network.ConnectedNetworks = {}
		end
	end

	local homeNetwork = nil
	for _, network in ipairs(playerNetworks) do
		if network.IsPlayerHome then
			homeNetwork = network
			break
		end
	end

	if homeNetwork then
		local oldIP = homeNetwork.IP
		if oldIP and NetworkGenerator.IsIPUsed(oldIP) then
			NetworkGenerator.ReleaseIP(oldIP)
		end

		local newIP = NetworkGenerator.GenerateIP()
		homeNetwork.IP = newIP
		data.IP = newIP
		DataStoreManager.SavePlayerIP(player.UserId, newIP)

		data.CurrentNetwork = homeNetwork.Id
		homeNetwork.Scanned = true
		for _, device in ipairs(homeNetwork.Devices) do
			device.Scanned = true
		end
	end

	local loggedInNetworkId = data.LoggedInNetwork
	TraceManager.HandleResetProtocol(player, oldNetworkId, loggedInNetworkId, {})

	if loggedInNetworkId then
		AccessCodeSystem.LogoutFromAllDevicesOnNetwork(player.UserId, loggedInNetworkId)
	end

	data.LoggedInNetwork = nil
	data.LoggedInDevice = nil
	data.ScannedNetworks = {}

	for networkId, connections in pairs(PlayerHomeConnections) do
		if connections[player.UserId] then
			connections[player.UserId] = nil
		end
	end

	for otherUserId, otherData in pairs(PlayerData) do
		if otherUserId ~= player.UserId and otherData.Networks then
			local homeNetId = data.HomeNetwork
			for i = #otherData.Networks, 1, -1 do
				if otherData.Networks[i].IsOtherPlayerHome and otherData.Networks[i].OriginalOwnerId == player.UserId then
					table.remove(otherData.Networks, i)
				end
			end

			local otherPlayer = Players:GetPlayerByUserId(otherUserId)
			if otherPlayer then
				local clientNetworks = prepareNetworksForClient(otherData.Networks, otherUserId)
				SendNetworkData:FireClient(otherPlayer, clientNetworks, otherData.CurrentNetwork, otherData.LoggedInNetwork, otherData.LoggedInDevice)
			end
		end
	end

	NotifyPlayer:FireClient(player, "Success", "Network protocol reset. Scan for new networks.")
	local clientNetworks = prepareNetworksForClient(playerNetworks, player.UserId)
	SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
	CenterOnHomeNetwork:FireClient(player)
end)

