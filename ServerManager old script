				end

				local network = getNetwork(netId, player.UserId)
				if not network then return false end

				local targetFirewall = nil
				local targetDeviceId = deviceId
				if type(deviceId) == "table" then
					targetDeviceId = deviceId.DeviceId or deviceId.Id
				end

				if targetDeviceId then
					for _, device in ipairs(network.Devices) do
