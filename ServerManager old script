function generateNetworksForPlayer(player, playerIP)
	local networks = {}

	local homeNetwork = NetworkGenerator.GeneratePlayerHomeNetwork(player, playerIP, PlayerData[player.UserId], GameData, ExploitData, AccessCodeSystem)

	local savedHomeData = loadHomeNetworkData(player.UserId)
	if savedHomeData then
		if savedHomeData.NetworkId then
			homeNetwork.Id = savedHomeData.NetworkId
		end
		if savedHomeData.Devices then
			homeNetwork.Devices = savedHomeData.Devices
			for _, device in ipairs(homeNetwork.Devices) do
				if not device.AccessCode then
					device.AccessCode = AccessCodeSystem.GenerateAccessCode()
				end
			end
		end

		if savedHomeData.StealCooldowns then
			if not AccessCodeSystem.StealTimers[player.UserId] then
				AccessCodeSystem.StealTimers[player.UserId] = {}
			end
			for key, remainingTime in pairs(savedHomeData.StealCooldowns) do
				AccessCodeSystem.StealTimers[player.UserId][key] = time() + remainingTime
			end
		end
	end

	table.insert(networks, homeNetwork)

	if GameData.EnablePlayerTestingHub and PlayerTestingHubId then
		local testingHubGlobal = nil
		for _, net in ipairs(GlobalNetworks) do
			if net.Id == PlayerTestingHubId then
				testingHubGlobal = net
				break
			end
		end

		if testingHubGlobal then
			local testingHubCopy = NetworkGenerator.CopyTestingHubForPlayer(testingHubGlobal, homeNetwork.Id)
			homeNetwork.ConnectedNetworks = homeNetwork.ConnectedNetworks or {}
			table.insert(homeNetwork.ConnectedNetworks, testingHubCopy.Id)
			table.insert(networks, testingHubCopy)

			if not PlayerHomeConnections[PlayerTestingHubId] then
				PlayerHomeConnections[PlayerTestingHubId] = {}
			end
			PlayerHomeConnections[PlayerTestingHubId][player.UserId] = {
				HomeNetworkId = homeNetwork.Id,
				HomeNetworkName = homeNetwork.Name,
				PlayerName = player.Name,
				IP = playerIP
			}
		end
	end

	return networks
end

