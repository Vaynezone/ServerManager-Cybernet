UnlockSkill.OnServerEvent:Connect(function(player, skillId)
	local data = PlayerData[player.UserId]
	if not data then return end

	-- Find the skill in the skill tree
	local skill = nil
	local branchName = nil
	for branchKey, branch in pairs(GameData.SkillTree.Branches) do
		for _, s in ipairs(branch.Skills) do
			if s.Id == skillId then
				skill = s
				branchName = branchKey
				break
			end
		end
		if skill then break end
	end

	if not skill then
		NotifyPlayer:FireClient(player, "Error", "Skill not found!")
		return
	end

	-- Check if already unlocked
	if data.UnlockedSkills[skillId] then
		NotifyPlayer:FireClient(player, "Error", "Skill already unlocked!")
		return
	end

	-- Check prerequisites
	if skill.Prerequisites and #skill.Prerequisites > 0 then
		for _, prereqId in ipairs(skill.Prerequisites) do
			if not data.UnlockedSkills[prereqId] then
				NotifyPlayer:FireClient(player, "Error", "Prerequisites not met!")
				return
			end
		end
	end

	-- Check skill points
	if (data.SkillPoints or 0) < skill.Cost then
		NotifyPlayer:FireClient(player, "Error", "Not enough skill points! Need " .. skill.Cost .. " SP.")
		return
	end

	-- Unlock the skill
	data.UnlockedSkills[skillId] = true
	data.SkillPoints = (data.SkillPoints or 0) - skill.Cost
	queuePlayerSave(player.UserId)

	NotifyPlayer:FireClient(player, "Success", "Unlocked: " .. skill.Name .. "!")

	-- Send updated skill tree data
	SendSkillTree:FireClient(player, {
		SkillPoints = data.SkillPoints,
		UnlockedSkills = data.UnlockedSkills
	})
end)

