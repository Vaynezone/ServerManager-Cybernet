	local ResetProtocolFunc = programBindables:FindFirstChild("ResetProtocol")
	if ResetProtocolFunc then
		ResetProtocolFunc.OnInvoke = function(player)
			local data = PlayerData[player.UserId]
			if not data then return end

			local userId = player.UserId
			local oldNetworkId = data.CurrentNetwork
			local playerNetworks = data.Networks

			-- Clear all non-home networks
			local homeNetwork = nil
			for i = #playerNetworks, 1, -1 do
				if playerNetworks[i].IsPlayerHome then
					homeNetwork = playerNetworks[i]
				else
					table.remove(playerNetworks, i)
				end
			end

			-- Clear connected networks
			for _, network in ipairs(playerNetworks) do
				if network.ConnectedNetworks then
					network.ConnectedNetworks = {}
				end
			end

			if homeNetwork then
				-- Generate new IP (critical for new network scans)
				local oldIP = homeNetwork.IP
				if oldIP and NetworkGenerator.IsIPUsed(oldIP) then
					NetworkGenerator.ReleaseIP(oldIP)
				end

				local newIP = NetworkGenerator.GenerateIP()
				homeNetwork.IP = newIP
				data.IP = newIP
				DataStoreManager.SavePlayerIP(userId, newIP)

				data.CurrentNetwork = homeNetwork.Id
				homeNetwork.Scanned = true
				for _, device in ipairs(homeNetwork.Devices) do
					device.Scanned = true
				end
			end

			-- Handle trace/logout
			local loggedInNetworkId = data.LoggedInNetwork
			-- NEW FEATURE: Check protocol lockout (from government backdoor or new network type)
			if data.ProtocolLockoutUntil and time() < data.ProtocolLockoutUntil then
				local remaining = math.ceil(data.ProtocolLockoutUntil - time())
				NotifyPlayer:FireClient(player, "Error", "Protocol reset is locked! Wait " .. remaining .. " more seconds.")
				TerminalResponse:FireClient(player, "ERROR: Protocol reset locked for " .. remaining .. " more seconds.")
				return
			end

			-- NEW FEATURE: Check protocol lockout (from government backdoor or new network type)
			local data = PlayerData[player.UserId]
			if data and data.ProtocolLockoutUntil and time() < data.ProtocolLockoutUntil then
				local remaining = math.ceil(data.ProtocolLockoutUntil - time())
				return {Success = false, Message = "Protocol reset is locked! Wait " .. remaining .. " more seconds."}
			end

			TraceManager.HandleResetProtocol(player, oldNetworkId, loggedInNetworkId, {})

			if loggedInNetworkId then
				AccessCodeSystem.LogoutFromAllDevicesOnNetwork(userId, loggedInNetworkId)
			end

			data.LoggedInNetwork = nil
			data.LoggedInDevice = nil
			data.ScannedNetworks = {}

			-- Clean up player home connections
			for networkId, connections in pairs(PlayerHomeConnections) do
				if connections[userId] then
					connections[userId] = nil
				end
			end

			-- Update other players who had connections to this player
			for otherUserId, otherData in pairs(PlayerData) do
				if otherUserId ~= userId and otherData.Networks then
					for i = #otherData.Networks, 1, -1 do
						if otherData.Networks[i].IsOtherPlayerHome and otherData.Networks[i].OriginalOwnerId == userId then
