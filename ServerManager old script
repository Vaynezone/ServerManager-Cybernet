MarketplaceService.ProcessReceipt = function(receiptInfo)
	local player = Players:GetPlayerByUserId(receiptInfo.PlayerId)
	if not player then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local data = PlayerData[player.UserId]
	if not data then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local productId = receiptInfo.ProductId
	local productData = nil
	local productKey = nil

	for key, devProduct in pairs(GamepassConfig.DevProducts) do
		if devProduct.ID == productId then
			productData = devProduct
			productKey = key
			break
		end
	end

	if not productData then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local success = pcall(function()
		if productData.Category == "RC" then
			local rcAmount = applyMoneyMultiplier(productData.Amount)
			data.Money = data.Money + rcAmount
			checkAndResetPlayerRC(player.UserId)
			UpdateMoney:FireClient(player, data.Money)
			pcall(function()
				DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
			end)
			NotifyPlayer:FireClient(player, "Success", "Received " .. productData.Amount .. " Ro-Coin!")

		elseif productKey == "ShopRefresh" then
			RefreshShop:FireClient(player)
			NotifyPlayer:FireClient(player, "Success", "Shop inventory refreshed!")

		elseif productKey == "ReputationReset" then
			data.Reputation = 0
			data.PositiveRep = 0
			data.NegativeRep = 0
			UpdateReputation:FireClient(player, 0, 0, 0)
			NotifyPlayer:FireClient(player, "Success", "Reputation has been reset!")

		elseif productKey == "XPBoost30Min" or productKey == "UltimateXPBoost60Min" then
			data.ActiveBoosts = data.ActiveBoosts or {}
			data.ActiveBoosts[productKey] = {
				Type = "XP",
				Multiplier = productData.Multiplier,
				Expiry = time() + productData.Duration
			}
			NotifyPlayer:FireClient(player, "Success", productData.Name .. " activated!")

		elseif productKey == "ScanSpeedBoost1Hr" then
			data.ActiveBoosts = data.ActiveBoosts or {}
			data.ActiveBoosts[productKey] = {
				Type = "ScanSpeed",
				Multiplier = productData.Multiplier,
				Expiry = time() + productData.Duration
			}
			NotifyPlayer:FireClient(player, "Success", productData.Name .. " activated!")
		end
	end)

	if success then
		return Enum.ProductPurchaseDecision.PurchaseGranted
	else
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
end

function saveGuildData(guildId, force)
	local guild = Guilds[guildId]
	if not guild then return end

	-- Always calculate reputation dynamically instead of using stored value
	-- Use pcall in case calculateGuildReputation isn't loaded yet or fails
	local calculatedReputation = 0
	local repSuccess, rep = pcall(function()
		return calculateGuildReputation(guild)
	end)
	if repSuccess and rep then
		calculatedReputation = rep
	else
		-- Fallback to stored reputation if calculation fails
		calculatedReputation = guild.Reputation or 0
	end

	DataStoreManager.SaveGuildData(guildId, {
		Id = guild.Id,
		Name = guild.Name,
		OwnerId = guild.OwnerId,
		Funds = guild.Funds or 0,
		Reputation = calculatedReputation, -- Use calculated reputation, not stored
		Members = guild.Members,
		InviteOnly = guild.InviteOnly,
		NetworkIP = guild.NetworkIP,
		NetworkId = guild.NetworkId,
		FundsDeviceId = guild.FundsDeviceId
	}, force)

	if not cachedGuildList[guildId] then
		cachedGuildList[guildId] = true
		pcall(function()
			local GuildDataStore = DataStoreManager.Stores.GuildData
			local guildList = GuildDataStore:GetAsync("GuildList") or {}
			if not table.find(guildList, guildId) then
				table.insert(guildList, guildId)
				GuildDataStore:SetAsync("GuildList", guildList)
			end
		end)
	end
end

