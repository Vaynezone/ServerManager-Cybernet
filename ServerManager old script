			savedData = loadAllPlayerData(player.UserId)
		end
	end
	--]]

	-- Attempt to restore lost data from legacy stores if current data appears reset (only after V3.3, starting from V3.4)
	local VersionConfig = require(ReplicatedStorage:FindFirstChild("VersionConfig"))
	local currentVersion = VersionConfig and VersionConfig.CurrentVersion or ""
	local isAfterV33 = false

	if currentVersion then
		local major, minor = currentVersion:match("v(%d+)%.(%d+)")
		if major and minor then
			local majorNum = tonumber(major) or 0
			local minorNum = tonumber(minor) or 0
			isAfterV33 = (majorNum > 3) or (majorNum == 3 and minorNum > 3)
		end
	end

	if savedData and isAfterV33 then
		local needsRestore = false
		local restoreReason = ""

		if (savedData.BankBalance == 0 or savedData.BankBalance == nil) and 
			(savedData.Money == GameData.StartingMoney or savedData.Money == nil) and
			(savedData.Level == 0 or savedData.Level == nil) then
			needsRestore = true
			restoreReason = "Data appears reset (BankBalance=0, Money=starting, Level=0)"
		end

		if needsRestore then
			warn("[DATA RESTORE] Attempting to restore data for player: " .. player.Name .. " (" .. player.UserId .. ") - " .. restoreReason)

			-- Try to restore from legacy PlayerData store
			local legacySuccess, legacyDataString = pcall(function()
				local ver = ReplicatedStorage:WaitForChild("Version").Value
				local legacyStore = DataStoreService:GetDataStore("PlayerData" .. ver)
				return legacyStore:GetAsync("Data_" .. player.UserId)
			end)

			if legacySuccess and legacyDataString then
				local decodeSuccess, legacyData = pcall(function()
					return HttpService:JSONDecode(legacyDataString)
				end)

				if decodeSuccess and legacyData then
					-- Restore BankBalance and Money if they exist in legacy data
					if legacyData.BankBalance and legacyData.BankBalance > 0 and (not savedData.BankBalance or savedData.BankBalance == 0) then
						savedData.BankBalance = legacyData.BankBalance
						warn("[DATA RESTORE] Restored BankBalance: " .. legacyData.BankBalance .. " for player: " .. player.Name)
					end

					if legacyData.Money and legacyData.Money > GameData.StartingMoney and (not savedData.Money or savedData.Money == GameData.StartingMoney) then
						savedData.Money = legacyData.Money
						warn("[DATA RESTORE] Restored Money: " .. legacyData.Money .. " for player: " .. player.Name)
