end)

UpgradePC.OnServerEvent:Connect(function(player, component)
	local data = PlayerData[player.UserId]
	if not data then return end

	-- Validate component
	if component ~= "CPU" and component ~= "RAM" and component ~= "Network" then
		NotifyPlayer:FireClient(player, "Error", "Invalid upgrade component!")
		return
	end

	-- Get current level
	local currentLevel
	if component == "CPU" then
		currentLevel = data.CPULevel or 1
	elseif component == "RAM" then
		currentLevel = data.RAMLevel or 1
	else
		currentLevel = data.NetworkLevel or 1
	end

	-- Check if already max level
	if currentLevel >= 5 then
		NotifyPlayer:FireClient(player, "Error", component .. " is already at maximum level!")
		return
	end

	-- Get upgrade cost
	local nextLevel = currentLevel + 1
	local upgradeData = GameData.PCUpgrades[component][nextLevel]
	if not upgradeData then
		NotifyPlayer:FireClient(player, "Error", "Invalid upgrade level!")
		return
	end

	local cost = upgradeData.Cost

	-- Check if player has enough money
	if data.Money < cost then
		NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. cost .. " RC.")
		return
	end

	-- Apply upgrade
	data.Money = data.Money - cost
	if component == "CPU" then
		data.CPULevel = nextLevel
	elseif component == "RAM" then
		data.RAMLevel = nextLevel
	else
		data.NetworkLevel = nextLevel
	end

	UpdateMoney:FireClient(player, data.Money)
	pcall(function()
		DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
	end)

	SendSystemData:FireClient(player, {
		Money = data.Money,
		CPULevel = data.CPULevel,
		RAMLevel = data.RAMLevel,
		NetworkLevel = data.NetworkLevel,
		PCSecurityLevel = data.PCSecurityLevel,
		HomeAdminTier = data.HomeAdminTier,
		OwnedGamepasses = data.OwnedGamepasses
	})

	NotifyPlayer:FireClient(player, "Success", component .. " upgraded to level " .. nextLevel .. "!")
	queuePlayerSave(player.UserId)
end)

