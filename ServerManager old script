function isNetworkConnected(network1, network2)
	if not network1.ConnectedNetworks then
		network1.ConnectedNetworks = {}
	end
	for _, connectedId in ipairs(network1.ConnectedNetworks) do
		if connectedId == network2.Id then
			return true
		end
	end
	return false
end

function connectNetworks(network1, network2)
	if not network1.ConnectedNetworks then
		network1.ConnectedNetworks = {}
	end
	if not network2.ConnectedNetworks then
		network2.ConnectedNetworks = {}
	end
	if not isNetworkConnected(network1, network2) then
		table.insert(network1.ConnectedNetworks, network2.Id)
		table.insert(network2.ConnectedNetworks, network1.Id)
	end
end

function disconnectNetworks(network1, network2)
	if network1.ConnectedNetworks then
		for i, connectedId in ipairs(network1.ConnectedNetworks) do
			if connectedId == network2.Id then
				table.remove(network1.ConnectedNetworks, i)
				break
			end
		end
	end
	if network2.ConnectedNetworks then
		for i, connectedId in ipairs(network2.ConnectedNetworks) do
			if connectedId == network1.Id then
				table.remove(network2.ConnectedNetworks, i)
				break
			end
		end
	end

	for otherUserId, otherData in pairs(PlayerData) do
		if otherData.Networks then
			for _, otherNet in ipairs(otherData.Networks) do
				if otherNet.Id == network1.Id and otherNet.ConnectedNetworks then
					for i, connId in ipairs(otherNet.ConnectedNetworks) do
						if connId == network2.Id then
							table.remove(otherNet.ConnectedNetworks, i)
							break
						end
					end
				elseif otherNet.Id == network2.Id and otherNet.ConnectedNetworks then
					for i, connId in ipairs(otherNet.ConnectedNetworks) do
						if connId == network1.Id then
							table.remove(otherNet.ConnectedNetworks, i)
							break
						end
					end
				end
			end
		end
	end
end

function hasPathToNetwork(startNetwork, targetNetwork, userId, visited)
	visited = visited or {}
	if visited[startNetwork.Id] then
		return false
	end
	visited[startNetwork.Id] = true

	if startNetwork.Id == targetNetwork.Id then
		return true
	end

	if not startNetwork.ConnectedNetworks then
		return false
	end

	for _, connectedId in ipairs(startNetwork.ConnectedNetworks) do
		local connectedNet = getNetwork(connectedId, userId)
		if connectedNet and hasPathToNetwork(connectedNet, targetNetwork, userId, visited) then
			return true
		end
	end

	return false
end

-- Changed from local function to regular function to avoid local register limit
function prepareNetworksForClient(networks, userId)
	local clientNetworks = {}
	local data = PlayerData[userId]
	local includedIds = {}


	if not networks or type(networks) ~= "table" then
		return clientNetworks 
	end

	for _, net in ipairs(networks) do
		local network = net
		if type(net) == "string" then
			for _, globalNet in ipairs(GlobalNetworks) do
				if globalNet.Id == net then
					network = globalNet
					break
				end
			end
			if type(network) == "string" then
				-- Skip this network if it's still a string (not found in GlobalNetworks)
			else
				-- Process network (fall through to processing code below)
			end
		end

		-- Process network if it's a valid object (either from string conversion or already an object)
		if network and type(network) == "table" and network.Id then
			local netCopy = {}
			for key, value in pairs(network) do
				netCopy[key] = value
			end
			-- Sanitize firewall info before sending to client
			netCopy.Firewall = sanitizeFirewall(network.Firewall)
			netCopy.Awareness = getNetworkAwareness(network.Id)

			-- Add lockout remaining time if player is locked out of this network
			if data and data.LockedOutOfNetworks and data.LockedOutOfNetworks[network.Id] then
				local remaining = data.LockedOutOfNetworks[network.Id] - time()
				if remaining > 0 then
					netCopy.LockoutRemaining = remaining
				else
					data.LockedOutOfNetworks[network.Id] = nil
				end
			end

			if netCopy.Devices then
				for _, device in ipairs(netCopy.Devices) do
					-- Sanitize device firewall data
					device.Firewall = sanitizeFirewall(device.Firewall)
					local canSteal = AccessCodeSystem.CanSteal(userId, network.Id, device.Id)
					device.StealCooldownRemaining = canSteal and 0 or AccessCodeSystem.GetStealTimerRemaining(userId, network.Id, device.Id)
					device.IsLoggedIn = AccessCodeSystem.IsLoggedIn(userId, network.Id, device.Id)
				end
			end

			table.insert(clientNetworks, netCopy)
			includedIds[network.Id] = true
		end
	end

	-- For each network we have, check if there are connected networks from other players
	-- that we don't have yet, and add them (with minimal info for display purposes only)
	local networksToAdd = {}

	for _, clientNet in ipairs(clientNetworks) do
		if clientNet.ConnectedNetworks then
			for _, connectedId in ipairs(clientNet.ConnectedNetworks) do
				if not includedIds[connectedId] and not networksToAdd[connectedId] then
					-- Check if this is another player's home network
					for otherUserId, otherData in pairs(PlayerData) do
						if otherUserId ~= userId and otherData.Networks then
							for _, otherNet in ipairs(otherData.Networks) do
								if otherNet.Id == connectedId and otherNet.IsPlayerHome then
									networksToAdd[connectedId] = {
										Id = otherNet.Id,
										IP = otherNet.IP,
										Name = otherNet.Name,
										Type = otherNet.Type or "Home",
										Security = otherNet.Security,
										Scanned = false,
										Hacked = false,
										Owner = otherNet.Owner,
										Devices = {},
										ConnectedNetworks = {clientNet.Id},
										Position = otherNet.Position or Vector2.new(0, 0),
										Visible = true,
										IsPlayerHome = false,
										IsOtherPlayerHome = true,
										OwnerUserId = otherUserId
									}
									break
								end
							end
						end
						if networksToAdd[connectedId] then break end
					end
				end
			end
		end
	end

	-- Add the new networks
	for connectedId, netData in pairs(networksToAdd) do
		table.insert(clientNetworks, netData)
		includedIds[connectedId] = true
	end

	return clientNetworks
end

