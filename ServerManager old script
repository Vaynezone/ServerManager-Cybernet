	sendGroupStatusToClient(player, inGroup, rank, data)
end)

-- Claim reward (with cooldown)
ClaimGroupReward.OnServerEvent:Connect(function(player)
	local data = PlayerData[player.UserId]
	if not data then
		warn("[ServerManager] ClaimGroupReward: Player data not found for", player.UserId)
		return
	end

	local inGroup, rank = checkGroupMembership(player)
	if not inGroup then
		NotifyPlayer:FireClient(player, "Error", "You must be a member of the group to claim rewards!")
		return
	end

	-- Check cooldown
	local onCooldown, remaining = getGroupRewardCooldownState(data)
	if onCooldown then
		NotifyPlayer:FireClient(player, "Error", "Daily group reward is still on cooldown! Next in " .. math.ceil(remaining/60) .. " minute(s).")
		-- send status so client shows proper cooldown
		sendGroupStatusToClient(player, inGroup, rank, data)
		return
	end

	-- Award rewards
	local rewards = GroupRewardsConfig.Rewards or {}
	local rewardsGiven = {}

	-- Money
	if rewards.Money then
		-- Group rewards are configured in RC units; do not apply the global money multiplier here
		local rewardMoney = rewards.Money
		data.Money = (data.Money or 0) + rewardMoney
		if UpdateMoney then
			UpdateMoney:FireClient(player, data.Money)
		end
		table.insert(rewardsGiven, tostring(rewardMoney) .. " RC")
		pcall(function()
			if DataStoreManager and DataStoreManager.SetPlayerMoney then
				DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
			end
		end)
	end

	-- Skill points (supports fractional pending points)
	if rewards.SkillPoints then
		data.PendingSkillPoints = (data.PendingSkillPoints or 0) + rewards.SkillPoints

		-- award whole skill points now, keep fraction pending
		local skillPointsAwarded = math.floor(data.PendingSkillPoints)
		data.PendingSkillPoints = data.PendingSkillPoints - skillPointsAwarded

		if skillPointsAwarded > 0 then
			data.SkillPoints = (data.SkillPoints or 0) + skillPointsAwarded

			-- cap skill points if skill tree config available
			local maxSP = (GameData and GameData.SkillTree and GameData.SkillTree.MaxSkillPoints) or 50
			if data.SkillPoints > maxSP then
				data.SkillPoints = maxSP
			end

			table.insert(rewardsGiven, tostring(skillPointsAwarded) .. " Skill Point" .. (skillPointsAwarded > 1 and "s" or ""))
		else
			table.insert(rewardsGiven, string.format("%.1f", rewards.SkillPoints) .. " SP (pending)")
		end

		-- Update client skill tree if available
		if SendSkillTree then
			SendSkillTree:FireClient(player, {
				SkillPoints = data.SkillPoints or 0,
				UnlockedSkills = data.UnlockedSkills or {}
			})
		end
	end

	-- Experience / XP
	if rewards.Experience then
		if awardExperience then
			pcall(function()
				awardExperience(player, rewards.Experience, "Group Reward")
			end)
		end
		table.insert(rewardsGiven, tostring(rewards.Experience) .. " XP")
	end

	-- Record claim time and increment count
	data.GroupRewardClaimed = data.GroupRewardClaimed or { LastClaimTime = 0, ClaimCount = 0 }
	data.GroupRewardClaimed.LastClaimTime = os.time()
	data.GroupRewardClaimed.ClaimCount = (data.GroupRewardClaimed.ClaimCount or 0) + 1

	-- Persist and mark dirty
	if queuePlayerSave then queuePlayerSave(player.UserId) end
	if markPlayerDirty then markPlayerDirty(player.UserId) end

	-- Send updated status (now on cooldown)
	sendGroupStatusToClient(player, true, rank, data)

	NotifyPlayer:FireClient(player, "Success", "Group rewards claimed! Received: " .. table.concat(rewardsGiven, ", "))
end)

-- References for Music System
local PurchaseMusic = RemoteEvents:WaitForChild("PurchaseMusic")
local UpdateOwnedMusic = RemoteEvents:WaitForChild("UpdateOwnedMusic")

-- Purchase Music Logic
PurchaseMusic.OnServerEvent:Connect(function(player, trackIndex)
    -- Use the DataStoreManager you required at the top of ServerManager
    local data = DataStoreManager.GetPlayerData(player) 
    if not data then return end
    
    local TRACK_COST = 500
    
    -- Safety check: ensure the data has the OwnedMusic table
    -- Usually, you'd define this in your default data, but we can check here too
    if not data.OwnedMusic then
        data.OwnedMusic = {[1] = true} -- Track 1 is free by default
    end

    -- Check if they already own it (checking both number and string keys for safety)
    if data.OwnedMusic[trackIndex] or data.OwnedMusic[tostring(trackIndex)] then
        print(player.Name .. " already owns Track #" .. trackIndex)
        return 
    end

    -- Check balance
    if data.Money >= TRACK_COST then
        data.Money -= TRACK_COST
        data.OwnedMusic[tostring(trackIndex)] = true -- Stores as string for consistent DataStore saving
        
        -- Save the updated data
        DataStoreManager.SavePlayerData(player)
        
        -- Tell the client to refresh their UI
        UpdateOwnedMusic:FireClient(player, trackIndex)
        
        -- If your game has a money update event, fire it to refresh their balance display
        if RemoteEvents:FindFirstChild("UpdateMoney") then
            RemoteEvents.UpdateMoney:FireClient(player, data.Money)
        end
        
        print(player.Name .. " successfully purchased Track #" .. trackIndex)
    else
        -- Optional: Trigger a notification if they are broke
        local NotifyPlayer = RemoteEvents:FindFirstChild("NotifyPlayer")
        if NotifyPlayer then
            NotifyPlayer:FireClient(player, "Insufficient RC to purchase this track!", "Error")
        end
    end
end)

