					netId = networkId.NetworkId or networkId.Id
				end

				-- Can't delete home network
				if netId == data.HomeNetwork then return false end

				-- Can't delete current network
				if netId == data.CurrentNetwork then return false end

				-- Find and remove the network
				local foundIndex = nil
				local removedNet = nil
				for i, network in ipairs(data.Networks) do
					if network.Id == netId then
						foundIndex = i
						removedNet = network
						break
					end
				end

				if not foundIndex then return false end

				table.remove(data.Networks, foundIndex)

				-- Clean up connections to this network
				for _, network in ipairs(data.Networks) do
					if network.ConnectedNetworks then
						for j = #network.ConnectedNetworks, 1, -1 do
							if network.ConnectedNetworks[j] == removedNet.Id then
