					Owner = guildNetwork.Owner,
					Locked = false,
					LockExpiry = 0,
					TracesReceived = 0,
					Devices = {},
					ConnectedNetworks = {},
					Position = guildNetwork.Position,
					Visible = true,
					IsGuildNetwork = true,
					GuildId = guild.Id,
					AccessCode = guildNetwork.AccessCode
				}

				for _, device in ipairs(guildNetwork.Devices) do
