-- Dedicated RemoveNetwork handler for direct calls (more reliable than terminal command)
if RemoveNetwork then
	RemoveNetwork.OnServerEvent:Connect(function(player, networkIP)
		local userId = player.UserId
		local data = PlayerData[userId]
		if not data then return end

		-- Validate networkIP
		if not networkIP or type(networkIP) ~= "string" or networkIP == "" then
			NotifyPlayer:FireClient(player, "Error", "Invalid network IP")
			return
		end

		-- Check if it's home network
		local homeNet = getNetwork(data.HomeNetwork, userId)
		if homeNet and homeNet.IP == networkIP then
			NotifyPlayer:FireClient(player, "Error", "Cannot remove your home network")
			return
		end

		-- Check if it's current network
		local currentNet = getNetwork(data.CurrentNetwork, userId)
		if currentNet and currentNet.IP == networkIP then
			NotifyPlayer:FireClient(player, "Error", "Cannot remove network you are currently connected to. Use 'move' command first")
			return
		end

		-- Find and remove network
		local foundIndex = nil
		for i, network in ipairs(data.Networks) do
			if network.IP == networkIP and (network.Visible == nil or network.Visible == true) then
				foundIndex = i
				break
			end
		end

		if not foundIndex then
			NotifyPlayer:FireClient(player, "Error", "Network " .. networkIP .. " not found in viewer")
			return
		end

		local removedNet = data.Networks[foundIndex]
		table.remove(data.Networks, foundIndex)

		-- Clean up connections from other networks
		for _, network in ipairs(data.Networks) do
			if network.ConnectedNetworks then
				for j = #network.ConnectedNetworks, 1, -1 do
					if network.ConnectedNetworks[j] == removedNet.Id then
						table.remove(network.ConnectedNetworks, j)
					end
				end
			end
		end

		-- Mark player data as dirty to ensure it gets saved
		markPlayerDirty(userId)

		-- Send updated network data to client
		local clientNetworks = prepareNetworksForClient(data.Networks, player.UserId)
		SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		NotifyPlayer:FireClient(player, "Success", "Network " .. networkIP .. " removed from network viewer")
	end)
end

