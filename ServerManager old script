AddMoneySignal.Event:Connect(function(player, amount, xp)
	if PlayerData[player.UserId] then
		-- Apply the values
		PlayerData[player.UserId].Money = (PlayerData[player.UserId].Money or 0) + amount
		PlayerData[player.UserId].Exp = (PlayerData[player.UserId].Exp or 0) + xp

		-- Update the specific stats you mentioned earlier
		PlayerData[player.UserId].Stats = PlayerData[player.UserId].Stats or {}
		PlayerData[player.UserId].Stats.MoneyStolen = (PlayerData[player.UserId].Stats.MoneyStolen or 0) + amount

		-- Refresh the UI using ServerManager's existing system
		if game.ReplicatedStorage:FindFirstChild("UpdateMoney") then
			game.ReplicatedStorage.UpdateMoney:FireClient(player, PlayerData[player.UserId].Money)
		end

		print("SUCCESS: Added " .. amount .. " RC to " .. player.Name)
	end
end)

-- Dedicated function to handle Task Rewards safely
_G.AwardTaskReward = function(player, amount, xp)
	local data = PlayerData[player.UserId]
	if not data then
		warn("[ServerManager] AwardTaskReward: Player data not found for", player.UserId)
		return false
	end

	-- 1. Award Money (RC)
	data.Money = (data.Money or 0) + amount
	if UpdateMoney then
		UpdateMoney:FireClient(player, data.Money)
	end

	-- 2. Award Experience (XP)
	if awardExperience then
		pcall(function()
			awardExperience(player, xp, "Task Reward")
		end)
	end

	-- 3. Persist and Save (Matching your Group Reward logic)
	if queuePlayerSave then queuePlayerSave(player.UserId) end
	if markPlayerDirty then markPlayerDirty(player.UserId) end

	print("[ServerManager] Task Reward processed for " .. player.Name .. ": " .. amount .. " RC")
	return true
end
