						IsGuildFundsDevice = device.IsGuildFundsDevice,
						LANIP = device.LANIP,
						GuildId = device.GuildId,
						AccessCode = device.AccessCode
					})
				end

				local hasNetwork = false
				for _, net in ipairs(PlayerData[member.UserId].Networks) do
					if (type(net) == "table" and net.Id == guildNetworkId) then
						hasNetwork = true
						break
					end
				end

				if not hasNetwork then
					table.insert(PlayerData[member.UserId].Networks, guildNetworkCopy)
				end

				PlayerData[member.UserId].Guild = guild.Id

				local clientNetworks = prepareNetworksForClient(PlayerData[member.UserId].Networks, member.UserId)
				SendNetworkData:FireClient(memberPlayer, clientNetworks, PlayerData[member.UserId].CurrentNetwork, PlayerData[member.UserId].LoggedInNetwork, PlayerData[member.UserId].LoggedInDevice)
			end
		end
	end

	return guildNetwork
end

function checkAndMarkExpiredMissions(userId, mailList)
	local updatedMail = false
	for i, mail in ipairs(mailList) do
		if mail.Type == "MissionMail" and not mail.Expired then
			local missionExists = false
			if mail.Faction and mail.MissionId then
				local acceptedMission = MissionsConfig.GetAcceptedMission(userId, mail.MissionId)
				if acceptedMission then
					missionExists = true
				else
					for _, m in ipairs(MissionsConfig.ActiveMissions[mail.Faction] or {}) do
						if m.Id == mail.MissionId then
							missionExists = true
							break
						end
					end
				end
			end

			if not missionExists then
				mailList[i].Expired = true
				mailList[i].Subject = mail.Subject .. " [EXPIRED]"
				updatedMail = true
			end
		end
	end

	if updatedMail then
		DataStoreManager.SaveMailData(userId, mailList)
	end

	return mailList
end

