-- Group Rewards System (daily / cooldown-based)
-- checkGroupMembership: returns (inGroup(boolean), rank(number))
function checkGroupMembership(player)
	if not GroupRewardsConfig then
		warn("[ServerManager] GroupRewardsConfig not loaded!")
		return false, 0
	end

	if not GroupRewardsConfig.GroupId then
		warn("[ServerManager] GroupRewardsConfig.GroupId not set!")
		return false, 0
	end

	local groupId = GroupRewardsConfig.GroupId
	local ok, inGroup = pcall(function() return player:IsInGroup(groupId) end)
	if not ok or not inGroup then
		return false, 0
	end

	local ok2, rank = pcall(function() return player:GetRankInGroup(groupId) end)
	if not ok2 or not rank then
		return false, 0
	end

	local minRank = GroupRewardsConfig.MinRank or 0
	if rank < minRank then
		return false, rank
	end

	return true, rank
end

-- Helper to compute cooldown state for a player
local function getGroupRewardCooldownState(data)
	local lastClaim = data and data.GroupRewardClaimed and data.GroupRewardClaimed.LastClaimTime or 0
	local cooldown = GroupRewardsConfig and GroupRewardsConfig.ClaimCooldown or (24 * 3600) -- default 24h
	if lastClaim <= 0 then
		return false, 0 -- not on cooldown
	end
	local elapsed = os.time() - lastClaim
	if elapsed < cooldown then
		return true, (cooldown - elapsed)
	end
	return false, 0
end

-- Client status sender for consistency
local function sendGroupStatusToClient(player, inGroup, rank, data)
	local onCooldown, remaining = getGroupRewardCooldownState(data)
	SendGroupRewardStatus:FireClient(player, {
		InGroup = inGroup,
		Rank = rank,
		OnCooldown = onCooldown,
		CooldownRemaining = remaining
	})
end

