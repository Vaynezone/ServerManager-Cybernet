						SendNetworkData:FireClient(otherPlayer, clientNetworks, otherData.CurrentNetwork, otherData.LoggedInNetwork, otherData.LoggedInDevice)
					end
				end
			end

			SendNetworkData:FireClient(player, prepareNetworksForClient(data.Networks, userId), data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
			markPlayerDirty(userId)
		end
	end

