-- Changed from local function to regular function to avoid local register limit
function throttledGuildGet(guildId)
	local now = time()
	local timeSinceLast = now - lastGuildDatastoreRequest
	if timeSinceLast < GUILD_REQUEST_INTERVAL then
		task.wait(GUILD_REQUEST_INTERVAL - timeSinceLast)
	end
	lastGuildDatastoreRequest = time()

	local GuildDataStore = DataStoreManager.Stores.GuildData
	local success, guildData = pcall(function()
		return GuildDataStore:GetAsync("Guild_" .. guildId)
	end)

	if not success then
		task.wait(GUILD_REQUEST_INTERVAL * 2)
		lastGuildDatastoreRequest = time()
		success, guildData = pcall(function()
			return GuildDataStore:GetAsync("Guild_" .. guildId)
		end)
	end

	if success and guildData then
		local decodeSuccess, decoded = pcall(function()
			return game:GetService("HttpService"):JSONDecode(guildData)
		end)
		if decodeSuccess and decoded then
			return decoded
		end
	end
	return nil
end

-- Changed from local function to regular function to avoid local register limit
function loadAllGuildsFromList()
	if guildListLoaded or guildListLoading then return end
	guildListLoading = true

	task.wait(5)

	local GuildDataStore = DataStoreManager.Stores.GuildData
	local guildList = nil
	lastGuildDatastoreRequest = time()
	pcall(function()
		guildList = GuildDataStore:GetAsync("GuildList") or {}
	end)

	if guildList then
		for _, guildId in ipairs(guildList) do
			cachedGuildList[guildId] = true
			if not Guilds[guildId] then
				local guildData = throttledGuildGet(guildId)
				if guildData then
					Guilds[guildId] = guildData
					if guildData.NetworkId then
						createGuildNetwork(guildData)
					end
					GuildLoadedEvent:Fire(guildId, guildData)
				end
			end
		end
	end
	guildListLoaded = true
	guildListLoading = false
	guildListLoadedEvent:Fire()
end

