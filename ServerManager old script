function fixDuplicatePartIds(userId)
	local data = PlayerData[userId]
	if not data or not data.OwnedParts then return end

	local seenPartIds = {}
	local fixed = false

	for _, part in ipairs(data.OwnedParts) do
		if part.PartId then
			if seenPartIds[part.PartId] then
				part.PartId = HttpService:GenerateGUID(false)
				fixed = true
			else
				seenPartIds[part.PartId] = true
			end
		else
			part.PartId = HttpService:GenerateGUID(false)
			fixed = true
		end
	end

	if fixed then
		queuePlayerSave(userId)
	end
end

function ensurePartHasId(part, userId)
	if not part then return end
	if not part.PartId or part.PartId == "" then
		local newId = HttpService:GenerateGUID(false)
		if ExploitLogger then
			ExploitLogger.Log(userId, "FixPartId", "Assigned missing PartId to part: " .. tostring(part.Name or "unknown") .. " -> " .. newId, "Info")
		else
			warn("Assigned missing PartId to part for user " .. tostring(userId) .. ": " .. tostring(part.Name or "unknown") .. " -> " .. newId)
		end
		part.PartId = newId
		queuePlayerSave(userId)
	end
end

function ensureStartingPartsMarked(userId)
	local data = PlayerData[userId]
	if not data then return end

	local hasStartingParts = false
	for _, part in ipairs(data.OwnedParts) do
		if part.IsStartingPart then
			hasStartingParts = true
			break
		end
	end

	if data.Motherboard and data.Motherboard.IsStartingPart then
		hasStartingParts = true
	end

	if hasStartingParts then return end

	if not data.Motherboard or not data.Motherboard.Slots then return end

	local requiredSocket = data.Motherboard.Slots.CPUType
	local requiredRAMType = data.Motherboard.Slots.RAMType

	local foundCPU = nil
	local foundRAM = nil
	local foundPSU = nil
	local foundHDD = nil
	local foundNET = nil

	for _, part in ipairs(data.OwnedParts) do
		if not foundCPU and part.Type == "CPU" and part.SocketType == requiredSocket then
			foundCPU = part
		elseif not foundRAM and part.Type == "RAM" and part.RAMType == requiredRAMType then
			foundRAM = part
		elseif not foundPSU and part.Type == "PSU" then
			foundPSU = part
		elseif not foundHDD and part.Type == "HDD" then
			foundHDD = part
		elseif not foundNET and part.Type == "NET" then
			foundNET = part
		end

		if foundCPU and foundRAM and foundPSU and foundHDD and foundNET then
			break
		end
	end

	if foundCPU then foundCPU.IsStartingPart = true end
	if foundRAM then foundRAM.IsStartingPart = true end
	if foundPSU then foundPSU.IsStartingPart = true end
	if foundHDD then foundHDD.IsStartingPart = true end
	if foundNET then foundNET.IsStartingPart = true end

	if data.Motherboard then
		data.Motherboard.IsStartingPart = true
	end

	queuePlayerSave(userId)
end

-- Changed from local function to regular function to avoid local register limit
function validatePCConfiguration(equippedParts)
	if not equippedParts or type(equippedParts) ~= "table" then
		return false, "Invalid parts data"
	end

	local validSlots = {CPU = true, GPU = true, RAM1 = true, RAM2 = true, RAM3 = true, RAM4 = true, PSU = true, HDD = true, NET = true}
	for slot, _ in pairs(equippedParts) do
		if not validSlots[slot] then
			return false, "Invalid slot: " .. tostring(slot)
		end
	end

	return true, nil
end

