PurchaseItem.OnServerEvent:Connect(function(player, itemData, clientPrice, itemType)
	local data = PlayerData[player.UserId]
	if not data then return end

	local price
	if itemType == "exploit" then
		if not itemData or type(itemData) ~= "table" then
			NotifyPlayer:FireClient(player, "Error", "Invalid purchase request!")
			if ExploitLogger then ExploitLogger.Log(player.UserId, "InvalidPurchase", "itemData is nil or not a table", "Warning") end
			return
		end

		if not clientPrice or type(clientPrice) ~= "number" or clientPrice <= 0 then
			NotifyPlayer:FireClient(player, "Error", "Invalid purchase request!")
			if ExploitLogger then ExploitLogger.Log(player.UserId, "InvalidPurchase", "Invalid price: " .. tostring(clientPrice), "Warning") end
			return
		end

		if not itemData.Library or not itemData.Version then
			NotifyPlayer:FireClient(player, "Error", "Invalid exploit data!")
			if ExploitLogger then ExploitLogger.Log(player.UserId, "InvalidPurchase", "Missing exploit Library or Version", "Warning") end
			return
		end

		local exploitInfo = ExploitData.GetExploit and ExploitData.GetExploit(itemData.Library, itemData.Version)
		if not exploitInfo then
			NotifyPlayer:FireClient(player, "Error", "Exploit not found!")
			if ExploitLogger then ExploitLogger.Log(player.UserId, "ExploitPurchase", "Attempted to purchase non-existent exploit: " .. tostring(itemData.Library) .. " " .. tostring(itemData.Version), "Critical") end
			return
		end

		price = exploitInfo.Price or 5000
		if math.abs(clientPrice - price) > price * 0.15 then
			if ExploitLogger then ExploitLogger.Log(player.UserId, "PriceMismatch", "Exploit price mismatch. Client: " .. clientPrice .. ", Server: " .. price, "Critical") end
			NotifyPlayer:FireClient(player, "Error", "Price verification failed!")
			return
		end

		if data.Money < price then
			NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. price .. " RC.")
			return
		end

		data.Money = data.Money - price
		if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, price, "Purchase", "exploit: " .. tostring(itemData.Name or "Unknown")) end

		if not data.OwnedExploits then
			data.OwnedExploits = {}
		end
		local exploitKey = itemData.Library .. "_" .. itemData.Version
		if data.OwnedExploits[exploitKey] then
			NotifyPlayer:FireClient(player, "Error", "You already own this exploit!")
			data.Money = data.Money + price
			return
		end
		data.OwnedExploits[exploitKey] = itemData
		queuePlayerSave(player.UserId)
		NotifyPlayer:FireClient(player, "Success", "Purchased " .. itemData.Name .. " for " .. price .. " RC!")
		ExploitPurchased:FireClient(player, itemData)
		UpdateMoney:FireClient(player, data.Money)
		pcall(function()
			DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
		end)
	else
		-- PC Part purchase - itemData is the inventory index
		local inventoryIndex = itemData
		if type(inventoryIndex) ~= "number" or inventoryIndex < 1 then
			NotifyPlayer:FireClient(player, "Error", "Invalid purchase request!")
			if ExploitLogger then ExploitLogger.Log(player.UserId, "InvalidPurchase", "Invalid inventory index: " .. tostring(inventoryIndex), "Warning") end
			return
		end

		local inventory = PlayerShopInventory[player.UserId]
		if not inventory or not inventory.Items then
			NotifyPlayer:FireClient(player, "Error", "Shop inventory not loaded! Please refresh.")
			return
		end

		local shopItem = inventory.Items[inventoryIndex]
		if not shopItem then
			NotifyPlayer:FireClient(player, "Error", "Item not found in shop!")
			if ExploitLogger then ExploitLogger.Log(player.UserId, "InvalidPurchase", "Invalid inventory index: " .. tostring(inventoryIndex) .. " (out of range)", "Warning") end
			return
		end

		local part = shopItem.Part
		price = shopItem.Price

		if data.Money < price then
			NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. price .. " RC.")
			return
		end

		data.Money = data.Money - price
		if ExploitLogger then ExploitLogger.LogLargeTransaction(player.UserId, price, "Purchase", "part: " .. tostring(part.Name or "Unknown")) end

		local newPart = {
			PartId = HttpService:GenerateGUID(false),
			Type = part.Type,
			Name = part.Name,
			Rating = part.Rating,
			Quality = part.Quality or 50,
			Health = part.Health or 100,
			Performance = part.Performance,
			NETSpeed = part.NETSpeed,
			Storage = part.Storage,
			Power = part.Power,
			SocketType = part.SocketType,
			RAMType = part.RAMType,
			Slots = part.Slots
		}

		-- Defensive: ensure PartId is present and unique
		ensurePartHasId(newPart, player.UserId)
		table.insert(data.OwnedParts, newPart)
		if TraceManager and TraceManager.RecordPartOperation then
			TraceManager.RecordPartOperation(player.UserId, "Purchase", newPart.PartId, {Name = newPart.Name, Price = price})
		end
		queuePlayerSave(player.UserId)
		SendPCPartsData:FireClient(player, {
			OwnedParts = data.OwnedParts,
			EquippedParts = data.EquippedParts,
			Motherboard = data.Motherboard
		})
		NotifyPlayer:FireClient(player, "Success", "Purchased " .. newPart.Name .. " for " .. price .. " RC!")
		UpdateMoney:FireClient(player, data.Money)
		pcall(function()
			DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
		end)
	end
end)

SellPCPart.OnServerEvent:Connect(function(player, partId)
	local data = PlayerData[player.UserId]
	if not data then return end

	if not partId then
		NotifyPlayer:FireClient(player, "Error", "Invalid sell request!")
		return
	end

	local partIndex = nil
	local partToSell = nil

	for i, part in ipairs(data.OwnedParts) do
		if part.PartId == partId then
			if part.IsStartingPart then
				NotifyPlayer:FireClient(player, "Error", "Cannot sell starting parts!")
				return
			end
			partIndex = i
			partToSell = part
			break
		end
	end

	if not partToSell then
		NotifyPlayer:FireClient(player, "Error", "Part not found!")
		return
	end

	if partToSell.Type == "MOBO" then
		if data.Motherboard and data.Motherboard.PartId == partId then
			NotifyPlayer:FireClient(player, "Error", "Cannot sell equipped motherboard! Unequip it first.")
			return
		end
	else
		for slotName, equippedPart in pairs(data.EquippedParts) do
			if equippedPart and equippedPart.PartId == partId then
				NotifyPlayer:FireClient(player, "Error", "Cannot sell equipped part! Unequip it first.")
				return
			end
		end
	end

	-- Use same basePrices as shop generation (Bitcoin-level economy)
	-- Top tier parts (rating 10) are extremely expensive for long-term progression
	local basePrices = {[0] = 0.1, [1] = 0.5, [2] = 2, [3] = 5, [4] = 15, [5] = 40, [6] = 100, [7] = 250, [8] = 500, [9] = 750, [10] = 5000}
	local sellPrice = math.floor((basePrices[partToSell.Rating] or 0.5) * 0.6 * 1000) / 1000
	-- Don't apply multiplier again - basePrices are already scaled

	table.remove(data.OwnedParts, partIndex)
	data.Money = data.Money + sellPrice
	if TraceManager and TraceManager.RecordPartOperation then
		TraceManager.RecordPartOperation(player.UserId, "Sell", partToSell.PartId, {Name = partToSell.Name, Price = sellPrice})
	end
	checkAndResetPlayerRC(player.UserId)

	queuePlayerSave(player.UserId)
	UpdateMoney:FireClient(player, data.Money)
	pcall(function()
		DataStoreManager.SetPlayerMoney(player.UserId, data.Money)
	end)
	SendPCPartsData:FireClient(player, {
		OwnedParts = data.OwnedParts,
		EquippedParts = data.EquippedParts,
		Motherboard = data.Motherboard
	})
	NotifyPlayer:FireClient(player, "Success", "Sold " .. partToSell.Name .. " for " .. sellPrice .. " RC!")
end)

