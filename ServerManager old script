function getEffectiveSecurity(networkId, userId)
	local baseNetwork = nil

	if userId and PlayerData[userId] then
		for _, net in ipairs(PlayerData[userId].Networks) do
			if net.Id == networkId then
				baseNetwork = net
				break
			end
		end
	end

	if not baseNetwork then
		for _, net in ipairs(GlobalNetworks) do
			if net.Id == networkId then
				baseNetwork = net
				break
			end
		end
	end

	if not baseNetwork then
		return 1
	end

	local security = baseNetwork.Security

	-- Apply skill effects for home network defense
	if baseNetwork.IsPlayerHome and userId then
		local skillEffects = getPlayerSkillEffects(userId)
		if skillEffects.SecurityBoost then
			security = math.min(5, security + skillEffects.SecurityBoost)
		end
	end

	local boost = NetworkSecurityBoosts[networkId]
	if boost and time() < boost.ExpiryTime then
		security = math.min(5, security + boost.BoostLevel)
	end

	return security
end

