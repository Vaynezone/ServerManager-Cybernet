-- MailManager | ModuleScript | ServerScriptService.ServerFramework

local MailManager = {}
local EconomyManager = require(script.Parent.EconomyManager)

-- Dependencies
local deps = {}

function MailManager.Init(dependencies)
	deps = dependencies

	-- Connect Remote Events
	deps.Events.RequestMail.OnServerEvent:Connect(MailManager.OnRequestMail)
	deps.Events.SendMail.OnServerEvent:Connect(MailManager.OnSendMail)
	deps.Events.DeleteMail.OnServerEvent:Connect(MailManager.OnDeleteMail)
	deps.Events.ClaimMailMoney.OnServerEvent:Connect(MailManager.OnClaimMailMoney)
	deps.Events.ReplyToMail.OnServerEvent:Connect(MailManager.OnReplyToMail)
end

-- [ HELPER FUNCTIONS ] --

function MailManager.FilterMailData(mail, viewerId)
	for _, m in ipairs(mail) do
		if m.Type == "PlayerMail" then
			m.Subject = deps.filterText(m.Subject, viewerId)
			m.Message = deps.filterText(m.Message, viewerId)
		end
	end
	return mail
end

function MailManager.CheckAndMarkExpiredMissions(userId, mailList)
	local updatedMail = false
	for i, mail in ipairs(mailList) do
		if mail.Type == "MissionMail" and not mail.Expired then
			local missionExists = false
			if mail.Faction and mail.MissionId then
				local acceptedMission = deps.MissionsConfig.GetAcceptedMission(userId, mail.MissionId)
				if acceptedMission then
					missionExists = true
				else
					for _, m in ipairs(deps.MissionsConfig.ActiveMissions[mail.Faction] or {}) do
						if m.Id == mail.MissionId then
							missionExists = true
							break
						end
					end
				end
			end

			if not missionExists then
				mailList[i].Expired = true
				mailList[i].Subject = mail.Subject .. " [EXPIRED]"
				updatedMail = true
			end
		end
	end

	if updatedMail then
		deps.DataStoreManager.SaveMailData(userId, mailList)
	end

	return mailList
end

function MailManager.LoadMail(userId)
	local mailData = deps.DataStoreManager.LoadMailData(userId)
	if mailData then
		return MailManager.CheckAndMarkExpiredMissions(userId, mailData)
	end
	return {}
end

function MailManager.SaveMail(userId, mail)
	local mailList = MailManager.LoadMail(userId)
	table.insert(mailList, mail)
	deps.DataStoreManager.SaveMailData(userId, mailList)
end

function MailManager.DeleteMailById(userId, mailId)
	local mailList = MailManager.LoadMail(userId)
	for i = #mailList, 1, -1 do
		if mailList[i].Id == mailId then
			table.remove(mailList, i)
			break
		end
	end
	deps.DataStoreManager.SaveMailData(userId, mailList)
end

function MailManager.UpdateMailById(userId, mailId, updates)
	local mailList = MailManager.LoadMail(userId)
	for i, mail in ipairs(mailList) do
		if mail.Id == mailId then
			for key, value in pairs(updates) do
				mailList[i][key] = value
			end
			break
		end
	end
	deps.DataStoreManager.SaveMailData(userId, mailList)
end

function MailManager.SendWelcomeMail(userId)
	local mailId = deps.HttpService:GenerateGUID(false)
