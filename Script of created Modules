	if data.Money < nextLevelData.Cost then deps.Events.NotifyPlayer:FireClient(player, "Error", "Insufficient funds! Need " .. nextLevelData.Cost .. " RC.") return end

	data.Money = data.Money - nextLevelData.Cost
	data.NetworkScannerLevel = nextLevel
