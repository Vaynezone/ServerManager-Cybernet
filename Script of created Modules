-- Helper to sanitize firewalls for client
local function sanitizeFirewall(fw)
	if type(fw) ~= "table" then return nil end
	return {
		Library = tostring(fw.Library or ""),
		Version = tostring(fw.Version or ""),
		HasFirewall = (fw.HasFirewall == true) or false,
	}
end

function TerminalManager.Init(dependencies)
	deps = dependencies
	deps.Events.TerminalCommand.OnServerEvent:Connect(TerminalManager.OnTerminalCommand)
end

function TerminalManager.OnTerminalCommand(player, command, ...)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end

	if not command or type(command) ~= "string" or command == "" then
		deps.Events.TerminalResponse:FireClient(player, "ERROR: Invalid command. Type 'help' for a list of commands.")
		return
	end

	local args = {...}
	local trimmedCommand = command:match("^%s*(.-)%s*$")
	if trimmedCommand == "" then
		deps.Events.TerminalResponse:FireClient(player, "ERROR: Invalid command. Type 'help' for a list of commands.")
		return
	end
	local commandLower = trimmedCommand:lower()

	local aliasMap = {
		clr = "clear", sc = "scan", hk = "hack", exp = "exploit", lg = "login", lo = "logout",
		st = "steal", tl = "transactionlogs", cl = "connectionlogs", mv = "move", net = "networks",
		nw = "networks", dv = "devices", dev = "devices", cns = "connections", cnd = "connected",
		cn = "connect", dc = "disconnect", dsc = "discover", rm = "remove", rst = "reset_protocol",
		clops = "clearops", h = "help", ["?"] = "help"
	}
	if aliasMap[commandLower] then
		commandLower = aliasMap[commandLower]
	end

	if commandLower == "help" then
		if #args == 0 then
			deps.Events.TerminalResponse:FireClient(player, "Type 'help commands' to see a list of commands, or 'help <command>' for more information.\nPress Tab to autocomplete commands.")
		elseif args[1]:lower() == "commands" then
			deps.Events.TerminalResponse:FireClient(player, "Available commands (alias):\n  clear (clr) - Clear terminal output\n  scan (sc) - Scan a network or device\n  hack (hk) - Hack a network or device\n  exploit (exp) - Bypass firewall with exploit\n  login (lg) - Login to network/device with access code\n  logout (lo) - Logout from network/device\n  steal (st) - Steal Ro-Coin from device\n  transactionlogs (tl) - View transaction logs\n  connectionlogs (cl) - View connection logs\n  move (mv) - Move to a network\n  networks (net/nw) - List known networks\n  devices (dev/dv) - List devices on current network\n  connections (cns) - View recent connections to a network\n  connected (cnd) - View networks connected to an IP\n  connect (cn) - Connect two networks together\n  disconnect (dc) - Disconnect two networks\n  discover (dsc) - Add a network to viewer without connecting\n  remove (rm) - Remove a network from viewer\n  reset_protocol (rst) - Reset all networks\n  clearops (clops) - Clear stuck operations (fixes RAM issues)\n  help (h/?) - Display help information")
		else
			deps.Events.TerminalResponse:FireClient(player, "Help context provided for " .. args[1] .. " - Refer to manual.")
		end
	elseif commandLower == "clear" then
		-- Handled entirely by client usually, but included to prevent "Unknown Command"
		deps.Events.TerminalResponse:FireClient(player, "")
	elseif commandLower == "networks" then
		local networkList = "Known Networks:\n"
