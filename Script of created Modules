-- [ MULTIPLIERS & SKILLS ] --

function ProgressionManager.HasGamepass(userId, gamepassName)
	local data = deps.PlayerData[userId]
	if not data then return false end

	if data.OwnedGamepasses and data.OwnedGamepasses[gamepassName] then
		return true
	end

	local gamepassData = deps.GamepassConfig.Gamepasses[gamepassName]
	if gamepassData and gamepassData.ID > 0 then
		local success, owned = pcall(function()
			return deps.MarketplaceService:UserOwnsGamePassAsync(userId, gamepassData.ID)
		end)

		if success and owned then
			data.OwnedGamepasses = data.OwnedGamepasses or {}
			data.OwnedGamepasses[gamepassName] = true
			return true
		end
	end
	return false
end

function ProgressionManager.GetXPMultiplier(userId)
	local multiplier = 1
	local data = deps.PlayerData[userId]
	if not data then return multiplier end

	if ProgressionManager.HasGamepass(userId, "DoubleExperience") then multiplier = multiplier * 2 end
	if ProgressionManager.HasGamepass(userId, "CyberNetVIP") then multiplier = multiplier * 1.1 end

	if data.ActiveBoosts then
		for boostName, boostData in pairs(data.ActiveBoosts) do
			if boostData.Type == "XP" and time() < boostData.Expiry then
				multiplier = multiplier * boostData.Multiplier
			end
		end
	end
	return multiplier
end

function ProgressionManager.GetRoCoinMultiplier(userId)
	local multiplier = 1
	local data = deps.PlayerData[userId]
	if not data then return multiplier end

	if ProgressionManager.HasGamepass(userId, "DoubleProfits") then multiplier = multiplier * 2 end
	if ProgressionManager.HasGamepass(userId, "CyberNetVIP") then multiplier = multiplier * 1.1 end

	return multiplier
end

function ProgressionManager.GetPlayerSkillEffects(userId)
	local effects = {}
	local data = deps.PlayerData[userId]
	if not data or not data.UnlockedSkills then return effects end

	for branchKey, branch in pairs(deps.GameData.SkillTree.Branches) do
		for _, skill in ipairs(branch.Skills) do
			if data.UnlockedSkills[skill.Id] and skill.Effects then
				for effectKey, effectValue in pairs(skill.Effects) do
					if effectKey:find("Multiplier") then
						effects[effectKey] = (effects[effectKey] or 1) * effectValue
					elseif effectKey:find("Bonus") or effectKey:find("Reduction") or effectKey:find("Chance") then
						effects[effectKey] = (effects[effectKey] or 0) + effectValue
					elseif type(effectValue) == "boolean" then
						effects[effectKey] = effects[effectKey] or effectValue
					elseif type(effectValue) == "number" then
						if effectKey:find("Max") or effectKey:find("Duration") then
							effects[effectKey] = math.max(effectValue, effects[effectKey] or 0)
						else
							effects[effectKey] = (effects[effectKey] or 0) + effectValue
						end
					else
						effects[effectKey] = effectValue
					end
				end
			end
		end
	end
	return effects
end

function ProgressionManager.GetScanSpeedMultiplier(userId)
	local multiplier = 1
	local data = deps.PlayerData[userId]
	if not data then return multiplier end

	local skillEffects = ProgressionManager.GetPlayerSkillEffects(userId)
	if skillEffects.ScanSpeedMultiplier then
		multiplier = multiplier * skillEffects.ScanSpeedMultiplier
	end

	if data.ActiveBoosts then
		for boostName, boostData in pairs(data.ActiveBoosts) do
			if boostData.Type == "ScanSpeed" and time() < boostData.Expiry then
				multiplier = multiplier * boostData.Multiplier
			end
		end
	end
	return multiplier
end

function ProgressionManager.GetRareNetworkChanceBonus(userId)
	local bonus = 0
	if ProgressionManager.HasGamepass(userId, "CyberNetVIP") then bonus = bonus + 0.1 end
	return bonus
end

