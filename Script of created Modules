-- [ EVENT HANDLERS ] --

function MailManager.OnRequestMail(player)
	local userId = player.UserId
	local mail = MailManager.LoadMail(userId)
	deps.Events.SendMailData:FireClient(player, MailManager.FilterMailData(mail, userId))
end

function MailManager.OnSendMail(player, toPlayerName, subject, message, moneyAmount)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end

	moneyAmount = moneyAmount or 0
	if type(moneyAmount) ~= "number" or moneyAmount ~= moneyAmount or moneyAmount == math.huge or moneyAmount == -math.huge then
		moneyAmount = 0
	end
	moneyAmount = math.floor(math.abs(moneyAmount))

	if moneyAmount > 0 then
		if data.Money < moneyAmount then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Insufficient funds! You need " .. moneyAmount .. " RC.")
			return
		end
		if moneyAmount > 100000000 then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot send more than 100,000,000 RC!")
			return
		end
	end

	local targetUserId
	local success, result = pcall(function()
		return deps.Players:GetUserIdFromNameAsync(toPlayerName)
	end)

	if not success or not result then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Player '" .. toPlayerName .. "' not found!")
		return
	end

	targetUserId = result

	if targetUserId == userId then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "You cannot send mail to yourself!")
		return
	end

	subject = deps.filterText(subject, userId)
	message = deps.filterText(message, userId)

	if moneyAmount > 0 then
		local oldMoney = data.Money or 0
		local newMoney = oldMoney - moneyAmount

		if newMoney < 0 then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Insufficient funds! You need " .. moneyAmount .. " RC.")
			return
		end

		data.Money = newMoney
		EconomyManager.CheckAndResetPlayerRC(userId)
		deps.Events.UpdateMoney:FireClient(player, data.Money)
		pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
		deps.markPlayerDirty(userId)

		message = message .. "\n\n💰 Money attached: " .. moneyAmount .. " RC\nClick 'CLAIM' below to receive it."
	end

	local mailId = deps.HttpService:GenerateGUID(false)
	local mail = {
		Id = mailId,
		From = player.Name,
		Subject = subject,
		Message = message,
		Timestamp = os.time(),
		Read = false,
		Type = "PlayerMail",
		Responded = false,
		Money = moneyAmount > 0 and moneyAmount or nil,
		Claimed = false
	}

	MailManager.SaveMail(targetUserId, mail)

	local targetPlayer = deps.Players:GetPlayerByUserId(targetUserId)
	if targetPlayer then
		local targetMail = MailManager.LoadMail(targetUserId)
		deps.Events.SendMailData:FireClient(targetPlayer, MailManager.FilterMailData(targetMail, targetUserId))
	end

	local successMsg = "Mail sent to " .. toPlayerName .. (targetPlayer and " (online)" or " (offline)")
	if moneyAmount > 0 then
		successMsg = successMsg .. " with " .. moneyAmount .. " RC"
	end
	deps.Events.NotifyPlayer:FireClient(player, "Success", successMsg)
end

function MailManager.OnDeleteMail(player, mailId)
	MailManager.DeleteMailById(player.UserId, mailId)
end

function MailManager.OnClaimMailMoney(player, mailId)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end

	local mailList = MailManager.LoadMail(userId)
	local targetMail = nil
	for _, mail in ipairs(mailList) do
		if mail.Id == mailId then
			targetMail = mail
			break
		end
	end

	if not targetMail then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Mail not found!")
		return
	end
	if targetMail.Claimed then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "This reward has already been claimed!")
		return
	end
	if not targetMail.Money or targetMail.Money <= 0 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "This mail does not contain any money!")
		return
	end
	if targetMail.Type ~= "BountyReward" and targetMail.Type ~= "BountyRefund" and targetMail.Type ~= "PlayerMail" then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid mail type!")
		return
	end

	local rewardAmount = math.floor(targetMail.Money)

	data.Money = (data.Money or 0) + rewardAmount
	EconomyManager.CheckAndResetPlayerRC(userId)
	deps.Events.UpdateMoney:FireClient(player, data.Money)
	pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
	deps.markPlayerDirty(userId)

	MailManager.UpdateMailById(userId, mailId, { Claimed = true, Money = 0 })

	local userMail = MailManager.LoadMail(userId)
	deps.Events.SendMailData:FireClient(player, MailManager.FilterMailData(userMail, userId))
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Claimed " .. rewardAmount .. " RC!")
end

function MailManager.OnReplyToMail(player, mailId, replyText)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end

	local mail = MailManager.LoadMail(userId)
	local targetMail = nil

	for _, m in ipairs(mail) do
		if m.Id == mailId then
			targetMail = m
			break
		end
	end

	if not targetMail then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Mail not found!")
		return
	end

	if targetMail.Type == "MissionMail" then
		local mission = deps.MissionsConfig.GetAcceptedMission(userId, targetMail.MissionId)

		if not mission then
			for _, m in ipairs(deps.MissionsConfig.ActiveMissions[targetMail.Faction] or {}) do
				if m.Id == targetMail.MissionId then
					mission = m
					break
				end
			end
		end

		if not mission then
			MailManager.UpdateMailById(userId, mailId, { Expired = true, Subject = targetMail.Subject .. " [EXPIRED]" })
			local userMail = MailManager.LoadMail(userId)
			deps.Events.SendMailData:FireClient(player, MailManager.FilterMailData(userMail, userId))
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Mission expired - not available on this server!")
			return
		end

		if mission.Type == "GetConnectedIPs" then
			if not mission.ConnectedNetworks then
				local targetNet = nil
				for _, network in ipairs(deps.GlobalNetworks) do
					if network.Id == mission.TargetNetworkId then
						targetNet = network
						break
					end
				end

				if targetNet and targetNet.ConnectedNetworks then
					mission.ConnectedNetworks = {}
					for _, connId in ipairs(targetNet.ConnectedNetworks) do
						for _, network in ipairs(deps.GlobalNetworks) do
							if network.Id == connId then
								table.insert(mission.ConnectedNetworks, {IP = network.IP})
								break
							end
						end
					end
				end
			end
		elseif mission.Type == "StealFromDevice" then
			local hasStolen = false
			local targetNet = nil
			for _, network in ipairs(deps.GlobalNetworks) do
				if network.Id == mission.TargetNetworkId then
					targetNet = network
					break
				end
			end

			if targetNet and deps.AccessCodeSystem.ConnectionLogs then
				for _, device in ipairs(targetNet.Devices) do
					local logId = mission.TargetNetworkId .. "_" .. device.Id
					local logs = deps.AccessCodeSystem.ConnectionLogs[logId]
					if logs then
						for _, log in ipairs(logs) do
							if log.Action == "Steal" and log.User == player.Name then
								hasStolen = true
								break
							end
						end
					end
					if hasStolen then break end
				end
			end

			if not hasStolen then
				local factionName = targetMail.Faction == "NetSec" and "NetSec Authority" or "The Void Network"
				if not targetMail.Replies then targetMail.Replies = {} end

				local reply = {
					From = factionName,
					Message = "We have no record of a theft from the target network yet. Complete the mission and reply again.",
					Timestamp = os.time()
				}

				table.insert(targetMail.Replies, reply)
				MailManager.UpdateMailById(userId, mailId, {Replies = targetMail.Replies})

				local userMail = MailManager.LoadMail(userId)
				deps.Events.SendMailData:FireClient(player, MailManager.FilterMailData(userMail, userId))
				deps.Events.NotifyPlayer:FireClient(player, "Info", "Mission not complete yet")
				return
			end
		end

		local isComplete = deps.MissionsConfig.ValidateMissionCompletion(mission, replyText)
		local factionName = targetMail.Faction == "NetSec" and "NetSec Authority" or "The Void Network"

		if isComplete then
			local completionSuccess = deps.MissionsConfig.CompleteMission(userId, mission.Id)
			if not completionSuccess then
				warn("[MISSIONS] Failed to mark mission as complete for user " .. userId)
			end

			local missionReward = mission.Reward or 0
			data.Money = data.Money + missionReward
			EconomyManager.CheckAndResetPlayerRC(player.UserId)
			deps.Events.UpdateMoney:FireClient(player, data.Money)
			pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)

			if not targetMail.Replies then targetMail.Replies = {} end
			table.insert(targetMail.Replies, {
				From = factionName,
				Message = "Excellent work! Mission completed successfully.\n\nReward: " .. mission.Reward .. " RC has been deposited to your account.",
				Timestamp = os.time()
			})

			MailManager.UpdateMailById(userId, mailId, { Responded = true, Replies = targetMail.Replies })

			local userMail = MailManager.LoadMail(userId)
			deps.Events.SendMailData:FireClient(player, MailManager.FilterMailData(userMail, userId))
			deps.Events.NotifyPlayer:FireClient(player, "Success", "Mission completed! +" .. mission.Reward .. " RC")

			local isCriminal = targetMail.Faction == "Void"
			if isCriminal then
				deps.adjustReputation(player, -(mission.Stars * 2), "Completed Criminal Mission")
			else
				deps.adjustReputation(player, mission.Stars * 2, "Completed Police Mission")
			end
		else
			if not targetMail.Replies then targetMail.Replies = {} end
			table.insert(targetMail.Replies, {
				From = factionName,
				Message = "The information provided does not match our requirements. Please verify and submit again.",
				Timestamp = os.time()
			})

			MailManager.UpdateMailById(userId, mailId, {Replies = targetMail.Replies})

			local userMail = MailManager.LoadMail(userId)
			deps.Events.SendMailData:FireClient(player, MailManager.FilterMailData(userMail, userId))
			deps.Events.NotifyPlayer:FireClient(player, "Info", "Mission not complete yet")
		end
	end
end

-- Share these functions globally so ServerManager and BountyManager can still use them
_G.saveMail = MailManager.SaveMail
_G.loadMail = MailManager.LoadMail
_G.sendWelcomeMail = MailManager.SendWelcomeMail

return MailManager


-- AdminMonetizationManager | ModuleScript | ServerScriptService.ServerFramework

local AdminMonetizationManager = {}
local deps = {}

function AdminMonetizationManager.Init(dependencies)
	deps = dependencies

	-- Link DevProducts
	deps.MarketplaceService.ProcessReceipt = AdminMonetizationManager.ProcessReceipt

	-- Link Admin Bindables
	local AdminEditPlayerBindable = deps.Bindables.AdminEditPlayerBindable
	local AdminEditBountyBindable = deps.ReplicatedStorage:FindFirstChild("AdminEditBountyBindable") or Instance.new("BindableEvent", deps.ReplicatedStorage)
	AdminEditBountyBindable.Name = "AdminEditBountyBindable"

	local GetOnlinePlayersBindable = deps.ReplicatedStorage:FindFirstChild("GetOnlinePlayersBindable") or Instance.new("BindableFunction", deps.ReplicatedStorage)
	GetOnlinePlayersBindable.Name = "GetOnlinePlayersBindable"

	if AdminEditPlayerBindable then
		AdminEditPlayerBindable.Event:Connect(function(targetUserId, updates)
			if deps.PlayerData[targetUserId] then
				if updates.Money ~= nil then deps.PlayerData[targetUserId].Money = updates.Money end
				if updates.SkillPoints ~= nil then
					deps.PlayerData[targetUserId].SkillPoints = math.clamp(math.floor(updates.SkillPoints), 0, 90)
					deps.PlayerData[targetUserId].PendingSkillPoints = 0
					local player = deps.Players:GetPlayerByUserId(targetUserId)
					if player and deps.Events.SendSkillTree then
						deps.Events.SendSkillTree:FireClient(player, { SkillPoints = deps.PlayerData[targetUserId].SkillPoints or 0, UnlockedSkills = deps.PlayerData[targetUserId].UnlockedSkills or {} })
					end
				end
				if updates.Reputation ~= nil then deps.PlayerData[targetUserId].Reputation = updates.Reputation end
			end
		end)
	end

	AdminEditBountyBindable.Event:Connect(function(action, targetData, adminPlayer)
		if not deps.BountyManager then if adminPlayer then deps.Events.NotifyPlayer:FireClient(adminPlayer, "Error", "Bounty system not available.") end return end

		if action == "SetPoliceBounty" then
			deps.BountyManager.RemovePoliceBounty(targetData.UserId)
			if (targetData.Amount or 0) > 0 then deps.BountyManager.AddPoliceBounty(targetData.Name, targetData.UserId, targetData.Amount) end
			if adminPlayer then deps.Events.NotifyPlayer:FireClient(adminPlayer, "Success", "Police bounty for " .. targetData.Name .. " set to " .. targetData.Amount) end
		elseif action == "SetCriminalBounty" then
			deps.BountyManager.RemoveCriminalBounty(targetData.Name, targetData.IsGuild or false)
			if (targetData.Amount or 0) > 0 then deps.BountyManager.AddCriminalBounty(targetData.Name, targetData.Amount, nil, "Admin", targetData.IsGuild or false) end
			if adminPlayer then deps.Events.NotifyPlayer:FireClient(adminPlayer, "Success", "Criminal bounty for " .. targetData.Name .. " set to " .. targetData.Amount) end
		elseif action == "RemovePoliceBounty" then
			deps.BountyManager.RemovePoliceBounty(targetData.UserId)
			if adminPlayer then deps.Events.NotifyPlayer:FireClient(adminPlayer, "Success", "Police bounty for " .. (targetData.Name or "Unknown") .. " removed.") end
		elseif action == "RemoveCriminalBounty" then
			deps.BountyManager.RemoveCriminalBounty(targetData.Name, targetData.IsGuild or false)
			if adminPlayer then deps.Events.NotifyPlayer:FireClient(adminPlayer, "Success", "Criminal bounty for " .. targetData.Name .. " removed.") end
		end
	end)

	GetOnlinePlayersBindable.OnInvoke = function()
		local onlinePlayers = {}
		for _, player in ipairs(deps.Players:GetPlayers()) do
			local data = deps.PlayerData[player.UserId]
			if data then
				local guildName = (data.Guild and deps.Guilds[data.Guild]) and deps.Guilds[data.Guild].Name or nil
				table.insert(onlinePlayers, { UserId = player.UserId, Name = player.Name, Money = data.Money or 0, Reputation = data.Reputation or 0, IP = data.IP or "Unknown", GuildId = data.Guild, GuildName = guildName })
			else
				table.insert(onlinePlayers, { UserId = player.UserId, Name = player.Name, Money = 0, Reputation = 0, IP = "Unknown", GuildId = nil, GuildName = nil })
			end
		end
		return onlinePlayers
	end
end

function AdminMonetizationManager.ProcessReceipt(receiptInfo)
	local player = deps.Players:GetPlayerByUserId(receiptInfo.PlayerId)
	if not player then return Enum.ProductPurchaseDecision.NotProcessedYet end
	local data = deps.PlayerData[player.UserId]
	if not data then return Enum.ProductPurchaseDecision.NotProcessedYet end

	local productId = receiptInfo.ProductId
	local productData = nil
	local productKey = nil

	for key, devProduct in pairs(deps.GamepassConfig.DevProducts) do
		if devProduct.ID == productId then
			productData = devProduct
			productKey = key
			break
		end
	end

	if not productData then return Enum.ProductPurchaseDecision.NotProcessedYet end

	local success = pcall(function()
		if productData.Category == "RC" then
			local rcAmount = deps.EconomyManager.ApplyMoneyMultiplier(productData.Amount)
			data.Money = data.Money + rcAmount
			deps.EconomyManager.CheckAndResetPlayerRC(player.UserId)
			deps.Events.UpdateMoney:FireClient(player, data.Money)
			pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
			deps.Events.NotifyPlayer:FireClient(player, "Success", "Received " .. productData.Amount .. " Ro-Coin!")

		elseif productKey == "ShopRefresh" then
			if deps.HardwareManager and deps.HardwareManager.OnRefreshShop then
				deps.HardwareManager.OnRefreshShop(player)
			else
				deps.Events.NotifyPlayer:FireClient(player, "Success", "Shop inventory refreshed!")
			end

		elseif productKey == "ReputationReset" then
			data.Reputation = 0
			data.PositiveRep = 0
			data.NegativeRep = 0
			deps.Events.UpdateReputation:FireClient(player, 0, 0, 0)
			deps.Events.NotifyPlayer:FireClient(player, "Success", "Reputation has been reset!")

		elseif productKey == "XPBoost30Min" or productKey == "UltimateXPBoost60Min" then
			data.ActiveBoosts = data.ActiveBoosts or {}
			data.ActiveBoosts[productKey] = {
				Type = "XP", Multiplier = productData.Multiplier, Expiry = time() + productData.Duration
			}
			deps.Events.NotifyPlayer:FireClient(player, "Success", productData.Name .. " activated!")

		elseif productKey == "ScanSpeedBoost1Hr" then
			data.ActiveBoosts = data.ActiveBoosts or {}
			data.ActiveBoosts[productKey] = {
				Type = "ScanSpeed", Multiplier = productData.Multiplier, Expiry = time() + productData.Duration
			}
			deps.Events.NotifyPlayer:FireClient(player, "Success", productData.Name .. " activated!")
		end
	end)

	if success then
		return Enum.ProductPurchaseDecision.PurchaseGranted
	else
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
end

return AdminMonetizationManager

-- DataSaveManager | ModuleScript | ServerScriptService.ServerFramework

local DataSaveManager = {}
local deps = {}

function DataSaveManager.Init(dependencies)
	deps = dependencies
end

function DataSaveManager.MarkPlayerDirty(userId)
	deps.PlayerDataDirty[userId] = true
end

function DataSaveManager.BuildSaveData(userId)
	local data = deps.PlayerData[userId]
	if not data then return nil end

	local homeNetworkData = nil
	for _, network in ipairs(data.Networks or {}) do
		if network.IsPlayerHome then
			local devicesData = {}
			for _, device in ipairs(network.Devices or {}) do
				table.insert(devicesData, {
					Id = device.Id, Type = device.Type, Name = device.Name,
					Security = device.Security, Icon = device.Icon, LANIP = device.LANIP,
					IsPlayerComputer = device.IsPlayerComputer, Firewall = device.Firewall,
					AccessCode = device.AccessCode
				})
			end
			homeNetworkData = {
				Security = network.Security, AdminTier = network.AdminTier,
				Devices = devicesData, Firewall = network.Firewall, AccessCode = network.AccessCode
			}
			if deps.AccessCodeSystem.StealTimers and deps.AccessCodeSystem.StealTimers[userId] then
				homeNetworkData.StealCooldowns = {}
				for key, expiry in pairs(deps.AccessCodeSystem.StealTimers[userId]) do
					if key:find(network.Id, 1, true) then
						local remaining = math.max(0, expiry - time())
						if remaining > 0 then homeNetworkData.StealCooldowns[key] = remaining end
					end
				end
			end
			break
