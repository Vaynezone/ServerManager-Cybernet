function ProgressionManager.OnUnlockSkill(player, skillId)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	local skill = nil
	for branchKey, branch in pairs(deps.GameData.SkillTree.Branches) do
		for _, s in ipairs(branch.Skills) do
			if s.Id == skillId then skill = s break end
		end
		if skill then break end
	end

	if not skill then deps.Events.NotifyPlayer:FireClient(player, "Error", "Skill not found!") return end
	if data.UnlockedSkills[skillId] then deps.Events.NotifyPlayer:FireClient(player, "Error", "Skill already unlocked!") return end

	if skill.Prerequisites and #skill.Prerequisites > 0 then
		for _, prereqId in ipairs(skill.Prerequisites) do
			if not data.UnlockedSkills[prereqId] then
				deps.Events.NotifyPlayer:FireClient(player, "Error", "Prerequisites not met!") return
			end
		end
	end

	if (data.SkillPoints or 0) < skill.Cost then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough skill points! Need " .. skill.Cost .. " SP.") return
	end

	data.UnlockedSkills[skillId] = true
	data.SkillPoints = (data.SkillPoints or 0) - skill.Cost
	deps.queuePlayerSave(player.UserId)

	deps.Events.NotifyPlayer:FireClient(player, "Success", "Unlocked: " .. skill.Name .. "!")
	deps.Events.SendSkillTree:FireClient(player, {SkillPoints = data.SkillPoints, UnlockedSkills = data.UnlockedSkills})
end

