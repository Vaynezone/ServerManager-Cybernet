			if not currentNet then deps.Events.TerminalResponse:FireClient(player, "ERROR: Not connected to any network") return end
			ip2 = ip1; ip1 = currentNet.IP
		end

		local network1, network2 = nil, nil
		for _, network in ipairs(data.Networks) do
			if network.IP == ip1 then network1 = network end
			if network.IP == ip2 then network2 = network end
		end

		if not network1 or not network2 then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network not found") return end
		deps.disconnectNetworks(network1, network2)

		local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
		deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		deps.Events.TerminalResponse:FireClient(player, "✓ Disconnected " .. ip2 .. " from " .. ip1)

	elseif commandLower == "discover" then
		local targetIP = args[1]
		if not targetIP then deps.Events.TerminalResponse:FireClient(player, "ERROR: Usage: discover <IP>") return end

		local invisibleNetwork = nil
		for _, network in ipairs(data.Networks) do
			if network.IP == targetIP then
				if not network.Visible then invisibleNetwork = network else deps.Events.TerminalResponse:FireClient(player, "ERROR: Network already in viewer") return end
				break
			end
		end

		if invisibleNetwork then
			invisibleNetwork.Visible = true
			deps.Events.SendNetworkData:FireClient(player, deps.prepareNetworksForClient(data.Networks, player.UserId), data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
			deps.Events.TerminalResponse:FireClient(player, "✓ Network added to viewer")
			return
		end

		local foundNet = nil
		for _, globalNet in ipairs(deps.GlobalNetworks) do
			if globalNet.IP == targetIP then
				if globalNet.IsGuildNetwork then
					local currentNet = deps.getNetwork(data.CurrentNetwork, userId)
					local isConnected = false
					if currentNet and currentNet.ConnectedNetworks then
						for _, connectedId in ipairs(currentNet.ConnectedNetworks) do
							if connectedId == globalNet.Id then isConnected = true break end
						end
					end
					if not isConnected then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network Unreachable") return end
				end
				foundNet = globalNet
				break
			end
		end

		if not foundNet then
			for otherUserId, otherData in pairs(deps.PlayerData) do
				if otherUserId ~= userId and otherData.Networks then
					for _, network in ipairs(otherData.Networks) do
						if network.IP == targetIP and network.IsPlayerHome then
							local otherPlayer = deps.Players:GetPlayerByUserId(otherUserId)
							if otherPlayer then
								local netCopy = {}
								for key, value in pairs(network) do netCopy[key] = value end
								netCopy.Scanned = false; netCopy.Hacked = false; netCopy.IsPlayerHome = false
								netCopy.IsOtherPlayerHome = true; netCopy.OriginalOwnerId = otherUserId; netCopy.Owner = otherUserId
								netCopy.ConnectedNetworks = {}; netCopy.Devices = {}

								for _, dev in ipairs(network.Devices) do
									local deviceName = dev.IsPlayerComputer and (otherPlayer.Name .. "'s Computer") or dev.Name
									table.insert(netCopy.Devices, {
										Id = dev.Id, Type = dev.Type, Name = deviceName, Security = dev.Security, Icon = dev.Icon,
										Scanned = false, Hacked = false, IsPlayerComputer = false, LANIP = dev.LANIP, OwnerUserId = otherUserId,
										AccessCode = dev.AccessCode, Firewall = sanitizeFirewall(dev.Firewall), FirewallBypassed = false,
										ParentMainframe = dev.ParentMainframe, SubDevices = dev.SubDevices, IsMainframe = dev.IsMainframe, IsSpecialDevice = dev.IsSpecialDevice
									})
								end
								netCopy.Position = Vector2.new(math.random(-200, 200), math.random(-200, 200))
								netCopy.Visible = true

								local maxNetworks = deps.getMaxStoredNetworks(player)
								if #data.Networks >= maxNetworks then deps.Events.TerminalResponse:FireClient(player, "ERROR: HDD storage full!") return end

								table.insert(data.Networks, netCopy)
								deps.Events.SendNetworkData:FireClient(player, deps.prepareNetworksForClient(data.Networks, player.UserId), data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
								deps.Events.TerminalResponse:FireClient(player, "✓ Network " .. targetIP .. " added")
								return
							end
						end
					end
				end
			end
		end

		if not foundNet then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network " .. targetIP .. " not found") return end

		local netCopy = {
			Id = foundNet.Id, IP = foundNet.IP, Name = foundNet.Name, Type = foundNet.Type, Security = foundNet.Security, AdminTier = foundNet.AdminTier,
			HasAdmin = foundNet.HasAdmin, Scanned = false, Hacked = false, Owner = foundNet.Owner, Locked = false, LockExpiry = 0, TracesReceived = 0,
			Devices = {}, ConnectedNetworks = {}, Position = Vector2.new(math.random(-200, 200), math.random(-200, 200)), Visible = true,
			AccessCode = foundNet.AccessCode, Firewall = sanitizeFirewall(foundNet.Firewall), FirewallBypassed = false, IsGuildNetwork = foundNet.IsGuildNetwork, GuildId = foundNet.GuildId
		}

		for _, dev in ipairs(foundNet.Devices) do
			table.insert(netCopy.Devices, {
				Id = dev.Id, Type = dev.Type, Name = dev.Name, Security = dev.Security, Icon = dev.Icon, Scanned = false, Hacked = false,
				IsPlayerComputer = false, LANIP = dev.LANIP, AccessCode = dev.AccessCode, Firewall = sanitizeFirewall(dev.Firewall),
				FirewallBypassed = false, ParentMainframe = dev.ParentMainframe, SubDevices = dev.SubDevices, IsMainframe = dev.IsMainframe,
				IsSpecialDevice = dev.IsSpecialDevice, IsGuildFundsDevice = dev.IsGuildFundsDevice, GuildId = dev.GuildId
			})
		end

		local maxNetworks = deps.getMaxStoredNetworks(player)
		if #data.Networks >= maxNetworks then deps.Events.TerminalResponse:FireClient(player, "ERROR: HDD storage full!") return end

		table.insert(data.Networks, netCopy)

		local specialNetworkBadges = { SolariaNetwork = 1560663258748912, MonarchNetwork = 1500915775288637 }
		if specialNetworkBadges[foundNet.Type] then
			pcall(function() if not deps.BadgeService:UserHasBadgeAsync(player.UserId, specialNetworkBadges[foundNet.Type]) then deps.BadgeService:AwardBadge(player.UserId, specialNetworkBadges[foundNet.Type]) end end)
		end

		deps.Events.SendNetworkData:FireClient(player, deps.prepareNetworksForClient(data.Networks, player.UserId), data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		deps.Events.TerminalResponse:FireClient(player, "✓ Network " .. targetIP .. " added to network viewer")

	elseif commandLower == "remove" then
		local targetIP = args[1]
		if not targetIP or type(targetIP) ~= "string" or targetIP == "" then deps.Events.TerminalResponse:FireClient(player, "ERROR: Invalid network IP") return end

		local homeNet = deps.getNetwork(data.HomeNetwork, userId)
		if homeNet and homeNet.IP == targetIP then deps.Events.TerminalResponse:FireClient(player, "ERROR: Cannot remove your home network") return end

		local currentNet = deps.getNetwork(data.CurrentNetwork, userId)
		if currentNet and currentNet.IP == targetIP then deps.Events.TerminalResponse:FireClient(player, "ERROR: Cannot remove network you are currently connected to. Use 'move' command first") return end

		local foundIndex = nil
		for i, network in ipairs(data.Networks) do
			if network.IP == targetIP and (network.Visible == nil or network.Visible == true) then foundIndex = i break end
		end

		if not foundIndex then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network " .. targetIP .. " not found in viewer") return end

		local removedNet = data.Networks[foundIndex]
		table.remove(data.Networks, foundIndex)

		for _, network in ipairs(data.Networks) do
			if network.ConnectedNetworks then
				for j = #network.ConnectedNetworks, 1, -1 do
					if network.ConnectedNetworks[j] == removedNet.Id then table.remove(network.ConnectedNetworks, j) end
				end
			end
		end

		deps.markPlayerDirty(userId)
		deps.Events.SendNetworkData:FireClient(player, deps.prepareNetworksForClient(data.Networks, player.UserId), data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		deps.Events.TerminalResponse:FireClient(player, "✓ Network " .. targetIP .. " removed from network viewer")

	elseif commandLower == "transactionlogs" then
		local arg1, arg2 = args[1], args[2]
		local targetNet, targetDevice = nil, nil

		if arg2 then
			for _, network in ipairs(data.Networks) do if network.IP == arg1 then targetNet = network break end end
			if not targetNet then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network not found") return end
			for _, dev in ipairs(targetNet.Devices) do if dev.LANIP == arg2 then targetDevice = dev break end end
			if not targetDevice then deps.Events.TerminalResponse:FireClient(player, "ERROR: Device not found") return end
		else
			if not data.CurrentNetwork then deps.Events.TerminalResponse:FireClient(player, "ERROR: Not connected to any network.") return end
			targetNet = deps.getNetwork(data.CurrentNetwork, userId)
			for _, dev in ipairs(targetNet.Devices) do if dev.LANIP == arg1 then targetDevice = dev break end end
			if not targetDevice then deps.Events.TerminalResponse:FireClient(player, "ERROR: Device not found on current network") return end
		end

		if not deps.AccessCodeSystem.IsLoggedIn(player.UserId, targetNet.Id, targetDevice.Id) then deps.Events.TerminalResponse:FireClient(player, "ERROR: You must be logged in to view logs") return end

		local logs = deps.AccessCodeSystem.GetTransactionLogs(targetNet.Id, targetDevice.Id)
		local logText = "=== TRANSACTION LOGS ===\n\n"
		if #logs == 0 then logText = logText .. "No transactions recorded.\n" else
			for i = math.max(1, #logs - 9), #logs do
				local log = logs[i]
				local timeAgo = math.floor(os.time() - log.Time)
				logText = logText .. string.format("%s %d RC from %s (%ds ago)\n", log.Type, log.Amount, log.SourceIP, timeAgo)
			end
		end
		deps.Events.TerminalResponse:FireClient(player, logText)

	elseif commandLower == "connectionlogs" then
		local arg1, arg2 = args[1], args[2]
		local targetNet, targetDevice = nil, nil

		if arg2 then
			for _, network in ipairs(data.Networks) do if network.IP == arg1 then targetNet = network break end end
			if not targetNet then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network not found") return end
			for _, dev in ipairs(targetNet.Devices) do if dev.LANIP == arg2 then targetDevice = dev break end end
			if not targetDevice then deps.Events.TerminalResponse:FireClient(player, "ERROR: Device not found") return end
			if not deps.AccessCodeSystem.IsLoggedIn(player.UserId, targetNet.Id, targetDevice.Id) then deps.Events.TerminalResponse:FireClient(player, "ERROR: You must be logged in to view logs") return end
		elseif arg1 then
			targetNet = deps.getNetwork(data.CurrentNetwork, userId)
			local foundDev = false
			for _, dev in ipairs(targetNet.Devices) do if dev.LANIP == arg1 then targetDevice = dev; foundDev = true break end end
			if not foundDev then
				targetNet = nil
				for _, network in ipairs(data.Networks) do if network.IP == arg1 then targetNet = network break end end
				if not targetNet then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network or device not found") return end
				if not deps.AccessCodeSystem.IsLoggedIn(player.UserId, targetNet.Id) then deps.Events.TerminalResponse:FireClient(player, "ERROR: You must be logged in to view logs") return end
			else
				if not deps.AccessCodeSystem.IsLoggedIn(player.UserId, targetNet.Id, targetDevice.Id) then deps.Events.TerminalResponse:FireClient(player, "ERROR: You must be logged in to view logs") return end
			end
		else
			if not data.LoggedInNetwork then deps.Events.TerminalResponse:FireClient(player, "ERROR: You must be logged into a network or device") return end
			targetNet = {Id = data.LoggedInNetwork}
			if data.LoggedInDevice then targetDevice = {Id = data.LoggedInDevice} end
		end

		local logs = deps.AccessCodeSystem.GetConnectionLogs(targetNet.Id, targetDevice and targetDevice.Id or nil)
		local logText = "=== CONNECTION LOGS ===\n\n"
		if #logs == 0 then logText = logText .. "No connection activity recorded.\n" else
			for i = math.max(1, #logs - 9), #logs do
				local log = logs[i]
				local timeAgo = math.floor(os.time() - log.Time)
				local status = log.Success and "SUCCESS" or "FAILED"
				logText = logText .. string.format("[%s] %s from %s (%ds ago)\n", status, log.Action, log.UserIP, timeAgo)
			end
		end
		deps.Events.TerminalResponse:FireClient(player, logText)

	elseif commandLower == "reset_protocol" or commandLower == "reset" then
		deps.Events.Folder.ResetNetworks:Fire(player)

	elseif commandLower == "program" then
		local action = args[1] and args[1]:lower() or ""
		local programName = args[2]
		local targetIP = args[3]

		local progBindables = deps.ReplicatedStorage:FindFirstChild("ProgramBindables")

		if action == "list" then
			local programList = "=== PROGRAMS ===\n\n"
			local count = 0
			local ProgramsStore = deps.DataStoreService:GetDataStore("PlayerPrograms")
			local success, encoded = pcall(function() return ProgramsStore:GetAsync("Programs_" .. userId) end)

			local userPrograms = {}
			if success and encoded then
				local decoded = deps.HttpService:JSONDecode(encoded)
				if decoded then userPrograms = decoded end
			end

			for id, serialized in pairs(userPrograms) do
				local program = deps.ProgramManagerModule.DeserializeProgram(serialized)
				if program then
					count = count + 1
					local prebuilt = program.IsPrebuilt and " [Prebuilt]" or ""
					programList = programList .. "  " .. program.Name .. prebuilt .. "\n"
				end
			end
			if count == 0 then programList = programList .. "  No programs found.\n" end
			deps.Events.TerminalResponse:FireClient(player, programList)
		elseif action == "start" then
			if not programName then deps.Events.TerminalResponse:FireClient(player, "ERROR: Usage: program start <name> [target_ip]") return end
			local contextType = "None"
			local targetId = nil

			if targetIP then
				for _, network in ipairs(data.Networks) do
					if network.IP == targetIP then
						contextType = "Network"
						targetId = network.Id
						break
					end
				end
				if not targetId then deps.Events.TerminalResponse:FireClient(player, "ERROR: Network " .. targetIP .. " not found") return end
			end

			if progBindables then
				local startProg = progBindables:FindFirstChild("StartProgram")
				if startProg then
					local success, result = startProg:Invoke(player, programName, contextType, targetId, nil)
					if not success then deps.Events.TerminalResponse:FireClient(player, "ERROR: " .. (result or "Failed to start program")) end
				end
			end
		else
			deps.Events.TerminalResponse:FireClient(player, "ERROR: Unknown program action '" .. action .. "'. Use: list, start")
		end
	else
		deps.Events.TerminalResponse:FireClient(player, "Command executed or routed to UI. (Check GUI logs if error persists).")
	end
end

return TerminalManager
