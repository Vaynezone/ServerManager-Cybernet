			end
		else
			if network.FirewallBypassed then return {Library = "", Version = "", HasFirewall = false} end
		end
		local fw = deps.sanitizeFirewall(firewall)
		if fw and fw.HasFirewall == true then return {Library = fw.Library or "", Version = fw.Version or "", HasFirewall = true} end
		return {Library = "", Version = "", HasFirewall = false}
	end)

