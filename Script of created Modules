		if deviceId then return data.LoggedInDevice == deviceId end
		return data.LoggedInNetwork == networkId
	end)

	addBindable("GetParentNetwork", function(player, deviceId)
		local data = deps.PlayerData[player.UserId]
		if not data or not deviceId then return nil end
		for _, network in ipairs(data.Networks) do
			for _, device in ipairs(network.Devices or {}) do
