-- CrimeManager | ModuleScript | ServerScriptService.ServerFramework

local CrimeManager = {}
local deps = {}
local PendingStealChallenges = {}
local BOUNTY_LIMIT = 100000000

function CrimeManager.Init(dependencies)
	deps = dependencies

	-- Connect Events
	deps.Events.SubmitBounty.OnServerEvent:Connect(CrimeManager.OnSubmitBounty)
	deps.Events.ClaimBounty.OnServerEvent:Connect(CrimeManager.OnClaimBounty)
	deps.Events.ClaimPoliceBounty.OnServerEvent:Connect(CrimeManager.OnClaimPoliceBounty)
	deps.Events.RequestWantedBoards.OnServerEvent:Connect(CrimeManager.OnRequestWantedBoards)
	deps.Events.StealFromNode.OnServerEvent:Connect(CrimeManager.OnStealFromNode)
	deps.Events.SubmitStealAnswer.OnServerEvent:Connect(CrimeManager.OnSubmitStealAnswer)

	local RequestNetSecQTE = deps.Events.Folder:FindFirstChild("RequestNetSecQTE")
	local CompleteNetSecQTE = deps.Events.Folder:FindFirstChild("CompleteNetSecQTE")

	if RequestNetSecQTE then RequestNetSecQTE.OnServerEvent:Connect(CrimeManager.OnRequestNetSecQTE) end
	if CompleteNetSecQTE then CompleteNetSecQTE.OnServerEvent:Connect(CrimeManager.OnCompleteNetSecQTE) end
end

-- [ HELPER FUNCTIONS ] --

function CrimeManager.GenerateRandomWord(excludeWords)
	excludeWords = excludeWords or {}
	local allWords = {
		"Firewall", "Encryption", "Decryption", "Protocol", "Network", "Security",
		"Access", "Bypass", "Exploit", "Vulnerability", "Authentication", "Authorization",
		"Intrusion", "Detection", "Prevention", "Malware", "Virus", "Trojan",
		"Backdoor", "Rootkit", "Phishing", "Spyware", "Adware", "ZeroDay",
		"Payload", "Cipher", "Algorithm", "Hash", "Salt", "Token",
		"Session", "Cookie", "Certificate", "Breach", "Penetration", "Keylogger",
		"Ransomware", "Botnet", "Dictionary", "Rainbow", "Keygen", "Cracker",
		"ScriptKiddie", "WhiteHat", "BlackHat", "GreyHat", "Ethical", "Unethical",
		"NULLBYTE", "BUFFER", "STACK", "HEAP", "REGISTER",
		"SHELLCODE", "PAYLOAD", "EXPLOIT", "VULN", "PATCH",
		"NoSQLi", "Kerberos", "HTTPS", "TLS", "SSL", "AES", "RSA", "SHA256",
		"MD5", "SHA1", "BCrypt", "PBKDF2", "Scrypt",
		"APIKey", "AuthToken", "SessionID", "CookieID", "CSRFToken"
	}

	local excludeSet = {}
	for _, word in ipairs(excludeWords) do excludeSet[word] = true end

	local attempts = 0
	repeat
		local index = math.random(1, #allWords)
		local word = allWords[index]
		if not excludeSet[word] then return word end
		attempts = attempts + 1
	until attempts >= 100

	return allWords[math.random(1, #allWords)]
end

function CrimeManager.GenerateStealChallenge(securityLevel)
	securityLevel = math.clamp(securityLevel or 3, 1, 5)
	local wordCount = (securityLevel <= 2) and math.random(3, 5) or (securityLevel == 3) and math.random(5, 7) or math.random(7, 10)

	local challengeWords = {}
	local usedWords = {}

	for i = 1, wordCount do
		local word = CrimeManager.GenerateRandomWord(usedWords)
		table.insert(usedWords, word)
		table.insert(challengeWords, word)
	end
	return challengeWords
end

function CrimeManager.GetPlayerIP(userId)
	if deps.PlayerData[userId] then return deps.PlayerData[userId].IP end
	return "Offline"
end

-- [ REMOTE HANDLERS ] --

function CrimeManager.OnSubmitBounty(player, targetName, isGuild, bountyAmount)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if not targetName or targetName == "" then deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid target name!") return end
	if player.Name:lower() == targetName:lower() then deps.Events.NotifyPlayer:FireClient(player, "Error", "You cannot place a bounty on yourself!") return end
	if not deps.EconomyManager.IsValidNumber(bountyAmount) then deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid bounty amount!") return end

	bountyAmount = math.floor(bountyAmount)
	if bountyAmount < 100 then deps.Events.NotifyPlayer:FireClient(player, "Error", "Bounty must be at least 100 RC!") return end
	if bountyAmount > BOUNTY_LIMIT then deps.Events.NotifyPlayer:FireClient(player, "Error", "Bounty cannot exceed " .. BOUNTY_LIMIT .. " RC!") return end
	if data.Money < bountyAmount then deps.Events.NotifyPlayer:FireClient(player, "Error", "Insufficient funds!") return end

	local targetExists = false
	if not isGuild then
		for _, p in ipairs(deps.Players:GetPlayers()) do
			if p.Name:lower() == targetName:lower() then targetExists = true; targetName = p.Name; break end
		end
	end

	if not targetExists and not isGuild then deps.Events.NotifyPlayer:FireClient(player, "Error", "Player not found!") return end
	if not deps.BountyManager then deps.Events.NotifyPlayer:FireClient(player, "Error", "Bounty system unavailable!") return end

	data.Money = data.Money - bountyAmount
	deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)
	pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)

	deps.BountyManager.AddCriminalBounty(targetName, bountyAmount, nil, player.Name, isGuild)
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Bounty submitted for " .. targetName .. "!")

	for _, p in ipairs(deps.Players:GetPlayers()) do
		if deps.PlayerData[p.UserId] then
			local criminalData = deps.BountyManager.GetCriminalBountyData(CrimeManager.GetPlayerIP, true, deps.Guilds, deps.PlayerData)
			deps.Events.SendWantedBoards:FireClient(p, "Criminal", criminalData)
		end
	end
end

function CrimeManager.OnClaimBounty(player, targetName, isGuild)
	local data = deps.PlayerData[player.UserId]
	if not data or not deps.BountyManager then return end

	if not targetName or targetName == "" then deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid target name!") return end
	if player.Name:lower() == targetName:lower() then deps.Events.NotifyPlayer:FireClient(player, "Error", "You cannot claim your own bounty!") return end

	local bounty = deps.BountyManager.FindCriminalBounty(targetName, isGuild)
	if not bounty then deps.Events.NotifyPlayer:FireClient(player, "Error", "Bounty not found!") return end

	if not isGuild and bounty.SubmittedBy == "The Void Network" then
		local hasHackedVoidNetwork = false
		for _, net in ipairs(data.Networks) do
			if net.Type == "VoidNetwork" and net.Hacked then hasHackedVoidNetwork = true break end
		end
		if not hasHackedVoidNetwork then deps.Events.NotifyPlayer:FireClient(player, "Error", "You must hack a Void Network to claim this bounty!") return end
	end

	if not isGuild then
		local targetUserId
		for _, p in ipairs(deps.Players:GetPlayers()) do
			if p.Name:lower() == targetName:lower() then targetUserId = p.UserId break end
		end
		if not targetUserId then deps.Events.NotifyPlayer:FireClient(player, "Error", "Target player is offline!") return end

		local targetHacked = false
		for _, net in ipairs(data.Networks) do
			if net.IsOtherPlayerHome and net.Owner == targetUserId and net.Hacked then targetHacked = true break end
		end
		if not targetHacked then deps.Events.NotifyPlayer:FireClient(player, "Error", "You must hack the target's home network first!") return end
	end

	local bountyAmount = deps.BountyManager.RemoveCriminalBounty(targetName, isGuild)
	if not bountyAmount then deps.Events.NotifyPlayer:FireClient(player, "Error", "Failed to claim bounty!") return end

	local mail = {
		Id = deps.HttpService:GenerateGUID(false), From = "The Void Network", Subject = "Bounty Claimed - Reward",
		Message = "You successfully claimed the bounty on " .. targetName .. "!\n\nReward: " .. bountyAmount .. " RC\n\nClick 'CLAIM' below to receive your reward.",
		Timestamp = os.time(), Read = false, Type = "BountyReward", Money = bountyAmount, Claimed = false
	}
	deps.MailManager.SaveMail(player.UserId, mail)

	local userMail = deps.MailManager.LoadMail(player.UserId)
	deps.Events.SendMailData:FireClient(player, deps.MailManager.FilterMailData(userMail, player.UserId))
	deps.ProgressionManager.AdjustReputation(player, -(math.floor(bountyAmount / 100)), "Claimed Criminal Bounty")
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Bounty claimed! Check your mail to claim " .. bountyAmount .. " RC!")

	for _, p in ipairs(deps.Players:GetPlayers()) do
		if deps.PlayerData[p.UserId] then
			local criminalData = deps.BountyManager.GetCriminalBountyData(CrimeManager.GetPlayerIP, true, deps.Guilds, deps.PlayerData)
			deps.Events.SendWantedBoards:FireClient(p, "Criminal", criminalData)
		end
	end
end

function CrimeManager.OnClaimPoliceBounty(player, targetName, isGuild)
	local data = deps.PlayerData[player.UserId]
	if not data or not deps.BountyManager then return end

	if data.Reputation < 0 then deps.Events.NotifyPlayer:FireClient(player, "Error", "You cannot claim police bounties with negative reputation!") return end
	if not targetName or targetName == "" then deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid target name!") return end
	if player.Name:lower() == targetName:lower() then deps.Events.NotifyPlayer:FireClient(player, "Error", "You cannot claim your own bounty!") return end

	if not isGuild then
		local targetUserId
		for _, p in ipairs(deps.Players:GetPlayers()) do
			if p.Name:lower() == targetName:lower() then targetUserId = p.UserId break end
		end
		if not targetUserId then deps.Events.NotifyPlayer:FireClient(player, "Error", "Target player is offline!") return end

		local targetHacked = false
		for _, net in ipairs(data.Networks) do
			if (net.IsOtherPlayerHome and net.Owner == targetUserId and net.Hacked) or (net.Type == "NetSecNetwork" and net.Hacked) then
				targetHacked = true break
			end
		end
		if not targetHacked then deps.Events.NotifyPlayer:FireClient(player, "Error", "You must hack the target's home network or a NetSec network first!") return end

		local bounty = deps.BountyManager.FindPoliceBounty(targetUserId)
		if not bounty then deps.Events.NotifyPlayer:FireClient(player, "Error", "Bounty not found!") return end

		local bountyAmount = deps.BountyManager.RemovePoliceBounty(targetUserId)
		if not bountyAmount then deps.Events.NotifyPlayer:FireClient(player, "Error", "Failed to claim bounty!") return end

		bountyAmount = deps.EconomyManager.ApplyMoneyMultiplier(bountyAmount)
		data.Money = data.Money + bountyAmount
		deps.EconomyManager.CheckAndResetPlayerRC(player.UserId)
		deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)
		pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
		deps.ProgressionManager.AdjustReputation(player, math.floor(bountyAmount / 100), "Claimed Police Bounty")

		deps.Events.NotifyPlayer:FireClient(player, "Success", "Claimed police bounty! Earned " .. bountyAmount .. " RC!")
	else
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Guild police bounties not yet implemented!")
		return
	end

	for _, p in ipairs(deps.Players:GetPlayers()) do
		if deps.PlayerData[p.UserId] then
			local policeData = deps.BountyManager.GetPoliceBountyData(CrimeManager.GetPlayerIP, true, deps.Guilds, deps.PlayerData)
			deps.Events.SendWantedBoards:FireClient(p, "Police", policeData)
		end
	end
end

function CrimeManager.OnRequestWantedBoards(player, boardType, isLocal)
	if not deps.BountyManager then return end
	if boardType == "Police" then
		local policeData = deps.BountyManager.GetPoliceBountyData(CrimeManager.GetPlayerIP, isLocal, deps.Guilds, deps.PlayerData)
		deps.Events.SendWantedBoards:FireClient(player, boardType, policeData)
	elseif boardType == "Criminal" then
		local criminalData = deps.BountyManager.GetCriminalBountyData(CrimeManager.GetPlayerIP, isLocal, deps.Guilds, deps.PlayerData)
		deps.Events.SendWantedBoards:FireClient(player, boardType, criminalData)
	end
end

function CrimeManager.OnStealFromNode(player, networkId, deviceId)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	local network = deps.getNetwork(networkId, player.UserId)
	if not network then return end

	local device
	for _, d in ipairs(network.Devices or {}) do
		if d.Id == deviceId then device = d break end
	end
	if not device then return end

	local securityLevel = math.clamp(device.Security or network.Security or 3, 1, 5)
	local challengeWords = CrimeManager.GenerateStealChallenge(securityLevel)
	local challengeId = deps.HttpService:GenerateGUID(false)

	local baseTimePerWord = (securityLevel <= 2) and 12 or (securityLevel == 3) and 10 or 8
	local timeLimit = math.clamp(math.ceil(#challengeWords * baseTimePerWord), 30, 120)

	PendingStealChallenges[challengeId] = {
		Player = player, UserId = player.UserId, NetworkId = networkId, DeviceId = deviceId,
		ChallengeWords = challengeWords, CurrentWordIndex = 1, TotalAttempts = 0,
		MaxTotalAttempts = 3, TimeLimit = timeLimit, CreatedAt = time(), ExpiresAt = time() + timeLimit
	}

	local SendStealChallenge = deps.Events.Folder:FindFirstChild("SendStealChallenge")
	if SendStealChallenge then
		SendStealChallenge:FireClient(player, challengeId, challengeWords, 1, 3, timeLimit, false)
	end
end

function CrimeManager.OnSubmitStealAnswer(player, challengeId, answer)
	local challenge = PendingStealChallenges[challengeId]
	if not challenge or challenge.UserId ~= player.UserId then deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid challenge!") return end

	local SendStealChallenge = deps.Events.Folder:FindFirstChild("SendStealChallenge")

	if time() > challenge.ExpiresAt then
		PendingStealChallenges[challengeId] = nil
		if SendStealChallenge then SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) end
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Time's up! Steal failed.")
		return
	end

	local currentWord = challenge.ChallengeWords[challenge.CurrentWordIndex]
	if not currentWord then
		PendingStealChallenges[challengeId] = nil
		if SendStealChallenge then SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) end
		deps.GameActions.StealFromNode(deps.buildActionParams(player, {networkId = challenge.NetworkId, deviceId = challenge.DeviceId}))
		return
	end

	if answer == currentWord then
		challenge.CurrentWordIndex = challenge.CurrentWordIndex + 1
		if challenge.CurrentWordIndex > #challenge.ChallengeWords then
			PendingStealChallenges[challengeId] = nil
			if SendStealChallenge then SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) end
			deps.GameActions.StealFromNode(deps.buildActionParams(player, {networkId = challenge.NetworkId, deviceId = challenge.DeviceId}))
		else
			local remainingTime = math.max(0, challenge.ExpiresAt - time())
			local remainingAttempts = challenge.MaxTotalAttempts - challenge.TotalAttempts
			if SendStealChallenge then SendStealChallenge:FireClient(player, challengeId, challenge.ChallengeWords, challenge.CurrentWordIndex, remainingAttempts, remainingTime, false) end
		end
	else
		challenge.TotalAttempts = challenge.TotalAttempts + 1
		if challenge.TotalAttempts >= challenge.MaxTotalAttempts then
			PendingStealChallenges[challengeId] = nil
			if SendStealChallenge then SendStealChallenge:FireClient(player, challengeId, nil, 0, 0, 0, true) end
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Steal failed! Too many incorrect attempts.")
		else
			local usedWords = {}
			for i, word in ipairs(challenge.ChallengeWords) do
				if i ~= challenge.CurrentWordIndex then table.insert(usedWords, word) end
			end
			challenge.ChallengeWords[challenge.CurrentWordIndex] = CrimeManager.GenerateRandomWord(usedWords)
			local remainingTime = math.max(0, challenge.ExpiresAt - time())
			local remainingAttempts = challenge.MaxTotalAttempts - challenge.TotalAttempts
			if SendStealChallenge then SendStealChallenge:FireClient(player, challengeId, challenge.ChallengeWords, challenge.CurrentWordIndex, remainingAttempts, remainingTime, false) end
			if not challenge.IsTerminal then deps.Events.NotifyPlayer:FireClient(player, "Error", "Incorrect! Word changed. " .. remainingAttempts .. " attempt(s) left.") end
		end
	end
end

function CrimeManager.OnRequestNetSecQTE(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return end
	local hasNetSec = false
	for _, net in ipairs(data.Networks) do
		if net.Type == "NetSecNetwork" and net.Hacked then hasNetSec = true break end
	end
	if not hasNetSec then deps.Events.NotifyPlayer:FireClient(player, "Error", "You must hack a NetSec Network first!") return end
	deps.Events.NotifyPlayer:FireClient(player, "Info", "NetSec QTE system ready! (Full implementation needed)")
end

function CrimeManager.OnCompleteNetSecQTE(player, success, reductionPercent)
	local data = deps.PlayerData[player.UserId]
	if not data then return end
	if not success then deps.Events.NotifyPlayer:FireClient(player, "Failed", "QTE failed! No bounty reduction.") return end

	if deps.BountyManager then
		local policeBounty = deps.BountyManager.FindPoliceBounty(player.UserId)
		if policeBounty then
			local reduction = math.floor(policeBounty.Bounty * (reductionPercent or 0.5))
			if reductionPercent >= 1.0 then
				deps.BountyManager.RemovePoliceBounty(player.UserId)
				deps.Events.NotifyPlayer:FireClient(player, "Success", "Bounty completely cleared!")
			else
				deps.BountyManager.PoliceBounties.Players[policeBounty].Bounty = math.max(0, policeBounty.Bounty - reduction)
				deps.Events.NotifyPlayer:FireClient(player, "Success", "Bounty reduced by " .. reduction .. " RC!")
			end
		else
			deps.Events.NotifyPlayer:FireClient(player, "Info", "You have no active bounty.")
		end
	end
end

return CrimeManager



-- EconomyManager | ModuleScript | ServerScriptService.ServerFramework

local EconomyManager = {}

-- Dependencies (Passed from ServerManager)
local deps = {}

local RC_LIMIT = 1000000000000 -- 1 Trillion

-- [ INITIALIZATION ] --
function EconomyManager.Init(dependencies)
	deps = dependencies

	-- Connect Remote Events
	deps.Events.RequestBankData.OnServerEvent:Connect(EconomyManager.OnRequestBankData)
	deps.Events.BankDeposit.OnServerEvent:Connect(EconomyManager.OnBankDeposit)
	deps.Events.BankWithdraw.OnServerEvent:Connect(EconomyManager.OnBankWithdraw)
	deps.Events.BankTransfer.OnServerEvent:Connect(EconomyManager.OnBankTransfer)
end

-- [ UTILITY FUNCTIONS ] --
function EconomyManager.IsValidNumber(value)
	if type(value) ~= "number" then return false end
	if value ~= value then return false end -- NaN check
	if value == math.huge or value == -math.huge then return false end
	return true
end

function EconomyManager.SanitizeNumber(value, default)
	default = default or 0
	if not EconomyManager.IsValidNumber(value) then return default end
	return value
end

function EconomyManager.ApplyMoneyMultiplier(amount)
	if not amount or amount == 0 then return 0 end
	local multiplier = deps.GameData.MoneyMultiplier or 0.001
	return math.floor(amount * multiplier * 1000) / 1000
end

-- [ CORE ECONOMY LOGIC ] --
function EconomyManager.UpdateMoney(userId, amount, player)
	local data = deps.PlayerData[userId]
	if not data then return end

	data.Money = amount
	deps.markPlayerDirty(userId)

	if player then
		deps.Events.UpdateMoney:FireClient(player, amount)
	end
end

function EconomyManager.CheckAndResetPlayerRC(userId)
	local data = deps.PlayerData[userId]
	if not data then return false end

	if not EconomyManager.IsValidNumber(data.Money) then
		local oldMoney = tostring(data.Money)
		data.Money = 0
		if deps.ExploitLogger then
			deps.ExploitLogger.Log(userId, "AutoMod_InvalidRC", "Player Money was invalid (" .. oldMoney .. "), reset to 0", "Critical")
		end
	end

	if not EconomyManager.IsValidNumber(data.BankBalance) then
		local oldBank = tostring(data.BankBalance)
		data.BankBalance = 0
		if deps.ExploitLogger then
			deps.ExploitLogger.Log(userId, "AutoMod_InvalidRC", "Player BankBalance was invalid (" .. oldBank .. "), reset to 0", "Critical")
		end
	end

	local totalRC = (data.Money or 0) + (data.BankBalance or 0)
	if totalRC >= RC_LIMIT then
		local oldTotal = totalRC
		data.Money = 0
		data.BankBalance = 0

		local player = deps.Players:GetPlayerByUserId(userId)
		if player then
			if deps.Events.UpdateMoney then deps.Events.UpdateMoney:FireClient(player, 0) end
			if deps.Events.SendBankData then deps.Events.SendBankData:FireClient(player, 0, 2) end
			if deps.Events.NotifyPlayer then deps.Events.NotifyPlayer:FireClient(player, "Warning", "RC limit exceeded! Your balance has been reset.") end
		end

		if deps.ExploitLogger then
			deps.ExploitLogger.Log(userId, "AutoMod_RCReset", "Player RC reset from " .. oldTotal .. " to 0 (exceeded 1T limit)", "Critical")
		end
		return true
	end
	return false
end

function EconomyManager.CheckAndResetGuildRC(guildId)
	local guild = deps.Guilds[guildId]
	if not guild then return false end

	if (guild.Funds or 0) >= RC_LIMIT then
		local oldFunds = guild.Funds
		guild.Funds = 0

		if deps.ExploitLogger then
			deps.ExploitLogger.Log(guild.OwnerId or 0, "AutoMod_GuildRCReset", "Guild '" .. (guild.Name or guildId) .. "' funds reset from " .. oldFunds .. " to 0 (exceeded 1T limit)", "Critical")
		end

		for _, member in ipairs(guild.Members or {}) do
			if type(member.UserId) == "number" then
				local memberPlayer = deps.Players:GetPlayerByUserId(member.UserId)
				if memberPlayer and deps.Events.NotifyPlayer then
					deps.Events.NotifyPlayer:FireClient(memberPlayer, "Warning", "Guild funds limit exceeded! Guild balance has been reset.")
				end
			end
		end
		return true
	end
	return false
end

function EconomyManager.ApplyBankInterest(userId)
	local data = deps.PlayerData[userId]
	if not data then return end

	local savedData = deps.loadPlayerData(userId)
	if not savedData or not savedData.LastLoginTime then return end

	local lastLogin = savedData.LastLoginTime
	local currentTime = os.time()
	local daysPassed = math.floor((currentTime - lastLogin) / 86400)

	if daysPassed > 0 and data.BankBalance > 0 then
		local interestRate = 0.02
		local totalInterest = 0

		for day = 1, daysPassed do
			local dailyInterest = math.floor(data.BankBalance * interestRate)
			data.BankBalance = data.BankBalance + dailyInterest
			totalInterest = totalInterest + dailyInterest
		end

		if totalInterest > 0 then
			local player = deps.Players:GetPlayerByUserId(userId)
			if player then
				deps.Events.NotifyPlayer:FireClient(player, "Success", "Earned " .. totalInterest .. " RC from " .. daysPassed .. " day(s) of bank interest!")
			end
		end
	end
end

-- [ REMOTE EVENT HANDLERS ] --

function EconomyManager.OnRequestBankData(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return end
	local balance = data.BankBalance or 0
	deps.Events.SendBankData:FireClient(player, balance, 2) -- 2 is interest rate
end

function EconomyManager.OnBankDeposit(player, amount)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if not EconomyManager.IsValidNumber(amount) then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	amount = math.floor(amount * 1000 + 0.5) / 1000
	if amount < 0.001 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Minimum deposit amount is 0.001 RC!")
		return
	end
	if amount > RC_LIMIT then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Amount too large!")
		return
	end

	local playerMoney = math.floor((data.Money or 0) * 1000 + 0.5) / 1000
	if playerMoney < amount - 0.0001 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough RC to deposit!")
		return
	end

	local fee = math.floor(amount * 0.025 * 1000 + 0.5) / 1000
	local depositAmount = math.floor((amount - fee) * 1000 + 0.5) / 1000

	data.Money = data.Money - amount
	data.BankBalance = (data.BankBalance or 0) + depositAmount
	EconomyManager.CheckAndResetPlayerRC(player.UserId)

	deps.Events.UpdateMoney:FireClient(player, data.Money)

	pcall(function()
		local saveData = deps.buildSaveData(player.UserId)
		if saveData then
			saveData.Money = data.Money
			saveData.BankBalance = data.BankBalance
			deps.DataStoreManager.SaveAllPlayerData(player.UserId, saveData, true)
		end
	end)

	deps.Events.SendBankData:FireClient(player, data.BankBalance, 2)

	if _G.ProgramStoreServerUpdateMoneyCache then
		_G.ProgramStoreServerUpdateMoneyCache(player.UserId, data.Money, data.BankBalance)
	end

	deps.markPlayerDirty(player.UserId)

	deps.Events.NotifyPlayer:FireClient(player, "Success", "Deposited " .. depositAmount .. " RC! (Fee: " .. fee .. " RC)")
	if deps.ExploitLogger then deps.ExploitLogger.LogLargeTransaction(player.UserId, amount, "BankDeposit", "Deposited " .. depositAmount .. " RC") end
end

function EconomyManager.OnBankWithdraw(player, amount)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if not EconomyManager.IsValidNumber(amount) then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	amount = math.floor(amount * 1000 + 0.5) / 1000
	if amount < 0.001 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Minimum withdraw amount is 0.001 RC!")
		return
	end
	if amount > RC_LIMIT then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Amount too large!")
		return
	end

	local bankBalance = math.floor((data.BankBalance or 0) * 1000 + 0.5) / 1000
	if bankBalance < amount - 0.0001 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Insufficient bank balance!")
		return
	end

	local fee = math.floor(amount * 0.025 * 1000 + 0.5) / 1000
	local withdrawAmount = math.floor((amount - fee) * 1000 + 0.5) / 1000

	data.BankBalance = bankBalance - amount
	data.Money = data.Money + withdrawAmount
	EconomyManager.CheckAndResetPlayerRC(player.UserId)

	if data.Money > data.Stats.HighestRC then
		data.Stats.HighestRC = data.Money
		deps.Events.UpdateProfileStats:FireClient(player, data.Stats)
	end

	deps.Events.UpdateMoney:FireClient(player, data.Money)

	pcall(function()
		local saveData = deps.buildSaveData(player.UserId)
		if saveData then
			saveData.Money = data.Money
			saveData.BankBalance = data.BankBalance
			deps.DataStoreManager.SaveAllPlayerData(player.UserId, saveData, true)
		end
	end)

	deps.Events.SendBankData:FireClient(player, data.BankBalance, 2)

	if _G.ProgramStoreServerUpdateMoneyCache then
		_G.ProgramStoreServerUpdateMoneyCache(player.UserId, data.Money, data.BankBalance)
	end

	deps.markPlayerDirty(player.UserId)

	deps.Events.NotifyPlayer:FireClient(player, "Success", "Withdrew " .. withdrawAmount .. " RC! (Fee: " .. fee .. " RC)")
	if deps.ExploitLogger then deps.ExploitLogger.LogLargeTransaction(player.UserId, amount, "BankWithdraw", "Withdrew " .. withdrawAmount .. " RC") end
end

function EconomyManager.OnBankTransfer(player, targetUsername, amount)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if not targetUsername or targetUsername == "" then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid username!")
		return
	end

	if not EconomyManager.IsValidNumber(amount) then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end

	amount = math.floor(amount)
	if amount <= 0 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid amount!")
		return
	end
	if amount > RC_LIMIT then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Amount too large!")
		return
	end

	local fee = math.floor(amount * 0.025)
	local transferAmount = amount - fee

	local success, targetUserId = pcall(function()
		return deps.Players:GetUserIdFromNameAsync(targetUsername)
	end)

	if not success or not targetUserId then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Player '" .. targetUsername .. "' not found!")
		return
	end

	if targetUserId == player.UserId then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot transfer to yourself!")
		return
	end

	local currentMoney = data.Money or 0
	local currentBankBalance = data.BankBalance or 0
	local totalAvailable = currentMoney + currentBankBalance

	if totalAvailable < amount then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Insufficient funds! You have " .. currentMoney .. " RC on-hand and " .. currentBankBalance .. " RC in bank.")
		return
	end

	local remainingAmount = amount
	local fromMoney = math.min(remainingAmount, currentMoney)
	remainingAmount = remainingAmount - fromMoney
	local fromBank = remainingAmount

	if fromMoney > 0 then data.Money = currentMoney - fromMoney end
	if fromBank > 0 then data.BankBalance = currentBankBalance - fromBank end

	deps.markPlayerDirty(player.UserId)
	EconomyManager.CheckAndResetPlayerRC(player.UserId)
	deps.saveAllPlayerData(player.UserId, true)

	deps.Events.UpdateMoney:FireClient(player, data.Money or 0)
	deps.Events.SendBankData:FireClient(player, data.BankBalance or 0, 2)

	local targetPlayer = deps.Players:GetPlayerByUserId(targetUserId)
	if targetPlayer and deps.PlayerData[targetUserId] then
		deps.PlayerData[targetUserId].BankBalance = (deps.PlayerData[targetUserId].BankBalance or 0) + transferAmount
		deps.markPlayerDirty(targetUserId)
		EconomyManager.CheckAndResetPlayerRC(targetUserId)
		deps.Events.SendBankData:FireClient(targetPlayer, deps.PlayerData[targetUserId].BankBalance, 2)
		deps.Events.NotifyPlayer:FireClient(targetPlayer, "Success", "Received " .. transferAmount .. " RC from " .. player.Name .. "!")
	else
		local targetData = deps.DataStoreManager.LoadAllPlayerData(targetUserId)
		if targetData and type(targetData.BankBalance) == "number" then
			targetData.BankBalance = (targetData.BankBalance or 0) + transferAmount
			deps.DataStoreManager.SaveAllPlayerData(targetUserId, targetData, true)
		else
			data.Money = currentMoney
			data.BankBalance = currentBankBalance
			deps.markPlayerDirty(player.UserId)
			EconomyManager.CheckAndResetPlayerRC(player.UserId)
			deps.Events.UpdateMoney:FireClient(player, data.Money)
			pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
			deps.Events.SendBankData:FireClient(player, data.BankBalance, 2)
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Failed to transfer: target player data not found!")
			return
		end
	end

	deps.Events.NotifyPlayer:FireClient(player, "Success", "Transferred " .. transferAmount .. " RC to " .. targetUsername .. "! (Fee: " .. fee .. " RC)")
	if deps.ExploitLogger then deps.ExploitLogger.LogLargeTransaction(player.UserId, amount, "BankTransfer", "Transferred to " .. targetUsername) end
end

return EconomyManager


-- GuildServerManager | ModuleScript | ServerScriptService.ServerFramework

local GuildServerManager = {}

-- Dependencies
local deps = {}
local GUILD_REQUEST_INTERVAL = 3
local guildListLoaded = false
local guildListLoading = false
local lastGuildDatastoreRequest = 0
local lastGuildDataRequest = {}

function GuildServerManager.Init(dependencies)
	deps = dependencies

	-- Connect Remote Events
	deps.Events.RequestGuildData.OnServerEvent:Connect(GuildServerManager.OnRequestGuildData)
	deps.Events.CreateGuild.OnServerEvent:Connect(GuildServerManager.OnCreateGuild)
	deps.Events.JoinGuild.OnServerEvent:Connect(GuildServerManager.OnJoinGuild)
	deps.Events.LeaveGuild.OnServerEvent:Connect(GuildServerManager.OnLeaveGuild)
	deps.Events.InviteToGuild.OnServerEvent:Connect(GuildServerManager.OnInviteToGuild)
	deps.Events.KickFromGuild.OnServerEvent:Connect(GuildServerManager.OnKickFromGuild)
	deps.Events.PromoteInGuild.OnServerEvent:Connect(GuildServerManager.OnPromoteInGuild)
	deps.Events.DemoteInGuild.OnServerEvent:Connect(GuildServerManager.OnDemoteInGuild)
	deps.Events.ToggleGuildInviteOnly.OnServerEvent:Connect(GuildServerManager.OnToggleGuildInviteOnly)
	deps.Events.RespondToGuildInvite.OnServerEvent:Connect(GuildServerManager.OnRespondToGuildInvite)

	-- Connect Bindables
	if deps.Bindables.AdminCreateGuildBindable then
		deps.Bindables.AdminCreateGuildBindable.Event:Connect(GuildServerManager.OnAdminCreateGuild)
	end
	if deps.Bindables.GetGuildsBindable then
		deps.Bindables.GetGuildsBindable.OnInvoke = GuildServerManager.GetAllGuildsForBindable
	end

	local AdminEditGuildBindable = deps.ReplicatedStorage:WaitForChild("AdminEditGuildBindable", 10)
	if AdminEditGuildBindable then
		AdminEditGuildBindable.Event:Connect(GuildServerManager.OnAdminEditGuild)
	end

	-- Start initial guild loading
	task.spawn(GuildServerManager.LoadAllGuildsFromList)
end

-- [ HELPER FUNCTIONS ] --

function GuildServerManager.CalculateGuildReputation(guild)
	local rep = 0
	if deps.BountyManager and guild and guild.Members then
		for _, member in ipairs(guild.Members) do
			if type(member.UserId) == "number" then
				local policeBounty = deps.BountyManager.FindPoliceBounty(member.UserId)
				if policeBounty and type(policeBounty.Bounty) == "number" then
					rep = rep + policeBounty.Bounty
				end
				local pName = member.Name
				local onlinePlayer = deps.Players:GetPlayerByUserId(member.UserId)
				if onlinePlayer then pName = onlinePlayer.Name end
				if pName then
					local criminalBounty = deps.BountyManager.FindCriminalBounty(pName, false)
					if criminalBounty and type(criminalBounty.Bounty) == "number" then
						rep = rep + criminalBounty.Bounty
					end
				end
			end
		end
	end
	if rep ~= rep then rep = 0 end
	return math.floor(rep)
end

function GuildServerManager.SaveGuildData(guildId, force)
	local guild = deps.Guilds[guildId]
	if not guild then return end

	local calculatedReputation = 0
	local repSuccess, rep = pcall(function() return GuildServerManager.CalculateGuildReputation(guild) end)
	if repSuccess and rep then
		calculatedReputation = rep
	else
		calculatedReputation = guild.Reputation or 0
	end

	deps.DataStoreManager.SaveGuildData(guildId, {
		Id = guild.Id,
		Name = guild.Name,
		OwnerId = guild.OwnerId,
		Funds = guild.Funds or 0,
		Reputation = calculatedReputation,
		Members = guild.Members,
		InviteOnly = guild.InviteOnly,
		NetworkIP = guild.NetworkIP,
		NetworkId = guild.NetworkId,
		FundsDeviceId = guild.FundsDeviceId
	}, force)

	if not deps.cachedGuildList[guildId] then
		deps.cachedGuildList[guildId] = true
		pcall(function()
			local GuildDataStore = deps.DataStoreManager.Stores.GuildData
			local guildList = GuildDataStore:GetAsync("GuildList") or {}
			if not table.find(guildList, guildId) then
				table.insert(guildList, guildId)
				GuildDataStore:SetAsync("GuildList", guildList)
			end
		end)
	end
end

function GuildServerManager.ThrottledGuildGet(guildId)
	local now = time()
	local timeSinceLast = now - lastGuildDatastoreRequest
	if timeSinceLast < GUILD_REQUEST_INTERVAL then
		task.wait(GUILD_REQUEST_INTERVAL - timeSinceLast)
	end
	lastGuildDatastoreRequest = time()

	local GuildDataStore = deps.DataStoreManager.Stores.GuildData
	local success, guildData = pcall(function() return GuildDataStore:GetAsync("Guild_" .. guildId) end)

	if not success then
		task.wait(GUILD_REQUEST_INTERVAL * 2)
		lastGuildDatastoreRequest = time()
		success, guildData = pcall(function() return GuildDataStore:GetAsync("Guild_" .. guildId) end)
	end

	if success and guildData then
		local decodeSuccess, decoded = pcall(function() return deps.HttpService:JSONDecode(guildData) end)
		if decodeSuccess and decoded then return decoded end
	end
	return nil
end

function GuildServerManager.LoadAllGuildsFromList()
	if guildListLoaded or guildListLoading then return end
	guildListLoading = true

	task.wait(5)
	local GuildDataStore = deps.DataStoreManager.Stores.GuildData
	local guildList = nil
	lastGuildDatastoreRequest = time()
	pcall(function() guildList = GuildDataStore:GetAsync("GuildList") or {} end)

	if guildList then
		for _, guildId in ipairs(guildList) do
			deps.cachedGuildList[guildId] = true
			if not deps.Guilds[guildId] then
				local guildData = GuildServerManager.ThrottledGuildGet(guildId)
				if guildData then
					deps.Guilds[guildId] = guildData
					if guildData.NetworkId then
						GuildServerManager.CreateGuildNetwork(guildData)
					end
				end
			end
		end
	end
	guildListLoaded = true
	guildListLoading = false
end

function GuildServerManager.GetAllGuilds()
	local allGuilds = {}
	for guildId, guild in pairs(deps.Guilds) do
		table.insert(allGuilds, {
			Id = guild.Id,
			Name = guild.Name,
			Reputation = GuildServerManager.CalculateGuildReputation(guild),
			Funds = guild.Funds,
			Members = guild.Members,
			InviteOnly = guild.InviteOnly,
			NetworkIP = guild.NetworkIP
		})
	end
	table.sort(allGuilds, function(a, b)
		if a.Reputation ~= b.Reputation then return a.Reputation > b.Reputation end
		return #a.Members > #b.Members
	end)
	return allGuilds
end

function GuildServerManager.GetServerGuilds()
	local serverGuilds = {}
	for guildId, guild in pairs(deps.Guilds) do
		for _, member in ipairs(guild.Members) do
			if type(member.UserId) == "number" then
				local player = deps.Players:GetPlayerByUserId(member.UserId)
				if player then
					table.insert(serverGuilds, {
						Id = guild.Id,
						Name = guild.Name,
						Reputation = GuildServerManager.CalculateGuildReputation(guild),
						Funds = guild.Funds,
						Members = guild.Members,
						InviteOnly = guild.InviteOnly,
						NetworkIP = guild.NetworkIP
					})
					break
				end
			end
		end
	end
	table.sort(serverGuilds, function(a, b)
		if a.Reputation ~= b.Reputation then return a.Reputation > b.Reputation end
		return #a.Members > #b.Members
	end)
	return serverGuilds
end

function GuildServerManager.CreateGuildNetwork(guild)
	local guildNetworkId = guild.NetworkId or deps.HttpService:GenerateGUID(false)
	local guildIP = guild.NetworkIP or deps.NetworkGenerator.GenerateIP()

	local guildNetwork = {
		Id = guildNetworkId,
		IP = guildIP,
		Name = guild.Name .. " Network",
		Type = "Guild",
		Security = 3,
		AdminTier = 0,
		HasAdmin = false,
		Scanned = false,
		Hacked = false,
		Owner = "Guild_" .. guild.Id,
		Locked = false,
		LockExpiry = 0,
		TracesReceived = 0,
		Devices = {},
		ConnectedNetworks = {},
		Position = Vector2.new(math.random(-500, 500), math.random(-500, 500)),
		Visible = true,
		IsGuildNetwork = true,
		GuildId = guild.Id,
		AccessCode = deps.AccessCodeSystem.GenerateAccessCode()
	}

	local fundsDeviceId = guild.FundsDeviceId or deps.HttpService:GenerateGUID(false)
	local usedLANIPs = {}

	table.insert(guildNetwork.Devices, {
		Id = fundsDeviceId,
		Type = "Server",
		Name = "Guild Funds Server",
		Security = 3,
		Icon = "💾",
		Scanned = false,
		Hacked = false,
		IsPlayerComputer = false,
		IsGuildFundsDevice = true,
		LANIP = deps.NetworkGenerator.GenerateLANIP(guildIP, usedLANIPs),
		GuildId = guild.Id,
		AccessCode = deps.AccessCodeSystem.GenerateAccessCode()
	})

	guild.NetworkId = guildNetworkId
	guild.NetworkIP = guildIP
	guild.FundsDeviceId = fundsDeviceId

	deps.GuildNetworks[guild.Id] = guildNetwork

	for _, member in ipairs(guild.Members) do
		if type(member.UserId) == "number" then
			local memberPlayer = deps.Players:GetPlayerByUserId(member.UserId)
			if memberPlayer and deps.PlayerData[member.UserId] then
				local guildNetworkCopy = {
					Id = guildNetwork.Id, IP = guildNetwork.IP, Name = guildNetwork.Name,
					Type = guildNetwork.Type, Security = guildNetwork.Security,
					AdminTier = guildNetwork.AdminTier, HasAdmin = guildNetwork.HasAdmin,
					Scanned = true, Hacked = true, Owner = guildNetwork.Owner,
					Locked = false, LockExpiry = 0, TracesReceived = 0,
					Devices = {}, ConnectedNetworks = {}, Position = guildNetwork.Position,
					Visible = true, IsGuildNetwork = true, GuildId = guild.Id,
					AccessCode = guildNetwork.AccessCode
				}

				for _, device in ipairs(guildNetwork.Devices) do
					table.insert(guildNetworkCopy.Devices, {
						Id = device.Id, Type = device.Type, Name = device.Name,
						Security = device.Security, Icon = device.Icon,
						Scanned = true, Hacked = false,
						IsPlayerComputer = device.IsPlayerComputer,
						IsGuildFundsDevice = device.IsGuildFundsDevice,
						LANIP = device.LANIP, GuildId = device.GuildId,
						AccessCode = device.AccessCode
					})
				end

				local hasNetwork = false
				for _, net in ipairs(deps.PlayerData[member.UserId].Networks) do
					if (type(net) == "table" and net.Id == guildNetworkId) then
						hasNetwork = true
						break
					end
				end

				if not hasNetwork then
					table.insert(deps.PlayerData[member.UserId].Networks, guildNetworkCopy)
				end

				deps.PlayerData[member.UserId].Guild = guild.Id
				local clientNetworks = deps.prepareNetworksForClient(deps.PlayerData[member.UserId].Networks, member.UserId)
				deps.Events.SendNetworkData:FireClient(memberPlayer, clientNetworks, deps.PlayerData[member.UserId].CurrentNetwork, deps.PlayerData[member.UserId].LoggedInNetwork, deps.PlayerData[member.UserId].LoggedInDevice)
			end
		end
	end

	return guildNetwork
end

function GuildServerManager.GetGuildRank(guild, userId)
	for _, member in ipairs(guild.Members) do
		if member.UserId == userId then return member.Rank end
	end
	return nil
end

-- [ EVENT HANDLERS ] --

function GuildServerManager.OnRequestGuildData(player)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end

	local now = time()
	if lastGuildDataRequest[userId] and now - lastGuildDataRequest[userId] < 2 then return end
	lastGuildDataRequest[userId] = now

	local playerGuild = nil
	if data.Guild then
		local guild = deps.Guilds[data.Guild]
		if not guild then
			local freshGuildData = deps.DataStoreManager.LoadGuildData(data.Guild)
			if freshGuildData then
				deps.Guilds[data.Guild] = freshGuildData
				deps.cachedGuildList[data.Guild] = true
				if freshGuildData.NetworkId then
					GuildServerManager.CreateGuildNetwork(freshGuildData)
				end
				guild = freshGuildData
			else
				data.Guild = nil
				deps.queuePlayerSave(userId)
			end
		else
			local savedData = deps.DataStoreManager.LoadGuildData(data.Guild)
			if savedData and savedData.Funds ~= nil then
				deps.Guilds[data.Guild].Funds = savedData.Funds
				local repSuccess, calculatedRep = pcall(function() return GuildServerManager.CalculateGuildReputation(deps.Guilds[data.Guild]) end)
				if repSuccess and calculatedRep then deps.Guilds[data.Guild].Reputation = calculatedRep end
			end
		end

		if guild then
			playerGuild = {
				Id = guild.Id, Name = guild.Name, Reputation = GuildServerManager.CalculateGuildReputation(guild),
				Funds = guild.Funds or 0, Members = guild.Members,
				InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP
			}
		end
	end

	deps.Events.SendGuildData:FireClient(player, playerGuild, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
end

function GuildServerManager.OnCreateGuild(player, guildName)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end

	if not guildName or guildName == "" then deps.Events.NotifyPlayer:FireClient(player, "Error", "Guild name cannot be empty!") return end
	if #guildName > 30 then deps.Events.NotifyPlayer:FireClient(player, "Error", "Guild name cannot exceed 30 characters!") return end

	guildName = deps.filterText(guildName, userId)

	if data.Guild then
		if not deps.Guilds[data.Guild] then
			data.Guild = nil
			deps.queuePlayerSave(userId)
		else
			deps.Events.NotifyPlayer:FireClient(player, "Error", "You are already in a guild!")
			return
		end
	end

	if data.Money < deps.GuildManager.Config.CreateCost then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. deps.GuildManager.Config.CreateCost .. " RC.")
		return
	end

	local guildId = deps.HttpService:GenerateGUID(false)
	local guild = {
		Id = guildId, Name = guildName, OwnerId = userId,
		Funds = deps.GuildManager.Config.StartingFunds,
		Reputation = deps.GuildManager.Config.StartingReputation,
		Members = {{UserId = userId, Name = player.Name, Rank = deps.GuildManager.Ranks.Owner, JoinedAt = os.time(), Contribution = 0, LastActive = os.time()}},
		InviteOnly = false, NetworkIP = nil, NetworkId = nil, FundsDeviceId = nil
	}

	deps.Guilds[guildId] = guild
	data.Guild = guildId
	data.Money = data.Money - deps.GuildManager.Config.CreateCost
	deps.Events.UpdateMoney:FireClient(player, data.Money)
	pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
	deps.queuePlayerSave(userId)

	GuildServerManager.CreateGuildNetwork(guild)
	GuildServerManager.SaveGuildData(guildId)

	local welcomeMail = {
		Id = deps.HttpService:GenerateGUID(false), From = guild.Name .. " HQ", Subject = "Welcome to Your Guild!",
		Message = "Congratulations on creating " .. guild.Name .. "!\n\nUse the Guild Network to securely share files and funds.",
		Timestamp = os.time(), Read = false, Type = "GuildWelcome", Responded = false
	}
	deps.MailManager.SaveMail(userId, welcomeMail)

	deps.Events.NotifyPlayer:FireClient(player, "Success", "Guild '" .. guildName .. "' created!")
	deps.Events.SendGuildData:FireClient(player, {
		Id = guild.Id, Name = guild.Name, Reputation = guild.Reputation,
		Funds = guild.Funds, Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP
	}, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())

	local mail = deps.MailManager.LoadMail(userId)
	deps.Events.SendMailData:FireClient(player, deps.MailManager.FilterMailData(mail, userId))
end

function GuildServerManager.OnJoinGuild(player, guildId)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end
	if data.Guild then deps.Events.NotifyPlayer:FireClient(player, "Error", "You are already in a guild!") return end

	local guild = deps.Guilds[guildId]
	if not guild then deps.Events.NotifyPlayer:FireClient(player, "Error", "Guild not found!") return end
	if guild.InviteOnly then deps.Events.NotifyPlayer:FireClient(player, "Error", "This guild is invite only!") return end

	table.insert(guild.Members, {UserId = userId, Name = player.Name, Rank = deps.GuildManager.Ranks.Member})
	data.Guild = guildId
	deps.queuePlayerSave(userId)

	if deps.GuildNetworks[guildId] then
		local guildNetwork = deps.GuildNetworks[guildId]
		local guildNetworkCopy = {
			Id = guildNetwork.Id, IP = guildNetwork.IP, Name = guildNetwork.Name, Type = guildNetwork.Type,
			Security = guildNetwork.Security, AdminTier = guildNetwork.AdminTier, HasAdmin = guildNetwork.HasAdmin,
			Scanned = true, Hacked = true, Owner = guildNetwork.Owner, Locked = false, LockExpiry = 0, TracesReceived = 0,
			Devices = {}, ConnectedNetworks = {}, Position = guildNetwork.Position, Visible = true,
			IsGuildNetwork = true, GuildId = guildId, AccessCode = guildNetwork.AccessCode
		}

		for _, device in ipairs(guildNetwork.Devices) do
			table.insert(guildNetworkCopy.Devices, {
				Id = device.Id, Type = device.Type, Name = device.Name, Security = device.Security, Icon = device.Icon,
				Scanned = true, Hacked = false, IsPlayerComputer = device.IsPlayerComputer, IsGuildFundsDevice = device.IsGuildFundsDevice,
				LANIP = device.LANIP, GuildId = device.GuildId, AccessCode = device.AccessCode
			})
		end

		local hasNetwork = false
		for _, net in ipairs(data.Networks) do
			if (type(net) == "table" and net.Id == guildNetwork.Id) then hasNetwork = true break end
		end
		if not hasNetwork then table.insert(data.Networks, guildNetworkCopy) end

		local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
		deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
	end

	GuildServerManager.SaveGuildData(guildId)
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Joined guild '" .. guild.Name .. "'!")
	deps.Events.SendGuildData:FireClient(player, {
		Id = guild.Id, Name = guild.Name, Reputation = guild.Reputation, Funds = guild.Funds,
		Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP
	}, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
end

function GuildServerManager.OnLeaveGuild(player)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data or not data.Guild then return end

	local guild = deps.Guilds[data.Guild]
	if not guild then return end

	if guild.OwnerId == userId then
		-- Disband guild
		local guildId = guild.Id
		if deps.GuildNetworks[guild.Id] then deps.GuildNetworks[guild.Id] = nil end

		for _, member in ipairs(guild.Members) do
			if type(member.UserId) == "number" then
				local memberPlayer = deps.Players:GetPlayerByUserId(member.UserId)
				if memberPlayer and deps.PlayerData[member.UserId] then
					deps.PlayerData[member.UserId].Guild = nil
					for i = #deps.PlayerData[member.UserId].Networks, 1, -1 do
						local net = deps.PlayerData[member.UserId].Networks[i]
						if type(net) == "table" and net.IsGuildNetwork and net.GuildId == guildId then table.remove(deps.PlayerData[member.UserId].Networks, i) end
					end
					local clientNetworks = deps.prepareNetworksForClient(deps.PlayerData[member.UserId].Networks, member.UserId)
					deps.Events.SendNetworkData:FireClient(memberPlayer, clientNetworks, deps.PlayerData[member.UserId].CurrentNetwork, deps.PlayerData[member.UserId].LoggedInNetwork, deps.PlayerData[member.UserId].LoggedInDevice)
					deps.Events.NotifyPlayer:FireClient(memberPlayer, "Info", "Your guild has been disbanded")
					deps.queuePlayerSave(member.UserId)
				else
					local offlineData = deps.loadPlayerData(member.UserId)
					if offlineData then
						offlineData.Guild = nil
						pcall(function() deps.DataStoreManager.Stores.PlayerData:SetAsync("Data_" .. member.UserId, deps.HttpService:JSONEncode(offlineData)) end)
					end
				end
			end
		end

		deps.Guilds[guildId] = nil
		deps.cachedGuildList[guildId] = nil
		pcall(function()
			deps.DataStoreManager.Stores.GuildData:RemoveAsync("Guild_" .. guildId)
			local guildList = deps.DataStoreManager.Stores.GuildData:GetAsync("GuildList") or {}
			local newList = {}
			for _, id in ipairs(guildList) do if id ~= guildId then table.insert(newList, id) end end
			deps.DataStoreManager.Stores.GuildData:SetAsync("GuildList", newList)
		end)
		deps.Events.NotifyPlayer:FireClient(player, "Success", "Guild disbanded")

		local allGuilds = GuildServerManager.GetAllGuilds()
		local serverGuilds = GuildServerManager.GetServerGuilds()
		for _, p in ipairs(deps.Players:GetPlayers()) do
			local pData = deps.PlayerData[p.UserId]
			if pData then
				local pg = nil
				if pData.Guild and deps.Guilds[pData.Guild] then
					pg = {Id = deps.Guilds[pData.Guild].Id, Name = deps.Guilds[pData.Guild].Name, Reputation = deps.Guilds[pData.Guild].Reputation, Funds = deps.Guilds[pData.Guild].Funds, Members = deps.Guilds[pData.Guild].Members, InviteOnly = deps.Guilds[pData.Guild].InviteOnly, NetworkIP = deps.Guilds[pData.Guild].NetworkIP}
				end
				deps.Events.SendGuildData:FireClient(p, pg, allGuilds, serverGuilds)
			end
		end
		return
	else
		-- Standard leave
		for i = #guild.Members, 1, -1 do
			if guild.Members[i].UserId == userId then table.remove(guild.Members, i) break end
		end

		if deps.GuildNetworks[guild.Id] then
			for i = #data.Networks, 1, -1 do
				local net = data.Networks[i]
				if type(net) == "table" and net.IsGuildNetwork and net.GuildId == guild.Id then table.remove(data.Networks, i) end
			end
			local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
			deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		end

		data.Guild = nil
		deps.queuePlayerSave(userId)
		GuildServerManager.SaveGuildData(guild.Id)
		deps.Events.NotifyPlayer:FireClient(player, "Success", "Left guild '" .. guild.Name .. "'")
	end

	deps.Events.SendGuildData:FireClient(player, nil, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
end

function GuildServerManager.OnInviteToGuild(player, targetPlayerName)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data or not data.Guild then return end

	local guild = deps.Guilds[data.Guild]
	if not guild then return end

	local playerRank = GuildServerManager.GetGuildRank(guild, userId)
	if not playerRank or playerRank < deps.GuildManager.Ranks.Admin then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "You don't have permission to invite players!")
		return
	end

	local success, targetUserId = pcall(function() return deps.Players:GetUserIdFromNameAsync(targetPlayerName) end)
	if not success or not targetUserId then deps.Events.NotifyPlayer:FireClient(player, "Error", "Player '" .. targetPlayerName .. "' not found!") return end

	local targetPlayer = deps.Players:GetPlayerByUserId(targetUserId)
	local targetHasGuild = false

	if targetPlayer and deps.PlayerData[targetUserId] then
		targetHasGuild = deps.PlayerData[targetUserId].Guild ~= nil
	else
		local savedData = deps.loadPlayerData(targetUserId)
		if savedData and savedData.Guild then targetHasGuild = true end
	end

	if targetHasGuild then deps.Events.NotifyPlayer:FireClient(player, "Error", "Player is already in a guild!") return end

	local mail = {
		Id = deps.HttpService:GenerateGUID(false), From = "Guild: " .. guild.Name, Subject = "Guild Invitation",
		Message = "You have been invited to join " .. guild.Name .. "! Accept or decline below.", Timestamp = os.time(),
		Read = false, Type = "GuildInvite", GuildId = guild.Id, Responded = false
	}
	deps.MailManager.SaveMail(targetUserId, mail)

	if targetPlayer then
		local targetMail = deps.MailManager.LoadMail(targetUserId)
		deps.Events.SendMailData:FireClient(targetPlayer, deps.MailManager.FilterMailData(targetMail, targetUserId))
	end
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Invitation sent to " .. targetPlayerName)
end

function GuildServerManager.OnKickFromGuild(player, targetUserId)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data or not data.Guild then return end

	local guild = deps.Guilds[data.Guild]
	if not guild then return end

	local playerRank = GuildServerManager.GetGuildRank(guild, userId)
	if not playerRank or playerRank < deps.GuildManager.Ranks.Admin then deps.Events.NotifyPlayer:FireClient(player, "Error", "No permission!") return end

	local targetRank = GuildServerManager.GetGuildRank(guild, targetUserId)
	if not targetRank then deps.Events.NotifyPlayer:FireClient(player, "Error", "Player is not in the guild!") return end
	if targetRank >= playerRank then deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot kick higher or equal ranks!") return end

	local targetName = ""
	for i = #guild.Members, 1, -1 do
		if guild.Members[i].UserId == targetUserId then
			targetName = guild.Members[i].Name
			table.remove(guild.Members, i)
			break
		end
	end

	local targetPlayer = deps.Players:GetPlayerByUserId(targetUserId)
	if targetPlayer and deps.PlayerData[targetUserId] then
		deps.PlayerData[targetUserId].Guild = nil
		if deps.GuildNetworks[guild.Id] then
			for i = #deps.PlayerData[targetUserId].Networks, 1, -1 do
				local net = deps.PlayerData[targetUserId].Networks[i]
				if type(net) == "table" and net.IsGuildNetwork and net.GuildId == guild.Id then table.remove(deps.PlayerData[targetUserId].Networks, i) end
			end
			local clientNetworks = deps.prepareNetworksForClient(deps.PlayerData[targetUserId].Networks, targetUserId)
			deps.Events.SendNetworkData:FireClient(targetPlayer, clientNetworks, deps.PlayerData[targetUserId].CurrentNetwork, deps.PlayerData[targetUserId].LoggedInNetwork, deps.PlayerData[targetUserId].LoggedInDevice)
		end
		deps.Events.NotifyPlayer:FireClient(targetPlayer, "Info", "You have been kicked from " .. guild.Name)
		deps.Events.SendGuildData:FireClient(targetPlayer, nil, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
		deps.queuePlayerSave(targetUserId)
	else
		local offlineData = deps.loadPlayerData(targetUserId)
		if offlineData then
			offlineData.Guild = nil
			pcall(function() deps.DataStoreManager.Stores.PlayerData:SetAsync("Data_" .. targetUserId, deps.HttpService:JSONEncode(offlineData)) end)
		end
	end

	GuildServerManager.SaveGuildData(guild.Id)
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Kicked " .. targetName .. " from guild")

	local allG = GuildServerManager.GetAllGuilds()
	local sG = GuildServerManager.GetServerGuilds()
	local pG = {Id = guild.Id, Name = guild.Name, Reputation = guild.Reputation, Funds = guild.Funds, Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP}
	for _, member in ipairs(guild.Members) do
		local mPlayer = deps.Players:GetPlayerByUserId(member.UserId)
		if mPlayer then deps.Events.SendGuildData:FireClient(mPlayer, pG, allG, sG) end
	end
end

function GuildServerManager.OnPromoteInGuild(player, targetUserId)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data or not data.Guild then return end

	local guild = deps.Guilds[data.Guild]
	if not guild or guild.OwnerId ~= userId then deps.Events.NotifyPlayer:FireClient(player, "Error", "Only owner can promote!") return end

	local targetName = ""
	for _, member in ipairs(guild.Members) do
		if member.UserId == targetUserId then
			if member.Rank < deps.GuildManager.Ranks.Admin then
				member.Rank = deps.GuildManager.Ranks.Admin
				targetName = member.Name
				break
			else
				deps.Events.NotifyPlayer:FireClient(player, "Error", "Already an admin!") return
			end
		end
	end

	GuildServerManager.SaveGuildData(guild.Id)
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Promoted " .. targetName .. " to admin")

	local allG = GuildServerManager.GetAllGuilds()
	local sG = GuildServerManager.GetServerGuilds()
	local pG = {Id = guild.Id, Name = guild.Name, Reputation = guild.Reputation, Funds = guild.Funds, Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP}
	for _, member in ipairs(guild.Members) do
		local mPlayer = deps.Players:GetPlayerByUserId(member.UserId)
		if mPlayer then deps.Events.SendGuildData:FireClient(mPlayer, pG, allG, sG) end
	end
end

function GuildServerManager.OnDemoteInGuild(player, targetUserId)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data or not data.Guild then return end

	local guild = deps.Guilds[data.Guild]
	if not guild or guild.OwnerId ~= userId then deps.Events.NotifyPlayer:FireClient(player, "Error", "Only owner can demote!") return end

	local targetName = ""
	for _, member in ipairs(guild.Members) do
		if member.UserId == targetUserId then
			if member.Rank == deps.GuildManager.Ranks.Admin then
				member.Rank = deps.GuildManager.Ranks.Member
				targetName = member.Name
				break
			else
				deps.Events.NotifyPlayer:FireClient(player, "Error", "Member is not an admin!") return
			end
		end
	end

	GuildServerManager.SaveGuildData(guild.Id)
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Demoted " .. targetName)

	local allG = GuildServerManager.GetAllGuilds()
	local sG = GuildServerManager.GetServerGuilds()
	local pG = {Id = guild.Id, Name = guild.Name, Reputation = guild.Reputation, Funds = guild.Funds, Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP}
	for _, member in ipairs(guild.Members) do
		local mPlayer = deps.Players:GetPlayerByUserId(member.UserId)
		if mPlayer then deps.Events.SendGuildData:FireClient(mPlayer, pG, allG, sG) end
	end
end

function GuildServerManager.OnToggleGuildInviteOnly(player)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data or not data.Guild then return end

	local guild = deps.Guilds[data.Guild]
	if not guild or guild.OwnerId ~= userId then return end

	guild.InviteOnly = not guild.InviteOnly
	GuildServerManager.SaveGuildData(guild.Id)

	local allG = GuildServerManager.GetAllGuilds()
	local sG = GuildServerManager.GetServerGuilds()
	local pG = {Id = guild.Id, Name = guild.Name, Reputation = GuildServerManager.CalculateGuildReputation(guild), Funds = guild.Funds, Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP}

	deps.Events.SendGuildData:FireClient(player, pG, allG, sG)
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Invite only " .. (guild.InviteOnly and "enabled" or "disabled"))

	for _, member in ipairs(guild.Members) do
		if type(member.UserId) == "number" and member.UserId ~= userId then
			local mPlayer = deps.Players:GetPlayerByUserId(member.UserId)
			if mPlayer then deps.Events.SendGuildData:FireClient(mPlayer, pG, allG, sG) end
		end
	end
end

function GuildServerManager.OnRespondToGuildInvite(player, guildId, accept)
	local userId = player.UserId
	local data = deps.PlayerData[userId]
	if not data then return end
	if data.Guild then deps.Events.NotifyPlayer:FireClient(player, "Error", "Already in a guild!") return end

	local guild = deps.Guilds[guildId]
	if not guild then deps.Events.NotifyPlayer:FireClient(player, "Error", "Guild not found!") return end

	if accept then
		table.insert(guild.Members, {UserId = userId, Name = player.Name, Rank = deps.GuildManager.Ranks.Member})
		data.Guild = guildId
		deps.queuePlayerSave(userId)

		if deps.GuildNetworks[guildId] then
			local guildNetwork = deps.GuildNetworks[guildId]
			local playerNetwork = nil
			for _, network in ipairs(deps.GlobalNetworks) do
				if network.IsPlayerHome and network.Owner == userId then playerNetwork = network break end
			end

			if playerNetwork then
				if not table.find(playerNetwork.ConnectedNetworks, guildNetwork.Id) then table.insert(playerNetwork.ConnectedNetworks, guildNetwork.Id) end
				if not table.find(guildNetwork.ConnectedNetworks, playerNetwork.Id) then table.insert(guildNetwork.ConnectedNetworks, playerNetwork.Id) end
			end

			if not table.find(data.Networks, guildNetwork.Id) then table.insert(data.Networks, guildNetwork.Id) end
			local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
			deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		end

		GuildServerManager.SaveGuildData(guildId)
		deps.Events.NotifyPlayer:FireClient(player, "Success", "Joined guild!")
		local pG = {Id = guild.Id, Name = guild.Name, Reputation = guild.Reputation, Funds = guild.Funds, Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP}
		deps.Events.SendGuildData:FireClient(player, pG, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
	else
		deps.Events.NotifyPlayer:FireClient(player, "Info", "Guild invitation declined")
	end

	local mail = deps.MailManager.LoadMail(userId)
	for _, m in ipairs(mail) do
		if m.Type == "GuildInvite" and m.GuildId == guildId and not m.Responded then
			deps.MailManager.UpdateMailById(userId, m.Id, {Responded = true})
			break
		end
	end

	local updatedMail = deps.MailManager.LoadMail(userId)
	deps.Events.SendMailData:FireClient(player, deps.MailManager.FilterMailData(updatedMail, userId))
end

