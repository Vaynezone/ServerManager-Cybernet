-- ServerLoopManager | ModuleScript | ServerScriptService.ServerFramework

local ServerLoopManager = {}
local deps = {}

function ServerLoopManager.Init(dependencies)
	deps = dependencies

	-- 1. Bounty Expiration Loop
	task.spawn(function()
		task.wait(60)
		local UpdateMoneyEvent = deps.Events.Folder:FindFirstChild("UpdateMoney")
		local NotifyPlayerEvent = deps.Events.Folder:FindFirstChild("NotifyPlayer")
		while true do
			if deps.BountyManager and deps.BountyManager.ProcessExpiredBounties then
				deps.BountyManager.ProcessExpiredBounties(
					deps.PlayerData, 
					deps.MailManager.SaveMail, 
					deps.Events.SendMailData, 
					NotifyPlayerEvent, 
					UpdateMoneyEvent
				)
			end
			task.wait(3600)
		end
	end)

	-- 2. Awareness Decay & Trace Loop
	task.spawn(function()
		while true do
			task.wait(1)

			-- Check traces and lockouts
			for userId, data in pairs(deps.PlayerData) do
				local player = deps.Players:GetPlayerByUserId(userId)
				if player then
					deps.OperationManager.UpdatePlayerResourceUsage(userId)

					if data.CurrentNetwork then
						local currentNet = deps.NetworkStateManager.GetNetwork(data.CurrentNetwork, userId)
						if currentNet and currentNet.HasAdmin and currentNet.AdminTier > 0 then
							local awareness = deps.NetworkStateManager.GetNetworkAwareness(data.CurrentNetwork)
							if awareness > 0 then
								local traceChance = awareness / 10
								if math.random() * 100 < traceChance then
									deps.TraceManager.StartAdminTrace(player, currentNet, {
										getPlayerSkillEffects = deps.ProgressionManager.GetPlayerSkillEffects,
										getPlayerData = function(uid) return deps.PlayerData[uid] end,
										getNetworkAwareness = deps.NetworkStateManager.GetNetworkAwareness,
										getEffectiveSecurity = deps.NetworkStateManager.GetEffectiveSecurity,
										calculateNetworkValue = function(p, netId) return deps.PlayerData[p.UserId] and deps.PlayerData[p.UserId].NetworkValue[netId] or 0 end,
										resetNetworkAwareness = deps.NetworkStateManager.ResetNetworkAwareness,
										setNetworkSecurityBoost = function(networkId, boost) deps.NetworkSecurityBoosts[networkId] = boost end,
										kickAllPlayersFromNetwork = deps.NetworkStateManager.KickAllPlayersFromNetwork,
										prepareNetworksForClient = deps.NetworkStateManager.PrepareNetworksForClient
									})
								end
							end
						end
					end
				end

				-- Network Lock Expirations
				for _, network in ipairs(data.Networks or {}) do
					if network.Locked then
						if not network.LockExpiry or network.LockExpiry <= 0 or time() >= network.LockExpiry then
							network.Locked = false
							network.LockExpiry = nil
						elseif network.LockExpiry > time() + 3600 then
							network.Locked = false
							network.LockExpiry = nil
						end
					end
				end
			end

			-- Clear expired security boosts
			for networkId, boost in pairs(deps.NetworkSecurityBoosts) do
				if time() >= boost.ExpiryTime then
					deps.NetworkSecurityBoosts[networkId] = nil
				end
			end

			-- Process awareness decay
			local awarenessUpdates = {}
			for networkId, awarenessData in pairs(deps.NetworkAwareness) do
				if awarenessData.Level > 0 then
					local timeSinceUpdate = time() - awarenessData.LastUpdate
					local effectiveSecurity = deps.NetworkStateManager.GetEffectiveSecurity(networkId)
					local decayRate = deps.GameData.AwarenessDecayRates[effectiveSecurity] or (100 / 300)
					local decayAmount = decayRate * timeSinceUpdate
					local oldLevel = awarenessData.Level

					awarenessData.Level = math.max(0, awarenessData.Level - decayAmount)
					if awarenessData.Level < 0.1 then awarenessData.Level = 0 end
					awarenessData.LastUpdate = time()

					if awarenessData.Level > 0.1 then
						awarenessUpdates[networkId] = awarenessData.Level
					elseif oldLevel > 0.1 then
						awarenessUpdates[networkId] = 0
					end
				end
			end

			-- Broadcast awareness updates to relevant players
			if next(awarenessUpdates) then
				for userId, data in pairs(deps.PlayerData) do
					local player = deps.Players:GetPlayerByUserId(userId)
					if player then
						local playerAwarenessUpdates = {}
						for _, network in ipairs(data.Networks or {}) do
							if awarenessUpdates[network.Id] then
								playerAwarenessUpdates[network.Id] = awarenessUpdates[network.Id]
							end
						end
						if next(playerAwarenessUpdates) then
							deps.Events.UpdateNetworkAwareness:FireClient(player, playerAwarenessUpdates)
						end
					end
				end
			end
		end
	end)

	-- 3. Auto-Save and Moderation Loop
	task.spawn(function()
		while true do
			task.wait(300)
			deps.DataStoreManager.ProcessSaveQueue()

			-- Process Auto-Saves
			for userId, data in pairs(deps.PlayerData) do
				if deps.PlayerDataDirty[userId] then
					local lastSave = deps.LastPlayerSave[userId] or 0
					if time() - lastSave >= 60 then
						local saved = deps.DataSaveManager.SaveAllPlayerData(userId, false)
						if saved then
							deps.PlayerDataDirty[userId] = nil
							deps.LastPlayerSave[userId] = time()
						end
					end
				end
			end

			-- Process Auto-Moderation
			if deps.AutoModeration and deps.ExploitLogger then
				for guildId, guild in pairs(deps.Guilds) do
					deps.AutoModeration.RunAutoModOnGuild(guildId, deps.Guilds, deps.ExploitLogger)
				end
				for userId, data in pairs(deps.PlayerData) do
					deps.AutoModeration.RunAutoModOnPlayer(userId, deps.PlayerData, deps.ExploitLogger)
				end
			end
		end
	end)
end

return ServerLoopManager


-- NetworkStateManager | ModuleScript | ServerScriptService.ServerFramework

local NetworkStateManager = {}
local deps = {}

function NetworkStateManager.Init(dependencies)
	deps = dependencies
end

function NetworkStateManager.SanitizeFirewall(fw)
	if type(fw) ~= "table" then return nil end
	local ok, lib = pcall(function() return fw.Library end)
	local ok2, ver = pcall(function() return fw.Version end)
	return { Library = tostring(lib or ""), Version = tostring(ver or ""), HasFirewall = (fw.HasFirewall == true) or false }
end

function NetworkStateManager.GetNetwork(networkId, userId)
	if not deps.PlayerData[userId] or not deps.PlayerData[userId].Networks then return nil end
	for _, network in ipairs(deps.PlayerData[userId].Networks) do 
		if network.Id == networkId then return network end 
	end
	return nil
end

function NetworkStateManager.GetEffectiveSecurity(networkId, userId)
	local baseNetwork = NetworkStateManager.GetNetwork(networkId, userId)
	if not baseNetwork then
		for _, net in ipairs(deps.GlobalNetworks) do if net.Id == networkId then baseNetwork = net break end end
	end
	if not baseNetwork then return 1 end

	local security = baseNetwork.Security
	if baseNetwork.IsPlayerHome and userId then
		local skillEffects = deps.ProgressionManager.GetPlayerSkillEffects(userId)
		if skillEffects.SecurityBoost then security = math.min(5, security + skillEffects.SecurityBoost) end
	end
	local boost = deps.NetworkSecurityBoosts[networkId]
	if boost and time() < boost.ExpiryTime then security = math.min(5, security + boost.BoostLevel) end
	return security
end

function NetworkStateManager.GetNetworkAwareness(networkId)
	if not deps.NetworkAwareness[networkId] then deps.NetworkAwareness[networkId] = { Level = 0, LastUpdate = time() } end
	return deps.NetworkAwareness[networkId].Level
end

function NetworkStateManager.UpdateNetworkAwareness(networkId, amount)
	if not deps.NetworkAwareness[networkId] then deps.NetworkAwareness[networkId] = { Level = 0, LastUpdate = time() } end
	local wasZero = deps.NetworkAwareness[networkId].Level <= 0
	deps.NetworkAwareness[networkId].Level = math.clamp(deps.NetworkAwareness[networkId].Level + amount, 0, 100)
	if wasZero and deps.NetworkAwareness[networkId].Level > 0 then deps.NetworkAwareness[networkId].LastUpdate = time() end
end

function NetworkStateManager.ResetNetworkAwareness(networkId)
	if deps.NetworkAwareness[networkId] then
		deps.NetworkAwareness[networkId].Level = 0
		deps.NetworkAwareness[networkId].LastUpdate = time()
	end
end

function NetworkStateManager.RecordConnectionHistory(targetNetworkId, previousIP, userId)
	if not targetNetworkId or not previousIP then return end
	if not deps.NetworkConnectionHistory[targetNetworkId] then deps.NetworkConnectionHistory[targetNetworkId] = {} end
	table.insert(deps.NetworkConnectionHistory[targetNetworkId], 1, { PreviousIP = previousIP, UserId = userId, Timestamp = time() })
	while #deps.NetworkConnectionHistory[targetNetworkId] > 5 do table.remove(deps.NetworkConnectionHistory[targetNetworkId]) end
end

function NetworkStateManager.IsNetworkConnected(network1, network2)
	if not network1.ConnectedNetworks then network1.ConnectedNetworks = {} end
	for _, id in ipairs(network1.ConnectedNetworks) do if id == network2.Id then return true end end
	return false
end

function NetworkStateManager.ConnectNetworks(network1, network2)
	if not network1.ConnectedNetworks then network1.ConnectedNetworks = {} end
	if not network2.ConnectedNetworks then network2.ConnectedNetworks = {} end
	if not NetworkStateManager.IsNetworkConnected(network1, network2) then
		table.insert(network1.ConnectedNetworks, network2.Id)
		table.insert(network2.ConnectedNetworks, network1.Id)
	end
end

function NetworkStateManager.DisconnectNetworks(network1, network2)
	if network1.ConnectedNetworks then
		for i, id in ipairs(network1.ConnectedNetworks) do if id == network2.Id then table.remove(network1.ConnectedNetworks, i) break end end
	end
	if network2.ConnectedNetworks then
		for i, id in ipairs(network2.ConnectedNetworks) do if id == network1.Id then table.remove(network2.ConnectedNetworks, i) break end end
	end
	for _, otherData in pairs(deps.PlayerData) do
		if otherData.Networks then
			for _, net in ipairs(otherData.Networks) do
				if net.Id == network1.Id and net.ConnectedNetworks then
					for i, id in ipairs(net.ConnectedNetworks) do if id == network2.Id then table.remove(net.ConnectedNetworks, i) break end end
				elseif net.Id == network2.Id and net.ConnectedNetworks then
					for i, id in ipairs(net.ConnectedNetworks) do if id == network1.Id then table.remove(net.ConnectedNetworks, i) break end end
				end
			end
		end
	end
end

function NetworkStateManager.HasPathToNetwork(startNetwork, targetNetwork, userId, visited)
	visited = visited or {}
	if visited[startNetwork.Id] then return false end
	visited[startNetwork.Id] = true
	if startNetwork.Id == targetNetwork.Id then return true end
	if not startNetwork.ConnectedNetworks then return false end
	for _, connId in ipairs(startNetwork.ConnectedNetworks) do
		local net = NetworkStateManager.GetNetwork(connId, userId)
		if net and NetworkStateManager.HasPathToNetwork(net, targetNetwork, userId, visited) then return true end
	end
	return false
end

function NetworkStateManager.PrepareNetworksForClient(networks, userId)
	local clientNetworks = {}
	local data = deps.PlayerData[userId]
	local includedIds = {}

	if not networks or type(networks) ~= "table" then return clientNetworks end

	for _, net in ipairs(networks) do
		local network = net
		if type(net) == "string" then
			for _, gNet in ipairs(deps.GlobalNetworks) do if gNet.Id == net then network = gNet break end end
		end
		if network and type(network) == "table" and network.Id then
			local netCopy = {}
			for k, v in pairs(network) do netCopy[k] = v end
			netCopy.Firewall = NetworkStateManager.SanitizeFirewall(network.Firewall)
			netCopy.Awareness = NetworkStateManager.GetNetworkAwareness(network.Id)
			if data and data.LockedOutOfNetworks and data.LockedOutOfNetworks[network.Id] then
				local remaining = data.LockedOutOfNetworks[network.Id] - time()
				if remaining > 0 then netCopy.LockoutRemaining = remaining else data.LockedOutOfNetworks[network.Id] = nil end
			end
			if netCopy.Devices then
				for _, device in ipairs(netCopy.Devices) do
					device.Firewall = NetworkStateManager.SanitizeFirewall(device.Firewall)
					local canSteal = deps.AccessCodeSystem.CanSteal(userId, network.Id, device.Id)
					device.StealCooldownRemaining = canSteal and 0 or deps.AccessCodeSystem.GetStealTimerRemaining(userId, network.Id, device.Id)
					device.IsLoggedIn = deps.AccessCodeSystem.IsLoggedIn(userId, network.Id, device.Id)
				end
			end
			table.insert(clientNetworks, netCopy)
			includedIds[network.Id] = true
		end
	end

	local networksToAdd = {}
	for _, clientNet in ipairs(clientNetworks) do
		if clientNet.ConnectedNetworks then
			for _, connId in ipairs(clientNet.ConnectedNetworks) do
				if not includedIds[connId] and not networksToAdd[connId] then
					for oUserId, oData in pairs(deps.PlayerData) do
						if oUserId ~= userId and oData.Networks then
							for _, oNet in ipairs(oData.Networks) do
								if oNet.Id == connId and oNet.IsPlayerHome then
									networksToAdd[connId] = { Id = oNet.Id, IP = oNet.IP, Name = oNet.Name, Type = oNet.Type or "Home", Security = oNet.Security, Scanned = false, Hacked = false, Owner = oNet.Owner, Devices = {}, ConnectedNetworks = {clientNet.Id}, Position = oNet.Position or Vector2.new(0,0), Visible = true, IsPlayerHome = false, IsOtherPlayerHome = true, OwnerUserId = oUserId }
									break
								end
							end
						end
						if networksToAdd[connId] then break end
					end
				end
			end
		end
	end
	for _, netData in pairs(networksToAdd) do table.insert(clientNetworks, netData); includedIds[netData.Id] = true end
	return clientNetworks
end

function NetworkStateManager.BroadcastPlayerPositions(player)
	local positions = {}
	for userId, data in pairs(deps.PlayerData) do
		if data.CurrentNetwork then
			if not positions[data.CurrentNetwork] then positions[data.CurrentNetwork] = {} end
			local tPlayer = deps.Players:GetPlayerByUserId(userId)
			if tPlayer then table.insert(positions[data.CurrentNetwork], { UserId = userId, PlayerName = tPlayer.Name, IP = data.IP }) end
		end
	end
	if player then deps.Events.UpdatePlayerPositions:FireClient(player, positions) else for _, p in ipairs(deps.Players:GetPlayers()) do if deps.PlayerData[p.UserId] then deps.Events.UpdatePlayerPositions:FireClient(p, positions) end end end
end

function NetworkStateManager.KickAllPlayersFromNetwork(networkId, kickedPlayerId)
	for userId, data in pairs(deps.PlayerData) do
		if userId ~= kickedPlayerId and data.CurrentNetwork == networkId then
			local targetPlayer = deps.Players:GetPlayerByUserId(userId)
			if targetPlayer then
				deps.cancelAllPlayerOperations(targetPlayer)
				local homeId = data.HomeNetwork
				data.CurrentNetwork = homeId
				deps.TraceManager.CancelTraceForKickedPlayer(targetPlayer, networkId)
				deps.Events.NotifyPlayer:FireClient(targetPlayer, "Warning", "Network was locked! Kicked to home network.")
				if not data.Networks then data.Networks = {} end
				local clientNetworks = NetworkStateManager.PrepareNetworksForClient(data.Networks, userId)
				deps.Events.SendNetworkData:FireClient(targetPlayer, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
			end
		end
	end
end

return NetworkStateManager


-- OperationManager | ModuleScript | ServerScriptService.ServerFramework

local OperationManager = {}
local deps = {}

function OperationManager.Init(dependencies)
	deps = dependencies

	-- Background loop to clear stuck operations
	task.spawn(function()
		while true do
			task.wait(60)
			OperationManager.CleanupAllStaleOperations()
		end
	end)
end

function OperationManager.RegisterOperation(userId, nodeId, operationType, security, isDevice)
	if not deps.ActiveOperations[userId] then deps.ActiveOperations[userId] = {} end
	local operationId = nodeId .. "_" .. time()
	local resourceCost = deps.PCStatsManager.GetOperationResourceCost(operationType, security)
	local usesNET = operationType == "ScanNetwork" or operationType == "ScanDevice" or operationType == "ScanForNetworks"
	local netShare = usesNET and (1 / (OperationManager.CountActiveNETOperations(userId) + 1)) or nil

	deps.ActiveOperations[userId][operationId] = {
		NodeId = nodeId, Type = operationType, Cancelled = false, ResourceCost = resourceCost,
		StartTime = time(), UsesNET = usesNET, NETShare = netShare, Progress = usesNET and 0 or nil, IsDevice = isDevice
	}

	OperationManager.UpdatePlayerResourceUsage(userId)
	if usesNET then OperationManager.RecalculateNETShares(userId) end
	return operationId
end

function OperationManager.IsOperationActive(userId, operationId)
	return deps.ActiveOperations[userId] and deps.ActiveOperations[userId][operationId] and not deps.ActiveOperations[userId][operationId].Cancelled
end

function OperationManager.UnregisterOperation(userId, operationId)
	if deps.ActiveOperations[userId] then
		deps.ActiveOperations[userId][operationId] = nil
		OperationManager.UpdatePlayerResourceUsage(userId)
		OperationManager.RecalculateNETShares(userId)
	end
end

function OperationManager.GetActiveNETOperations(userId)
	local netOps = {}
	if deps.ActiveOperations[userId] then
		for opId, op in pairs(deps.ActiveOperations[userId]) do
			if not op.Cancelled and op.UsesNET then netOps[opId] = op end
		end
	end
	return netOps
end

function OperationManager.CountActiveNETOperations(userId)
	local count = 0
	if deps.ActiveOperations[userId] then
		for _, op in pairs(deps.ActiveOperations[userId]) do
			if not op.Cancelled and op.UsesNET then count = count + 1 end
		end
	end
	return count
end

function OperationManager.RecalculateNETShares(userId)
	local player = deps.Players:GetPlayerByUserId(userId)
	if not player then return end
	local netOps = OperationManager.GetActiveNETOperations(userId)
	local opCount = 0; for _ in pairs(netOps) do opCount = opCount + 1 end
	if opCount == 0 then return end
	local share = 1 / opCount
	for opId, operation in pairs(netOps) do
		local oldShare = operation.NETShare or 1
		operation.NETShare = share
		if oldShare ~= share and operation.Progress then deps.Events.UpdateScanProgress:FireClient(player, operation.NodeId, operation.Progress, share, operation.IsDevice) end
	end
end

function OperationManager.SafeUnregisterOperation(userId, operationId)
	pcall(function() OperationManager.UnregisterOperation(userId, operationId) end)
end

function OperationManager.SafeDecrementOperations(player)
	pcall(function() if deps.PlayerData[player.UserId] then OperationManager.DecrementOperations(player) end end)
end

function OperationManager.CleanupOperation(player, operationId)
	if player and player.UserId and operationId then
		OperationManager.SafeUnregisterOperation(player.UserId, operationId)
		OperationManager.SafeDecrementOperations(player)
	end
end

function OperationManager.CleanupStaleOperations(userId)
	if not deps.ActiveOperations[userId] then return end
	local currentTime = time()
	local cleaned = false
	for operationId, operation in pairs(deps.ActiveOperations[userId]) do
		if operation.StartTime and (currentTime - operation.StartTime) > 300 then
			deps.ActiveOperations[userId][operationId] = nil
			cleaned = true
		end
	end
	if cleaned then
		if deps.PlayerData[userId] then
			local actualCount = 0
			for _ in pairs(deps.ActiveOperations[userId]) do actualCount = actualCount + 1 end
			deps.PlayerData[userId].ActiveOperationsCount = actualCount
		end
		OperationManager.UpdatePlayerResourceUsage(userId)
	end
end

function OperationManager.CleanupAllStaleOperations()
	for userId, _ in pairs(deps.ActiveOperations) do
		OperationManager.CleanupStaleOperations(userId)
	end
end

function OperationManager.CancelAllPlayerOperations(player)
	local userId = player.UserId
	if deps.ActiveOperations[userId] then
		for operationId, operation in pairs(deps.ActiveOperations[userId]) do
			operation.Cancelled = true
			if operation.Type == "ScanForNetworks" then
				deps.Events.CancelScanForNetworks:FireClient(player)
			else
				deps.Events.CancelProgressBar:FireClient(player, operation.NodeId)
			end
		end
		deps.ActiveOperations[userId] = {}
		if deps.PlayerData[userId] then deps.PlayerData[userId].ActiveOperationsCount = 0 end
		OperationManager.UpdatePlayerResourceUsage(userId)
	end
end

function OperationManager.UpdatePlayerResourceUsage(userId)
	if not deps.PlayerResourceUsage[userId] then deps.PlayerResourceUsage[userId] = {CPU = 0, RAM = 0, NET = 0} end
	local player = deps.Players:GetPlayerByUserId(userId)
	local data = deps.PlayerData[userId]
	if not player or not data then return end

	local psuEfficiency = deps.PCStatsManager.GetPSUEfficiency(data.EquippedParts)
	local base = data.BaseResourceUsage or {CPU = 5, RAM = 10, NET = 1}
	base = { CPU = math.floor(base.CPU * psuEfficiency), RAM = math.floor(base.RAM * psuEfficiency), NET = math.floor(base.NET * psuEfficiency) }
	local usage = { CPU = math.max(0, base.CPU + math.random(-2, 2)), RAM = math.max(0, base.RAM + math.random(-2, 1.5)), NET = math.max(0, base.NET + math.random(-2, 1.5)) }

	if deps.ActiveOperations[userId] then
		for _, op in pairs(deps.ActiveOperations[userId]) do
			if not op.Cancelled then
				local cost = op.ResourceCost or {CPU = 0, RAM = 0, NET = 0}
				usage.CPU, usage.RAM, usage.NET = usage.CPU + cost.CPU, usage.RAM + cost.RAM, usage.NET + cost.NET
			end
		end
	end

	if data.Networks then
		local networkCount = 0
		for _, net in ipairs(data.Networks) do if net.Visible then networkCount = networkCount + 1 end end
		usage.RAM = usage.RAM + (networkCount * 0.5)
		usage.NET = usage.NET + (networkCount * 0.2)
	end
	deps.PlayerResourceUsage[userId] = usage

	if deps.Events.SendResourceUsage then
		deps.Events.SendResourceUsage:FireClient(player, usage, {
			CPU = deps.PCStatsManager.GetMaxCPUPoints(data.EquippedParts),
			RAM = deps.PCStatsManager.GetMaxRAMPoints(data.EquippedParts),
			NET = deps.PCStatsManager.GetMaxNETPoints(data.EquippedParts) * 100,
			STORAGE = deps.PCStatsManager.GetMaxStoredNetworks(data.EquippedParts)
		})
	end
end

function OperationManager.GetHackSpeed(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return 1 end
	local baseSpeed = deps.PCStatsManager.GetHackSpeed(data.EquippedParts, data.CPULevel or 1)
	local skillEffects = deps.ProgressionManager.GetPlayerSkillEffects(player.UserId)
	if skillEffects.HackSpeedMultiplier then baseSpeed = baseSpeed / skillEffects.HackSpeedMultiplier end
	if data.ActiveBoosts then
		for _, boost in pairs(data.ActiveBoosts) do if boost.Type == "HackSpeed" and time() < boost.Expiry then baseSpeed = baseSpeed / boost.Multiplier end end
	end
	return baseSpeed
end

function OperationManager.GetScanSpeed(player)
	return deps.PlayerData[player.UserId] and deps.PCStatsManager.GetScanSpeed(deps.PlayerData[player.UserId].EquippedParts, deps.ProgressionManager.GetScanSpeedMultiplier(player.UserId), deps.PlayerData[player.UserId].NetworkLevel or 1) or 1
end

function OperationManager.CanStartOperation(player)
	return deps.PlayerData[player.UserId] and deps.PCStatsManager.CanStartOperation(deps.PlayerData[player.UserId].EquippedParts, deps.PlayerData[player.UserId].ActiveOperationsCount, deps.PlayerData[player.UserId].RAMLevel or 1) or false
end

function OperationManager.GetMaxOperations(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return 1 end
	local baseMax = deps.PCStatsManager.GetMaxOperations(data.EquippedParts, data.RAMLevel or 1)
	local skillEffects = deps.ProgressionManager.GetPlayerSkillEffects(player.UserId)
	if skillEffects.MaxOperationsBonus then baseMax = baseMax + skillEffects.MaxOperationsBonus end
	return baseMax
end

function OperationManager.IncrementOperations(player) deps.PlayerData[player.UserId].ActiveOperationsCount = deps.PlayerData[player.UserId].ActiveOperationsCount + 1 end
function OperationManager.DecrementOperations(player) deps.PlayerData[player.UserId].ActiveOperationsCount = math.max(0, deps.PlayerData[player.UserId].ActiveOperationsCount - 1) end

return OperationManager


-- RewardManager | ModuleScript | ServerScriptService.ServerFramework

local RewardManager = {}
local deps = {}

function RewardManager.Init(dependencies)
	deps = dependencies

	-- Connect Group Rewards
	deps.Events.CheckGroupReward.OnServerEvent:Connect(RewardManager.OnCheckGroupReward)
	deps.Events.ClaimGroupReward.OnServerEvent:Connect(RewardManager.OnClaimGroupReward)

	-- Connect Special Items
	local RequestSpecialItems = deps.Events.Folder:FindFirstChild("RequestSpecialItems")
	local SellSpecialItem = deps.Events.Folder:FindFirstChild("SellSpecialItem")
	if RequestSpecialItems then RequestSpecialItems.OnServerEvent:Connect(RewardManager.OnRequestSpecialItems) end
	if SellSpecialItem then SellSpecialItem.OnServerEvent:Connect(RewardManager.OnSellSpecialItem) end

	-- Connect Music
	local PurchaseMusic = deps.ReplicatedStorage:FindFirstChild("RemoteEvents") and deps.ReplicatedStorage.RemoteEvents:FindFirstChild("PurchaseMusic")
	if PurchaseMusic then
		PurchaseMusic.OnServerEvent:Connect(RewardManager.OnPurchaseMusic)
	end

	-- Setup Global Task Reward
	_G.AwardTaskReward = RewardManager.AwardTaskReward
end

-- [ HELPER FUNCTIONS ] --

function RewardManager.CheckGroupMembership(player)
	if not deps.GroupRewardsConfig or not deps.GroupRewardsConfig.GroupId then return false, 0 end
	local groupId = deps.GroupRewardsConfig.GroupId
	local ok, inGroup = pcall(function() return player:IsInGroup(groupId) end)
	if not ok or not inGroup then return false, 0 end
	local ok2, rank = pcall(function() return player:GetRankInGroup(groupId) end)
	if not ok2 or not rank then return false, 0 end
	local minRank = deps.GroupRewardsConfig.MinRank or 0
	if rank < minRank then return false, rank end
	return true, rank
end

function RewardManager.GetGroupRewardCooldownState(data)
	local lastClaim = data and data.GroupRewardClaimed and data.GroupRewardClaimed.LastClaimTime or 0
	local cooldown = deps.GroupRewardsConfig and deps.GroupRewardsConfig.ClaimCooldown or (24 * 3600)
	if lastClaim <= 0 then return false, 0 end
	local elapsed = os.time() - lastClaim
	if elapsed < cooldown then return true, (cooldown - elapsed) end
	return false, 0
end

function RewardManager.SendGroupStatusToClient(player, inGroup, rank, data)
	local onCooldown, remaining = RewardManager.GetGroupRewardCooldownState(data)
	deps.Events.SendGroupRewardStatus:FireClient(player, { InGroup = inGroup, Rank = rank, OnCooldown = onCooldown, CooldownRemaining = remaining })
end

-- [ REMOTE HANDLERS ] --

function RewardManager.OnCheckGroupReward(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return end
	local inGroup, rank = RewardManager.CheckGroupMembership(player)
	RewardManager.SendGroupStatusToClient(player, inGroup, rank, data)
end

function RewardManager.OnClaimGroupReward(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	local inGroup, rank = RewardManager.CheckGroupMembership(player)
	if not inGroup then deps.Events.NotifyPlayer:FireClient(player, "Error", "You must be a member of the group to claim rewards!") return end

	local onCooldown, remaining = RewardManager.GetGroupRewardCooldownState(data)
	if onCooldown then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Daily group reward is still on cooldown! Next in " .. math.ceil(remaining/60) .. " minute(s).")
		RewardManager.SendGroupStatusToClient(player, inGroup, rank, data)
		return
	end

	local rewards = deps.GroupRewardsConfig.Rewards or {}
	local rewardsGiven = {}

	if rewards.Money then
		data.Money = (data.Money or 0) + rewards.Money
		if deps.Events.UpdateMoney then deps.Events.UpdateMoney:FireClient(player, data.Money) end
		table.insert(rewardsGiven, rewards.Money .. " RC")
		pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
	end

	if rewards.SkillPoints then
		data.PendingSkillPoints = (data.PendingSkillPoints or 0) + rewards.SkillPoints
		local spAwarded = math.floor(data.PendingSkillPoints)
		data.PendingSkillPoints = data.PendingSkillPoints - spAwarded
		if spAwarded > 0 then
			data.SkillPoints = math.min((deps.GameData.SkillTree.MaxSkillPoints or 50), (data.SkillPoints or 0) + spAwarded)
			table.insert(rewardsGiven, spAwarded .. " SP")
		else
			table.insert(rewardsGiven, string.format("%.1f", rewards.SkillPoints) .. " SP (pending)")
		end
		if deps.Events.SendSkillTree then deps.Events.SendSkillTree:FireClient(player, { SkillPoints = data.SkillPoints or 0, UnlockedSkills = data.UnlockedSkills or {} }) end
	end

	if rewards.Experience and deps.ProgressionManager.AwardExperience then
		pcall(function() deps.ProgressionManager.AwardExperience(player, rewards.Experience, "Group Reward") end)
		table.insert(rewardsGiven, rewards.Experience .. " XP")
	end

	data.GroupRewardClaimed = { LastClaimTime = os.time(), ClaimCount = (data.GroupRewardClaimed and data.GroupRewardClaimed.ClaimCount or 0) + 1 }
	deps.queuePlayerSave(player.UserId)
	deps.markPlayerDirty(player.UserId)
	RewardManager.SendGroupStatusToClient(player, true, rank, data)
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Claimed: " .. table.concat(rewardsGiven, ", "))
end

function RewardManager.OnPurchaseMusic(player, trackIndex)
	local data = deps.DataStoreManager.GetPlayerData(player)
	if not data then return end
	local TRACK_COST = 500
	if not data.OwnedMusic then data.OwnedMusic = {[1] = true} end
	if data.OwnedMusic[trackIndex] or data.OwnedMusic[tostring(trackIndex)] then return end

	if data.Money >= TRACK_COST then
		data.Money = data.Money - TRACK_COST
		data.OwnedMusic[tostring(trackIndex)] = true
		deps.DataStoreManager.SavePlayerData(player)
		local UpdateOwnedMusic = deps.ReplicatedStorage.RemoteEvents:FindFirstChild("UpdateOwnedMusic")
		if UpdateOwnedMusic then UpdateOwnedMusic:FireClient(player, trackIndex) end
		if deps.Events.UpdateMoney then deps.Events.UpdateMoney:FireClient(player, data.Money) end
	else
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Insufficient RC!")
	end
end

function RewardManager.AwardTaskReward(player, amount, xp)
	local data = deps.PlayerData[player.UserId]
	if not data then return false end
	data.Money = (data.Money or 0) + amount
	if deps.Events.UpdateMoney then deps.Events.UpdateMoney:FireClient(player, data.Money) end
	if deps.ProgressionManager.AwardExperience then pcall(function() deps.ProgressionManager.AwardExperience(player, xp, "Task Reward") end) end
	if deps.queuePlayerSave then deps.queuePlayerSave(player.UserId) end
	if deps.markPlayerDirty then deps.markPlayerDirty(player.UserId) end
	return true
end

function RewardManager.OnRequestSpecialItems(player)
	local data = deps.PlayerData[player.UserId]
	local specialItems = data and data.SpecialItems or {}
	if #specialItems == 0 then
		local ver = deps.ReplicatedStorage:WaitForChild("Version").Value
		local UnifiedStore = deps.DataStoreService:GetDataStore("UnifiedPlayerData" .. ver)
		local success, savedString = pcall(function() return UnifiedStore:GetAsync("Player_" .. player.UserId) end)
		if success and savedString then
			local decodeSuccess, savedData = pcall(function() return deps.HttpService:JSONDecode(savedString) end)
			if decodeSuccess and savedData and savedData.SpecialItems then
				specialItems = savedData.SpecialItems
				if data then data.SpecialItems = specialItems end
			end
		end
	end
	local SendSpecialItems = deps.Events.Folder:FindFirstChild("SendSpecialItems")
	if SendSpecialItems then SendSpecialItems:FireClient(player, specialItems) end
end

function RewardManager.OnSellSpecialItem(player, itemIndex)
	local data = deps.PlayerData[player.UserId]
	if not data then return end
	local currentNet = deps.getNetwork(data.CurrentNetwork, player.UserId)
	if not currentNet or not deps.GameData.NetworkTypes[currentNet.Type] or not deps.GameData.NetworkTypes[currentNet.Type].CanSellTopSecret then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "You must be on a Black Market Hub to sell items!") return
	end
	local specialItems = data.SpecialItems or {}
	if #specialItems == 0 or itemIndex < 1 or itemIndex > #specialItems then deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid item!") return end

	local item = specialItems[itemIndex]
	local itemValue = item.Value or 0
	table.remove(specialItems, itemIndex)
	data.SpecialItems = specialItems
	data.Money = (data.Money or 0) + itemValue

	deps.Events.UpdateMoney:FireClient(player, data.Money)
	local SendSpecialItems = deps.Events.Folder:FindFirstChild("SendSpecialItems")
	if SendSpecialItems then SendSpecialItems:FireClient(player, specialItems) end
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Sold special item for " .. itemValue .. " RC!")
	deps.markPlayerDirty(player.UserId)
	pcall(function() deps.DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
end

return RewardManager


-- NetworkActionManager | ModuleScript | ServerScriptService.ServerFramework

local NetworkActionManager = {}
local deps = {}

function NetworkActionManager.Init(dependencies)
	deps = dependencies

	deps.Events.ScanForNetworks.OnServerEvent:Connect(function(player)
		if deps.GameActions then deps.GameActions.ScanForNetworks(deps.buildActionParams(player)) end
	end)

	deps.Events.ScanNetwork.OnServerEvent:Connect(function(player, networkId)
		if deps.GameActions then deps.GameActions.ScanNetwork(deps.buildActionParams(player, {networkId = networkId})) end
	end)

	deps.Events.HackNetwork.OnServerEvent:Connect(function(player, networkId)
		if deps.GameActions then deps.GameActions.HackNetwork(deps.buildActionParams(player, {networkId = networkId})) end
	end)

	deps.Events.ScanDevice.OnServerEvent:Connect(function(player, networkId, deviceId)
		if deps.GameActions then deps.GameActions.ScanDevice(deps.buildActionParams(player, {networkId = networkId, deviceId = deviceId})) end
	end)

	deps.Events.HackDevice.OnServerEvent:Connect(function(player, networkId, deviceId)
		if deps.GameActions then deps.GameActions.HackDevice(deps.buildActionParams(player, {networkId = networkId, deviceId = deviceId})) end
	end)

	deps.Events.ReturnHome.OnServerEvent:Connect(function(player)
		if deps.GameActions then deps.GameActions.ReturnHome(deps.buildActionParams(player)) end
	end)

	deps.Events.MoveToNetwork.OnServerEvent:Connect(function(player, networkId)
		if not deps.GameActions then return end
		local data = deps.PlayerData[player.UserId]
		if not data then return end
		local oldNetworkId = data.CurrentNetwork
		local oldNet = deps.getNetwork(oldNetworkId, player.UserId)
		local result = deps.GameActions.MoveToNetwork(deps.buildActionParams(player, {networkId = networkId}))
		if result then
			if oldNet then deps.recordConnectionHistory(networkId, oldNet.IP, player.UserId) end
			if oldNetworkId and oldNetworkId ~= networkId then
				local traceHelpers = {
					getPlayerData = function(uid) return deps.PlayerData[uid] end,
					getNetwork = deps.getNetwork,
					getEffectiveSecurity = deps.getEffectiveSecurity,
					updateNetworkAwareness = deps.updateNetworkAwareness
				}
				deps.TraceManager.HandlePlayerMove(player, oldNetworkId, traceHelpers)
			end
			deps.broadcastPlayerPositions(nil)
		end
	end)

	if deps.Events.RemoveNetwork then
		deps.Events.RemoveNetwork.OnServerEvent:Connect(function(player, networkIP)
			local userId = player.UserId
			local data = deps.PlayerData[userId]
			if not data then return end
			if not networkIP or type(networkIP) ~= "string" or networkIP == "" then deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid network IP") return end
			local homeNet = deps.getNetwork(data.HomeNetwork, userId)
			if homeNet and homeNet.IP == networkIP then deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot remove your home network") return end
			local currentNet = deps.getNetwork(data.CurrentNetwork, userId)
			if currentNet and currentNet.IP == networkIP then deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot remove current network") return end

			local foundIndex = nil
			for i, network in ipairs(data.Networks) do
				if network.IP == networkIP and (network.Visible == nil or network.Visible == true) then foundIndex = i break end
			end
			if not foundIndex then deps.Events.NotifyPlayer:FireClient(player, "Error", "Network not found in viewer") return end

			local removedNet = data.Networks[foundIndex]
			table.remove(data.Networks, foundIndex)
			for _, network in ipairs(data.Networks) do
				if network.ConnectedNetworks then
					for j = #network.ConnectedNetworks, 1, -1 do
						if network.ConnectedNetworks[j] == removedNet.Id then table.remove(network.ConnectedNetworks, j) end
					end
				end
			end
			deps.markPlayerDirty(userId)
			local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
			deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
			deps.Events.NotifyPlayer:FireClient(player, "Success", "Network removed")
		end)
	end

	deps.Events.GetFirewallData.OnServerEvent:Connect(function(player, networkId, deviceId)
		local data = deps.PlayerData[player.UserId]
		if not data then return end
		local targetFirewall, targetType = nil, nil
		local network = deps.getNetwork(networkId, player.UserId)
		if network then
			if deviceId then
				for _, device in ipairs(network.Devices) do
					if device.Id == deviceId and device.Firewall then
						targetFirewall = deps.sanitizeFirewall(device.Firewall); targetType = "device"; break
					end
				end
			elseif network.Firewall then
				targetFirewall = deps.sanitizeFirewall(network.Firewall); targetType = "network"
			end
		end
		deps.Events.SendFirewallData:FireClient(player, deps.sanitizeFirewall(targetFirewall), targetType, networkId, deviceId)
	end)

	deps.Events.GetPlayerExploits.OnServerEvent:Connect(function(player, library, version)
		local data = deps.PlayerData[player.UserId]
		if not data then return end
		local applicableExploits = {}
		if data.OwnedExploits then
			if library and version and library ~= "" and version ~= "" then
				for key, exploit in pairs(data.OwnedExploits) do
					if exploit.Library == library and exploit.Version == version then table.insert(applicableExploits, exploit) end
				end
			else
				for key, exploit in pairs(data.OwnedExploits) do table.insert(applicableExploits, exploit) end
			end
		end
		deps.Events.SendPlayerExploits:FireClient(player, applicableExploits, library, version)
	end)

	deps.Events.BypassFirewall.OnServerEvent:Connect(function(player, networkId, deviceId, exploitData)
		local data = deps.PlayerData[player.UserId]
		if not data then return end
		if not data.EquippedParts.CPU then deps.Events.NotifyPlayer:FireClient(player, "Error", "No CPU equipped.") return end
		if not deps.canStartOperation(player) then deps.Events.NotifyPlayer:FireClient(player, "Error", "Too many operations running!") return end

		local targetFirewall = nil
		local network = deps.getNetwork(networkId, player.UserId)
		if not network then return end

		if deviceId then
			for _, device in ipairs(network.Devices) do
				if device.Id == deviceId and device.Firewall then targetFirewall = deps.sanitizeFirewall(device.Firewall) break end
			end
		else
			if network.Firewall then targetFirewall = deps.sanitizeFirewall(network.Firewall) end
		end

		if not targetFirewall then deps.Events.NotifyPlayer:FireClient(player, "Error", "No firewall detected!") return end
		if not exploitData or exploitData.Library ~= targetFirewall.Library or exploitData.Version ~= targetFirewall.Version then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Exploit does not match firewall!") return
		end

		local effectiveSecurity = deviceId and 4 or deps.getEffectiveSecurity(networkId, player.UserId)
		local difficulty = deps.GameData.HackDifficulty[effectiveSecurity]
		local duration = difficulty.Duration * deps.getHackSpeed(player)

		deps.incrementOperations(player)
		local operationId = deps.registerOperation(player.UserId, deviceId or networkId, "BypassFirewall", effectiveSecurity)
		deps.Events.StartProgressBar:FireClient(player, deviceId or networkId, duration, deviceId ~= nil)
		task.wait(duration)

		if not deps.isOperationActive(player.UserId, operationId) then
			deps.unregisterOperation(player.UserId, operationId)
			deps.decrementOperations(player)
			return
		end

		if deviceId then
			for _, device in ipairs(network.Devices) do
				if device.Id == deviceId then device.FirewallBypassed = true; deps.Events.NotifyPlayer:FireClient(player, "Success", "Firewall bypassed!") break end
			end
		else
			network.FirewallBypassed = true
			deps.Events.NotifyPlayer:FireClient(player, "Success", "Firewall bypassed!")
		end

		local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
		deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		deps.unregisterOperation(player.UserId, operationId)
		deps.decrementOperations(player)
	end)

	deps.Events.ResetNetworks.OnServerEvent:Connect(function(player)
		local data = deps.PlayerData[player.UserId]
		if not data then return end
		local playerNetworks = data.Networks
		if not playerNetworks then return end
		local oldNetworkId = data.CurrentNetwork

		for i = #playerNetworks, 1, -1 do
			if not playerNetworks[i].IsPlayerHome and not playerNetworks[i].IsPlayerTestingHub and not playerNetworks[i].IsGuildNetwork and not playerNetworks[i].IsTutorialNetwork then
				table.remove(playerNetworks, i)
			end
		end

		for _, network in ipairs(playerNetworks) do
			if network.ConnectedNetworks then network.ConnectedNetworks = {} end
		end

		local homeNetwork = nil
		for _, network in ipairs(playerNetworks) do
			if network.IsPlayerHome then homeNetwork = network break end
		end

		if homeNetwork then
			local oldIP = homeNetwork.IP
			if oldIP and deps.NetworkGenerator.IsIPUsed(oldIP) then deps.NetworkGenerator.ReleaseIP(oldIP) end
			local newIP = deps.NetworkGenerator.GenerateIP()
			homeNetwork.IP = newIP; data.IP = newIP
			deps.DataStoreManager.SavePlayerIP(player.UserId, newIP)
			data.CurrentNetwork = homeNetwork.Id; homeNetwork.Scanned = true
			for _, device in ipairs(homeNetwork.Devices) do device.Scanned = true end
		end

		local loggedInNetworkId = data.LoggedInNetwork
		if data.ProtocolLockoutUntil and time() < data.ProtocolLockoutUntil then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Protocol reset is locked!") return
		end

		deps.TraceManager.HandleResetProtocol(player, oldNetworkId, loggedInNetworkId, {})
		if loggedInNetworkId then deps.AccessCodeSystem.LogoutFromAllDevicesOnNetwork(player.UserId, loggedInNetworkId) end
		data.LoggedInNetwork = nil; data.LoggedInDevice = nil; data.ScannedNetworks = {}

		for networkId, connections in pairs(deps.PlayerHomeConnections) do
			if connections[player.UserId] then connections[player.UserId] = nil end
		end

		for otherUserId, otherData in pairs(deps.PlayerData) do
			if otherUserId ~= player.UserId and otherData.Networks then
				for i = #otherData.Networks, 1, -1 do
					if otherData.Networks[i].IsOtherPlayerHome and otherData.Networks[i].OriginalOwnerId == player.UserId then table.remove(otherData.Networks, i) end
				end
				local otherPlayer = deps.Players:GetPlayerByUserId(otherUserId)
				if otherPlayer then
					local clientNetworks = deps.prepareNetworksForClient(otherData.Networks, otherUserId)
					deps.Events.SendNetworkData:FireClient(otherPlayer, clientNetworks, otherData.CurrentNetwork, otherData.LoggedInNetwork, otherData.LoggedInDevice)
				end
			end
		end

		deps.Events.NotifyPlayer:FireClient(player, "Success", "Network protocol reset.")
		local clientNetworks = deps.prepareNetworksForClient(playerNetworks, player.UserId)
		deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		deps.Events.CenterOnHomeNetwork:FireClient(player)
	end)

	deps.Events.DisconnectAllLines.OnServerEvent:Connect(function(player)
		local data = deps.PlayerData[player.UserId]
		if not data then return end
		for _, network in ipairs(data.Networks) do
			if network.ConnectedNetworks then network.ConnectedNetworks = {} end
		end
		deps.markPlayerDirty(player.UserId)
		deps.Events.SendNetworkData:FireClient(player, deps.prepareNetworksForClient(data.Networks, player.UserId), data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
		deps.Events.TerminalResponse:FireClient(player, "✓ All network connections have been disconnected")
	end)

	deps.Events.TraceConnection.OnServerEvent:Connect(function(player, targetUserId)
		local helpers = {
			getPlayerSkillEffects = deps.ProgressionManager.GetPlayerSkillEffects,
			getPlayerData = function(userId) return deps.PlayerData[userId] end,
			getNetwork = deps.getNetwork, getEffectiveSecurity = deps.getEffectiveSecurity,
			getScanSpeed = deps.getScanSpeed, canStartOperation = deps.canStartOperation,
			getMaxOperations = deps.getMaxOperations, incrementOperations = deps.incrementOperations,
			decrementOperations = deps.decrementOperations, registerOperation = deps.registerOperation,
			unregisterOperation = deps.unregisterOperation, isOperationActive = deps.isOperationActive,
			cancelAllPlayerOperations = deps.cancelAllPlayerOperations, prepareNetworksForClient = deps.prepareNetworksForClient,
			getPreviousIP = function(networkId, userId)
				if deps.NetworkConnectionHistory[networkId] then
					for _, connection in ipairs(deps.NetworkConnectionHistory[networkId]) do
						if connection.UserId == userId then return connection.PreviousIP end
					end
				end
				return "UNKNOWN"
			end
		}
		local success, result = deps.TraceManager.StartPlayerTrace(player, targetUserId, helpers)
		if not success then deps.Events.NotifyPlayer:FireClient(player, "Error", result) end
	end)

	deps.Events.UpdateViewerPositions.OnServerEvent:Connect(function(player, positionsData)
		local data = deps.PlayerData[player.UserId]
		if not data or not data.Networks then return end
		for _, posData in ipairs(positionsData) do
			for _, network in ipairs(data.Networks) do
				if network.Id == posData.NetworkId then
					network.Position = posData.Position
					if posData.Devices then
						for _, devicePosData in ipairs(posData.Devices) do
							for _, device in ipairs(network.Devices) do
								if device.Id == devicePosData.DeviceId then
									device.RelativePosition = devicePosData.RelativePosition
									break
								end
							end
						end
					end
					break
				end
			end
		end
	end)
end

return NetworkActionManager


-- ProgramServerBridge | ModuleScript | ServerScriptService.ServerFramework

local ProgramServerBridge = {}
local deps = {}

function ProgramServerBridge.Init(dependencies)
	deps = dependencies

	local programBindables = deps.ReplicatedStorage:WaitForChild("ProgramBindables", 30)
	if not programBindables or not deps.GameActions then return end
	task.wait(0.5)

	-- [ 1. PROGRAM ACTION BINDABLE ]
	local ProgramAction = programBindables:FindFirstChild("ProgramAction")
	if ProgramAction then
		ProgramAction.OnInvoke = function(player, action, targetType, networkId, deviceId, extra, extra2)
			if action == "ScanNetworks" then return deps.GameActions.ScanForNetworks(deps.buildActionParams(player))
			elseif action == "Scan" then
				if targetType == "Network" then return deps.GameActions.ScanNetwork(deps.buildActionParams(player, {networkId = networkId}))
				elseif targetType == "Device" then return deps.GameActions.ScanDevice(deps.buildActionParams(player, {networkId = networkId, deviceId = deviceId})) end
			elseif action == "Hack" then
				if targetType == "Network" then return deps.GameActions.HackNetwork(deps.buildActionParams(player, {networkId = networkId}))
				elseif targetType == "Device" then return deps.GameActions.HackDevice(deps.buildActionParams(player, {networkId = networkId, deviceId = deviceId})) end
			elseif action == "Move" then return deps.GameActions.MoveToNetwork(deps.buildActionParams(player, {networkId = networkId}))
			elseif action == "Login" then return deps.GameActions.LoginToNode(deps.buildActionParams(player, {networkId = networkId, deviceId = deviceId, accessCode = extra}))
			elseif action == "Logout" then return deps.GameActions.LogoutFromNode(deps.buildActionParams(player, {networkId = networkId, deviceId = deviceId}))
			elseif action == "Steal" then return deps.GameActions.StealFromNode(deps.buildActionParams(player, {networkId = networkId, deviceId = deviceId}))
			elseif action == "ReturnHome" then return deps.GameActions.ReturnHome(deps.buildActionParams(player))
			elseif action == "DeleteNetwork" then
				local data = deps.PlayerData[player.UserId]
				if not data then return false end
				local netId = type(networkId) == "table" and (networkId.NetworkId or networkId.Id) or networkId
				if netId == data.HomeNetwork or netId == data.CurrentNetwork then return false end

				local foundIndex, removedNet = nil, nil
				for i, network in ipairs(data.Networks) do
					if network.Id == netId then foundIndex = i; removedNet = network; break end
				end
				if not foundIndex then return false end

				table.remove(data.Networks, foundIndex)
				for _, network in ipairs(data.Networks) do
					if network.ConnectedNetworks then
						for j = #network.ConnectedNetworks, 1, -1 do
							if network.ConnectedNetworks[j] == removedNet.Id then table.remove(network.ConnectedNetworks, j) end
						end
					end
				end
				local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
				deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
				return true

			elseif action == "ConnectNetworks" then
				local data = deps.PlayerData[player.UserId]
				if not data then return false end
				local net1Id = type(networkId) == "table" and (networkId.NetworkId or networkId.Id) or networkId
				local net2Id = type(deviceId) == "table" and (deviceId.NetworkId or deviceId.Id) or deviceId

				local network1, network2 = nil, nil
				for _, network in ipairs(data.Networks) do
					if network.Id == net1Id then network1 = network end
					if network.Id == net2Id then network2 = network end
				end

				if not network1 or not network2 or network1.Id == network2.Id or deps.isNetworkConnected(network1, network2) then return false end
				deps.connectNetworks(network1, network2)
				local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
				deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
				return true

			elseif action == "DisconnectNetworks" then
				local data = deps.PlayerData[player.UserId]
				if not data then return false end
				local net1Id = type(networkId) == "table" and (networkId.NetworkId or networkId.Id) or networkId
				local net2Id = type(deviceId) == "table" and (deviceId.NetworkId or deviceId.Id) or deviceId

				local network1, network2 = nil, nil
				for _, network in ipairs(data.Networks) do
					if network.Id == net1Id then network1 = network end
					if network.Id == net2Id then network2 = network end
				end
				if not network1 or not network2 or not deps.isNetworkConnected(network1, network2) then return false end

				deps.disconnectNetworks(network1, network2)
				local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
				deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
				return true

			elseif action == "RunExploit" then
				local exploitData = extra
				local data = deps.PlayerData[player.UserId]
				if not data then return false end

				local netId = type(networkId) == "table" and (networkId.NetworkId or networkId.Id) or networkId
				local network = deps.getNetwork(netId, player.UserId)
				if not network then return false end

				local targetFirewall, targetDeviceId = nil, type(deviceId) == "table" and (deviceId.DeviceId or deviceId.Id) or deviceId

				if targetDeviceId then
					for _, device in ipairs(network.Devices) do
						if device.Id == targetDeviceId and device.Firewall and not device.FirewallBypassed then
							targetFirewall = deps.sanitizeFirewall(device.Firewall); break
						end
					end
				elseif network.Firewall and not network.FirewallBypassed then
					targetFirewall = deps.sanitizeFirewall(network.Firewall)
				end

				if not targetFirewall or not exploitData or exploitData.Library ~= targetFirewall.Library or exploitData.Version ~= targetFirewall.Version then return false end

				local ownsExploit = false
				if data.OwnedExploits then
					for key, ownedExp in pairs(data.OwnedExploits) do
						if ownedExp.Library == exploitData.Library and ownedExp.Version == exploitData.Version then ownsExploit = true; break end
					end
				end
				if not ownsExploit then return false end

				if targetDeviceId then
					for _, device in ipairs(network.Devices) do
						if device.Id == targetDeviceId then device.FirewallBypassed = true break end
					end
				else
					network.FirewallBypassed = true
				end

				local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
				deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
				return true

			elseif action == "GetMatchingExploit" then
				local data = deps.PlayerData[player.UserId]
				if not data or not data.OwnedExploits then return nil end
				for key, exploit in pairs(data.OwnedExploits) do
					if exploit.Library == targetType and exploit.Version == networkId then return exploit end
				end
				return nil
			elseif action == "GetOwnedExploits" then
				local data = deps.PlayerData[player.UserId]
				if not data or not data.OwnedExploits then return {} end
				local list = {}
				for key, exploit in pairs(data.OwnedExploits) do table.insert(list, exploit) end
				return list
			elseif action == "GetExploit" then
				local data = deps.PlayerData[player.UserId]
				if not data or not data.OwnedExploits then return nil end
				for key, exploit in pairs(data.OwnedExploits) do
					if exploit.Name == targetType or key == targetType then return exploit end
				end
				return nil
			elseif action == "GetRequiredExploit" then
				local network = deps.getNetwork(networkId, player.UserId)
				if not network then return {Library = "", Version = "", HasFirewall = false, Owned = false} end
				local fwInfo = deps.sanitizeFirewall(network.Firewall)
				local hasFirewall = fwInfo and fwInfo.HasFirewall and not network.FirewallBypassed
				if not hasFirewall then return {Library = "", Version = "", HasFirewall = false, Owned = false} end

				local owned = false
				local data = deps.PlayerData[player.UserId]
				if data and data.OwnedExploits then
					for key, exploit in pairs(data.OwnedExploits) do
						if exploit.Library == fwInfo.Library and exploit.Version == fwInfo.Version then owned = true break end
					end
				end
				return {Library = fwInfo.Library or "", Version = fwInfo.Version or "", HasFirewall = true, Owned = owned}
			elseif action == "FakePopup" or action == "FakeError" then
				local network = deps.getNetwork(networkId, player.UserId)
				if not network then return end
				local ownerUserId = network.OwnerUserId or network.OriginalOwnerId or network.Owner
				if type(ownerUserId) == "number" then
					local owner = deps.Players:GetPlayerByUserId(ownerUserId)
					if owner then deps.Events.NotifyPlayer:FireClient(owner, action == "FakePopup" and (deviceId or "Warning") or "Error", action == "FakePopup" and (extra or "Alert!") or (extra or deviceId or "Error")) end
				end
			elseif action == "InstallBackdoor" then
				local network = deps.getNetwork(networkId, player.UserId)
				if not network or not network.Hacked then return false end
				network.Backdoors = network.Backdoors or {}
				network.Backdoors[player.UserId] = true
				return true
			elseif action == "RemoveBackdoor" then
				local network = deps.getNetwork(networkId, player.UserId)
				if network and network.Backdoors then network.Backdoors[player.UserId] = nil end
			elseif action == "HasBackdoor" then
				local network = deps.getNetwork(networkId, player.UserId)
				if not network then return false end
				return network.Backdoors and network.Backdoors[player.UserId] == true
			elseif action == "GetDeviceInfo" then
				local network = deps.getNetwork(networkId, player.UserId)
				if not network then return {Name = "", IP = "", Type = "", Owner = "", Security = 0} end
				local device = nil
				if deviceId then
					for _, d in ipairs(network.Devices or {}) do
						if d.Id == deviceId then device = d break end
					end
				end
				if device then return {Name = device.Name or device.LANIP, IP = device.LANIP or "", Type = device.DeviceType or "Unknown", Owner = network.Name or network.IP, Security = device.Security or 0}
				else return {Name = network.Name or network.IP, IP = network.IP or "", Type = "Network", Owner = "", Security = network.Security or 0} end
			elseif action == "GetInstalledPrograms" or action == "GetActivePrograms" then
				return {}
			elseif action == "GetDeviceBalance" then
				local network = deps.getNetwork(networkId, player.UserId)
				return network and (network.Balance or 0) or 0
			elseif action == "TraceIntruder" then
				local intruderUserId = extra
				if not intruderUserId then return false end
				if deps.SpoofedOperations[intruderUserId] and time() < deps.SpoofedOperations[intruderUserId] then return false end
				local intruderPlayer = deps.Players:GetPlayerByUserId(intruderUserId)
				if not intruderPlayer then return false end

				local data = deps.PlayerData[player.UserId]
				if not data then return false end
				local homeNetwork = nil
				for _, net in ipairs(data.Networks) do
					if net.IsPlayerHome then homeNetwork = net break end
				end
				if not homeNetwork then return false end

				local traceHelpers = {
					getPlayerData = function(uid) return deps.PlayerData[uid] end, getNetwork = deps.getNetwork,
					getEffectiveSecurity = deps.getEffectiveSecurity, canStartOperation = deps.canStartOperation,
					getMaxOperations = deps.getMaxOperations, getScanSpeed = deps.getScanSpeed,
					incrementOperations = deps.incrementOperations, decrementOperations = deps.decrementOperations,
					registerOperation = deps.registerOperation, unregisterOperation = deps.unregisterOperation,
					isOperationActive = deps.isOperationActive, prepareNetworksForClient = deps.prepareNetworksForClient,
					markPlayerDirty = deps.markPlayerDirty,
				}
				local originalNetwork = data.CurrentNetwork
				data.CurrentNetwork = homeNetwork.Id
				local success, result = deps.TraceManager.StartPlayerTrace(player, intruderUserId, traceHelpers)
				data.CurrentNetwork = originalNetwork
				return success and result == "success"
			elseif action == "ForceLogoutPlayer" then
				local intruderUserId = extra
				if not intruderUserId then return false end
				local intruderData = deps.PlayerData[intruderUserId]
				local data = deps.PlayerData[player.UserId]
				if not intruderData or not data then return false end
				local homeNetworkId = nil
				for _, net in ipairs(data.Networks) do
					if net.IsPlayerHome then homeNetworkId = net.Id break end
				end
				if not homeNetworkId then return false end

				if intruderData.LoggedInNetwork == homeNetworkId then
					intruderData.LoggedInNetwork = nil
					intruderData.LoggedInDevice = nil
					deps.AccessCodeSystem.LogoutFromAllDevicesOnNetwork(intruderUserId, homeNetworkId)
					local intruderPlayer = deps.Players:GetPlayerByUserId(intruderUserId)
					if intruderPlayer then
						local clientNetworks = deps.prepareNetworksForClient(intruderData.Networks, intruderUserId)
						deps.Events.SendNetworkData:FireClient(intruderPlayer, clientNetworks, intruderData.CurrentNetwork, intruderData.LoggedInNetwork, intruderData.LoggedInDevice)
					end
					return true
				end
				return false
			elseif action == "CancelOperations" then
				local targetName = extra
				if not targetName then return 0 end
				local targetPlayer = nil
				for _, p in ipairs(deps.Players:GetPlayers()) do if p.Name == targetName then targetPlayer = p break end end
				if not targetPlayer then return 0 end
				local targetUserId = targetPlayer.UserId

				if deps.SpoofedOperations[targetUserId] and time() < deps.SpoofedOperations[targetUserId] then return 0 end

				local cancelled = 0
				if deps.ActiveOperations[targetUserId] then
					for opId, operation in pairs(deps.ActiveOperations[targetUserId]) do
						if not operation.Cancelled then
							operation.Cancelled = true
							cancelled = cancelled + 1
							if operation.NodeId then deps.Events.CancelProgressBar:FireClient(targetPlayer, operation.NodeId) end
						end
					end
					if cancelled > 0 then deps.Events.NotifyPlayer:FireClient(targetPlayer, "Warning", "Your operations were cancelled!") end
				end
				return cancelled
			elseif action == "SpoofOperation" then
				local duration = tonumber(extra) or 5
				deps.SpoofedOperations[player.UserId] = time() + math.min(duration, 5)
				return true
			end
			return false
		end
	end

