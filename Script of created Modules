function GuildServerManager.OnAdminCreateGuild(guildInfo, adminPlayer)
	local guildId = deps.HttpService:GenerateGUID(false)
	local guild = {
		Id = guildId, Name = guildInfo.Name, OwnerId = guildInfo.OwnerId, Funds = 0, Reputation = 0,
		Members = {{UserId = guildInfo.OwnerId, Name = guildInfo.OwnerName, Rank = deps.GuildManager.Ranks.Owner, IsAI = guildInfo.IsAI or false}},
		InviteOnly = false, NetworkIP = nil, NetworkId = nil, FundsDeviceId = nil
	}

	deps.Guilds[guildId] = guild
	GuildServerManager.CreateGuildNetwork(guild)
	GuildServerManager.SaveGuildData(guildId)

	if not guildInfo.IsAI and type(guildInfo.OwnerId) == "number" then
		local ownerPlayer = deps.Players:GetPlayerByUserId(guildInfo.OwnerId)
		if ownerPlayer and deps.PlayerData[guildInfo.OwnerId] then
			local pG = {Id = guild.Id, Name = guild.Name, Reputation = guild.Reputation, Funds = guild.Funds, Members = guild.Members, InviteOnly = guild.InviteOnly, NetworkIP = guild.NetworkIP}
			deps.Events.SendGuildData:FireClient(ownerPlayer, pG, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
		end
	end

	-- Notify others
	for _, player in ipairs(deps.Players:GetPlayers()) do
		if player ~= adminPlayer then
			local playerData = deps.PlayerData[player.UserId]
			if playerData then
				if playerData.Guild then
					local pgd = deps.Guilds[playerData.Guild]
					if pgd then
						local pG = {Id = pgd.Id, Name = pgd.Name, Reputation = pgd.Reputation, Funds = pgd.Funds, Members = pgd.Members, InviteOnly = pgd.InviteOnly, NetworkIP = pgd.NetworkIP}
						deps.Events.SendGuildData:FireClient(player, pG, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
					end
				else
					deps.Events.SendGuildData:FireClient(player, nil, GuildServerManager.GetAllGuilds(), GuildServerManager.GetServerGuilds())
				end
			end
		end
	end

	if adminPlayer then
		deps.Events.NotifyPlayer:FireClient(adminPlayer, "Success", "Guild created!")
		local SendAdminData = deps.Events.Folder:FindFirstChild("SendAdminData")
		if SendAdminData then
			SendAdminData:FireClient(adminPlayer, {Guilds = GuildServerManager.GetAllGuilds(), OnlinePlayers = {}, BannedPlayers = {}})
		end
	end
end

function GuildServerManager.OnAdminEditGuild(action, guildId, guildData)
	if action == "Update" then
		if not deps.Guilds[guildId] and guildData then
			deps.Guilds[guildId] = {Id = guildId, Name = guildData.Name, OwnerId = nil, Funds = guildData.Funds or 0, Reputation = guildData.Reputation or 0, Members = guildData.Members or {}, InviteOnly = guildData.InviteOnly or false, NetworkIP = guildData.NetworkIP, NetworkId = guildData.NetworkId}
			for _, m in ipairs(deps.Guilds[guildId].Members) do if m.Rank == 3 then deps.Guilds[guildId].OwnerId = m.UserId break end end
		elseif deps.Guilds[guildId] then
			if guildData.Name then deps.Guilds[guildId].Name = guildData.Name end
			if guildData.Funds then deps.Guilds[guildId].Funds = guildData.Funds end
			if guildData.Reputation then deps.Guilds[guildId].Reputation = guildData.Reputation end
			if guildData.Members then deps.Guilds[guildId].Members = guildData.Members end
			if guildData.InviteOnly ~= nil then deps.Guilds[guildId].InviteOnly = guildData.InviteOnly end
			for _, m in ipairs(deps.Guilds[guildId].Members) do if m.Rank == 3 then deps.Guilds[guildId].OwnerId = m.UserId break end end
		end

		if deps.Guilds[guildId] then
			local allG = GuildServerManager.GetAllGuilds()
			local sG = GuildServerManager.GetServerGuilds()
			for _, player in ipairs(deps.Players:GetPlayers()) do
				local pData = deps.PlayerData[player.UserId]
				if pData then
					if pData.Guild == guildId then
						local pG = {Id = deps.Guilds[guildId].Id, Name = deps.Guilds[guildId].Name, Reputation = deps.Guilds[guildId].Reputation, Funds = deps.Guilds[guildId].Funds, Members = deps.Guilds[guildId].Members, InviteOnly = deps.Guilds[guildId].InviteOnly, NetworkIP = deps.Guilds[guildId].NetworkIP}
						deps.Events.SendGuildData:FireClient(player, pG, allG, sG)
					else
						local pG = pData.Guild and deps.Guilds[pData.Guild] and {Id = deps.Guilds[pData.Guild].Id, Name = deps.Guilds[pData.Guild].Name, Reputation = deps.Guilds[pData.Guild].Reputation, Funds = deps.Guilds[pData.Guild].Funds, Members = deps.Guilds[pData.Guild].Members, InviteOnly = deps.Guilds[pData.Guild].InviteOnly, NetworkIP = deps.Guilds[pData.Guild].NetworkIP} or nil
						deps.Events.SendGuildData:FireClient(player, pG, allG, sG)
					end
				end
			end

			local memberIds = {}
			for _, m in ipairs(deps.Guilds[guildId].Members) do if type(m.UserId) == "number" then memberIds[m.UserId] = true end end
			for _, player in ipairs(deps.Players:GetPlayers()) do
				local pData = deps.PlayerData[player.UserId]
				if pData and pData.Guild == guildId and not memberIds[player.UserId] then
					pData.Guild = nil
					deps.queuePlayerSave(player.UserId)
					deps.Events.NotifyPlayer:FireClient(player, "Info", "Removed from guild by admin")
					deps.Events.SendGuildData:FireClient(player, nil, allG, sG)
				end
			end
		end
	elseif action == "Delete" then
		if deps.Guilds[guildId] then
			if deps.GuildNetworks[guildId] then deps.GuildNetworks[guildId] = nil end
			local allG = GuildServerManager.GetAllGuilds()
			local sG = GuildServerManager.GetServerGuilds()

			for _, member in ipairs(deps.Guilds[guildId].Members) do
				if type(member.UserId) == "number" then
					local mPlayer = deps.Players:GetPlayerByUserId(member.UserId)
					if mPlayer and deps.PlayerData[member.UserId] then
						deps.PlayerData[member.UserId].Guild = nil
						if deps.GuildNetworks[guildId] then
							for i = #deps.PlayerData[member.UserId].Networks, 1, -1 do
								local net = deps.PlayerData[member.UserId].Networks[i]
								if type(net) == "table" and net.IsGuildNetwork and net.GuildId == guildId then table.remove(deps.PlayerData[member.UserId].Networks, i) end
							end
							local cNets = deps.prepareNetworksForClient(deps.PlayerData[member.UserId].Networks, member.UserId)
							deps.Events.SendNetworkData:FireClient(mPlayer, cNets, deps.PlayerData[member.UserId].CurrentNetwork, deps.PlayerData[member.UserId].LoggedInNetwork, deps.PlayerData[member.UserId].LoggedInDevice)
						end
						deps.Events.NotifyPlayer:FireClient(mPlayer, "Info", "Guild deleted by admin")
						deps.Events.SendGuildData:FireClient(mPlayer, nil, allG, sG)
						deps.queuePlayerSave(member.UserId)
					end
				end
			end
			deps.Guilds[guildId] = nil
			allG = GuildServerManager.GetAllGuilds()
			for _, player in ipairs(deps.Players:GetPlayers()) do
				local pData = deps.PlayerData[player.UserId]
				if pData and pData.Guild ~= guildId then
					local pG = pData.Guild and deps.Guilds[pData.Guild] and {Id = deps.Guilds[pData.Guild].Id, Name = deps.Guilds[pData.Guild].Name, Reputation = deps.Guilds[pData.Guild].Reputation, Funds = deps.Guilds[pData.Guild].Funds, Members = deps.Guilds[pData.Guild].Members, InviteOnly = deps.Guilds[pData.Guild].InviteOnly, NetworkIP = deps.Guilds[pData.Guild].NetworkIP} or nil
					deps.Events.SendGuildData:FireClient(player, pG, allG, sG)
				end
			end
		end
	end
end

function GuildServerManager.GetAllGuildsForBindable()
	local guilds = {}
	for guildId, guild in pairs(deps.Guilds) do
		local membersWithNames = {}
		for _, member in ipairs(guild.Members or {}) do
			local memberName = "Unknown"
			if member.IsAI then
				memberName = member.Name
			elseif member.Name and member.Name ~= "" and member.Name ~= "Unknown" then
				memberName = member.Name
			elseif type(member.UserId) == "number" then
				local onlinePlayer = deps.Players:GetPlayerByUserId(member.UserId)
				if onlinePlayer then memberName = onlinePlayer.Name end
			end
			table.insert(membersWithNames, {UserId = member.UserId, Name = memberName, Rank = member.Rank, IsAI = member.IsAI})
		end
		local ownerName = "Unknown"
		for _, member in ipairs(membersWithNames) do
			if member.Rank == 3 then ownerName = member.Name break end
		end
		table.insert(guilds, {Id = guildId, Name = guild.Name, Funds = guild.Funds or 0, Reputation = GuildServerManager.CalculateGuildReputation(guild), Members = membersWithNames, CreatedTime = guild.CreatedTime or 0, IP = guild.NetworkIP, OwnerName = ownerName})
	end
	return guilds
end

return GuildServerManager


-- HardwareManager | ModuleScript | ServerScriptService.ServerFramework

local HardwareManager = {}

-- Dependencies
local deps = {}

-- Local State
local PlayerShopInventory = {}
local SHOP_REFRESH_INTERVAL = 1800 -- 30 minutes
local ITEMS_PER_CATEGORY = 10

function HardwareManager.Init(dependencies)
	deps = dependencies

	-- Connect Remote Events
	deps.Events.RequestPCPartsData.OnServerEvent:Connect(HardwareManager.OnRequestPCPartsData)
	deps.Events.UpdatePCParts.OnServerEvent:Connect(HardwareManager.OnUpdatePCParts)
	deps.Events.SavePCConfiguration.OnServerEvent:Connect(HardwareManager.OnSavePCConfiguration)
	deps.Events.SaveMotherboard.OnServerEvent:Connect(HardwareManager.OnSaveMotherboard)
	deps.Events.UpgradePC.OnServerEvent:Connect(HardwareManager.OnUpgradePC)
	deps.Events.UpgradeSecurity.OnServerEvent:Connect(HardwareManager.OnUpgradeSecurity)
	deps.Events.UpgradeHomeAdmin.OnServerEvent:Connect(HardwareManager.OnUpgradeHomeAdmin)
	deps.Events.PurchaseItem.OnServerEvent:Connect(HardwareManager.OnPurchaseItem)
	deps.Events.SellPCPart.OnServerEvent:Connect(HardwareManager.OnSellPCPart)
	deps.Events.RefreshShop.OnServerEvent:Connect(HardwareManager.OnRefreshShop)
	deps.Events.RequestShopInventory.OnServerEvent:Connect(HardwareManager.OnRequestShopInventory)
	deps.Events.UpdateShopRefreshTime.OnServerEvent:Connect(HardwareManager.OnUpdateShopRefreshTime)
end

-- [ HELPER FUNCTIONS ] --

function HardwareManager.IsPartIdCollision(partId, ownerUserId)
	if not partId then return false end
	for uid, pdata in pairs(deps.PlayerData) do
		if pdata and pdata.OwnedParts then
			for _, p in ipairs(pdata.OwnedParts) do
				if p and p.PartId == partId then
					return true
				end
			end
		end
	end
	return false
end

function HardwareManager.EnsurePartHasId(part, ownerUserId)
	if not part then return end
	if not part.PartId or type(part.PartId) ~= "string" or part.PartId == "" then
		part.PartId = deps.HttpService:GenerateGUID(false)
	end
	local attempts = 0
	while HardwareManager.IsPartIdCollision(part.PartId, ownerUserId) and attempts < 10 do
		part.PartId = deps.HttpService:GenerateGUID(false)
		attempts = attempts + 1
	end
	if attempts > 0 and deps.ExploitLogger then
		deps.ExploitLogger.Log(ownerUserId, "PartIdCollision", "Regenerated PartId after " .. attempts .. " attempts", "Warning")
	end
	if deps.TraceManager and deps.TraceManager.RecordPartOperation then
		deps.TraceManager.RecordPartOperation(ownerUserId, "AssignId", part.PartId, {Name = part.Name, Attempts = attempts})
	end
end

function HardwareManager.FixDuplicatePartIds(userId)
	local data = deps.PlayerData[userId]
	if not data or not data.OwnedParts then return end

	local seenPartIds = {}
	local fixed = false

	for _, part in ipairs(data.OwnedParts) do
		if part.PartId then
			if seenPartIds[part.PartId] then
				part.PartId = deps.HttpService:GenerateGUID(false)
				fixed = true
			else
				seenPartIds[part.PartId] = true
			end
		else
			part.PartId = deps.HttpService:GenerateGUID(false)
			fixed = true
		end
	end

	if fixed then deps.queuePlayerSave(userId) end
end

function HardwareManager.GenerateStartingParts()
	local parts = {}
	local startingMotherboard = deps.PCPartsData.GetMotherboard(1)
	local cpuSocket = startingMotherboard.Slots.CPUType
	local ramType = startingMotherboard.Slots.RAMType

	local cpu = deps.PCPartsData.GeneratePart("CPU", 1, cpuSocket)
	cpu.IsStartingPart = true
	table.insert(parts, cpu)

	local ram = deps.PCPartsData.GeneratePart("RAM", 2, nil, ramType)
	ram.IsStartingPart = true
	table.insert(parts, ram)

	local psu = deps.PCPartsData.GeneratePart("PSU", 1)
	psu.IsStartingPart = true
	table.insert(parts, psu)

	local hdd = deps.PCPartsData.GeneratePart("HDD", 1)
	hdd.IsStartingPart = true
	table.insert(parts, hdd)

	local net = deps.PCPartsData.GeneratePart("NET", 1)
	net.IsStartingPart = true
	table.insert(parts, net)

	startingMotherboard.IsStartingPart = true
	return parts, startingMotherboard
end

function HardwareManager.EnsureStartingPartsMarked(userId)
	local data = deps.PlayerData[userId]
	if not data then return end

	local hasStartingParts = false
	for _, part in ipairs(data.OwnedParts) do
		if part.IsStartingPart then hasStartingParts = true break end
	end
	if data.Motherboard and data.Motherboard.IsStartingPart then hasStartingParts = true end
	if hasStartingParts then return end
	if not data.Motherboard or not data.Motherboard.Slots then return end

	local requiredSocket = data.Motherboard.Slots.CPUType
	local requiredRAMType = data.Motherboard.Slots.RAMType
	local foundCPU, foundRAM, foundPSU, foundHDD, foundNET

	for _, part in ipairs(data.OwnedParts) do
		if not foundCPU and part.Type == "CPU" and part.SocketType == requiredSocket then foundCPU = part
		elseif not foundRAM and part.Type == "RAM" and part.RAMType == requiredRAMType then foundRAM = part
		elseif not foundPSU and part.Type == "PSU" then foundPSU = part
		elseif not foundHDD and part.Type == "HDD" then foundHDD = part
		elseif not foundNET and part.Type == "NET" then foundNET = part
		end
		if foundCPU and foundRAM and foundPSU and foundHDD and foundNET then break end
	end

	if foundCPU then foundCPU.IsStartingPart = true end
	if foundRAM then foundRAM.IsStartingPart = true end
	if foundPSU then foundPSU.IsStartingPart = true end
	if foundHDD then foundHDD.IsStartingPart = true end
	if foundNET then foundNET.IsStartingPart = true end
	if data.Motherboard then data.Motherboard.IsStartingPart = true end

	deps.queuePlayerSave(userId)
end

function HardwareManager.ValidatePCConfiguration(equippedParts)
	if not equippedParts or type(equippedParts) ~= "table" then return false, "Invalid parts data" end
	local validSlots = {CPU = true, GPU = true, RAM1 = true, RAM2 = true, RAM3 = true, RAM4 = true, PSU = true, HDD = true, NET = true}
	for slot, _ in pairs(equippedParts) do
		if not validSlots[slot] then return false, "Invalid slot: " .. tostring(slot) end
	end
	return true, nil
end

-- [ SHOP GENERATION ] --

function HardwareManager.GenerateShopInventory(userId)
	local inventory = {}
	local basePrices = {[0] = 0.1, [1] = 0.5, [2] = 2, [3] = 5, [4] = 15, [5] = 40, [6] = 100, [7] = 250, [8] = 500, [9] = 750, [10] = 5000}

	for _, partType in ipairs({"CPU", "GPU", "RAM", "PSU", "HDD", "NET", "MOBO"}) do
		for i = 1, ITEMS_PER_CATEGORY do
			local rating = math.random(1, 10)
			local part = deps.PCPartsData.GeneratePart(partType, rating)
			local basePrice = basePrices[rating] or 0.5
			local variance = math.floor(basePrice * (math.random(-10, 30) / 100) * 1000) / 1000
			local price = math.max(0.1, basePrice + variance)

			table.insert(inventory, {Part = part, Price = price})
		end
	end
	return {Items = inventory, GeneratedAt = time()}
end

function HardwareManager.GetOrGenerateShopInventory(userId)
	local existing = PlayerShopInventory[userId]
	if existing and (time() - existing.GeneratedAt) < SHOP_REFRESH_INTERVAL then
		return existing
	end
	local newInventory = HardwareManager.GenerateShopInventory(userId)
	PlayerShopInventory[userId] = newInventory
	return newInventory
end

function HardwareManager.ClearPlayerShop(userId)
	PlayerShopInventory[userId] = nil
end

-- [ EVENT HANDLERS ] --

function HardwareManager.OnRequestPCPartsData(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return end
	HardwareManager.EnsureStartingPartsMarked(player.UserId)
	deps.Events.SendPCPartsData:FireClient(player, {
		OwnedParts = data.OwnedParts,
		EquippedParts = data.EquippedParts,
		Motherboard = data.Motherboard
	})
end

function HardwareManager.OnUpdatePCParts(player, equippedParts)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if not equippedParts or type(equippedParts) ~= "table" then return end

	if deps.SecurityValidator then
		local valid, message = deps.SecurityValidator.ValidateEquippedParts(equippedParts, data.OwnedParts, data.Motherboard)
		if not valid then return end
	end

	local serverEquipped = {}
	for slotName, clientPart in pairs(equippedParts) do
		if clientPart ~= nil then
			local partId = type(clientPart) == "table" and clientPart.PartId or tostring(clientPart)
			if partId then
				for _, ownedPart in ipairs(data.OwnedParts) do
					if ownedPart.PartId == partId then
						serverEquipped[slotName] = ownedPart
						break
					end
				end
			end
		end
	end
	data.EquippedParts = serverEquipped
end

function HardwareManager.OnSavePCConfiguration(player, equippedParts)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if not equippedParts or type(equippedParts) ~= "table" then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid configuration data!")
		return
	end

	if deps.SecurityValidator then
		local valid, message = deps.SecurityValidator.ValidateEquippedParts(equippedParts, data.OwnedParts, data.Motherboard)
		if not valid then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid Configuration: " .. message)
			return
		end
	end

	local serverEquipped = {}
	for slotName, clientPart in pairs(equippedParts) do
		if clientPart ~= nil then
			local foundPart = nil
			local partId = type(clientPart) == "table" and clientPart.PartId or tostring(clientPart)
			if partId then
				for _, ownedPart in ipairs(data.OwnedParts) do
					if ownedPart.PartId == partId then
						foundPart = ownedPart
						break
					end
				end
			end

			if not foundPart then
				deps.Events.NotifyPlayer:FireClient(player, "Error", "Part not found in inventory!")
				return
			end
			serverEquipped[slotName] = foundPart
		end
	end

	data.EquippedParts = serverEquipped
	deps.queuePlayerSave(player.UserId)
	deps.updatePlayerResourceUsage(player.UserId)

	deps.Events.SendPCPartsData:FireClient(player, {
		OwnedParts = data.OwnedParts,
		EquippedParts = data.EquippedParts,
		Motherboard = data.Motherboard
	})
	deps.Events.NotifyPlayer:FireClient(player, "Success", "PC Configuration Saved!")

	if deps.TraceManager and deps.TraceManager.RecordPartOperation then
		for slotName, part in pairs(serverEquipped) do
			if part and part.PartId then
				deps.TraceManager.RecordPartOperation(player.UserId, "Equip", part.PartId, {Slot = slotName, Name = part.Name})
			end
		end
	end
end

function HardwareManager.OnSaveMotherboard(player, motherboardData)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if not motherboardData or type(motherboardData) ~= "table" then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid motherboard data!")
		return
	end

	if deps.SecurityValidator then
		local valid, reason = deps.SecurityValidator.ValidateMotherboard(motherboardData, data.OwnedParts)
		if not valid then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid motherboard: " .. tostring(reason))
			return
		end
	end

	local foundMotherboard = nil
	for _, part in ipairs(data.OwnedParts) do
		if part.PartId == motherboardData.PartId and (part.Type == "MOBO" or not part.Type) then
			foundMotherboard = part
			break
		end
	end

	if not foundMotherboard then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Motherboard not found in inventory!")
		return
	end

	if data.Motherboard then
		if not data.Motherboard.PartId then data.Motherboard.PartId = deps.HttpService:GenerateGUID(false) end
		if not data.Motherboard.Type then data.Motherboard.Type = "MOBO" end

		local alreadyInOwnedParts = false
		for _, part in ipairs(data.OwnedParts) do
			if part.PartId == data.Motherboard.PartId then alreadyInOwnedParts = true break end
		end
		if not alreadyInOwnedParts then
			HardwareManager.EnsurePartHasId(data.Motherboard, player.UserId)
			table.insert(data.OwnedParts, data.Motherboard)
		end
	end

	data.Motherboard = foundMotherboard
	data.EquippedParts = {CPU = nil, GPU = nil, RAM1 = nil, RAM2 = nil, RAM3 = nil, RAM4 = nil, PSU = nil, HDD = nil, NET = nil}
	deps.queuePlayerSave(player.UserId)
	HardwareManager.EnsureStartingPartsMarked(player.UserId)
	deps.updatePlayerResourceUsage(player.UserId)

	deps.Events.SendPCPartsData:FireClient(player, {
		OwnedParts = data.OwnedParts,
		EquippedParts = data.EquippedParts,
		Motherboard = data.Motherboard
	})
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Motherboard equipped! All parts unequipped due to compatibility.")
end

function HardwareManager.OnUpgradePC(player, component)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if component ~= "CPU" and component ~= "RAM" and component ~= "Network" then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Invalid upgrade component!")
		return
	end

	local currentLevel = (component == "CPU") and (data.CPULevel or 1) or (component == "RAM") and (data.RAMLevel or 1) or (data.NetworkLevel or 1)

	if currentLevel >= 5 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", component .. " is already at maximum level!")
		return
	end

	local nextLevel = currentLevel + 1
	local upgradeData = deps.GameData.PCUpgrades[component][nextLevel]
	local cost = upgradeData and upgradeData.Cost or 0

	if data.Money < cost then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. cost .. " RC.")
		return
	end

	data.Money = data.Money - cost
	if component == "CPU" then data.CPULevel = nextLevel
	elseif component == "RAM" then data.RAMLevel = nextLevel
	else data.NetworkLevel = nextLevel end

	deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)

	deps.Events.SendSystemData:FireClient(player, {
		Money = data.Money, CPULevel = data.CPULevel, RAMLevel = data.RAMLevel,
		NetworkLevel = data.NetworkLevel, PCSecurityLevel = data.PCSecurityLevel,
		HomeAdminTier = data.HomeAdminTier, OwnedGamepasses = data.OwnedGamepasses
	})
	deps.Events.NotifyPlayer:FireClient(player, "Success", component .. " upgraded to level " .. nextLevel .. "!")
	deps.queuePlayerSave(player.UserId)
end

function HardwareManager.OnUpgradeSecurity(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if data.PCSecurityLevel >= 5 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "PC Security is already at maximum level!")
		return
	end

	local nextLevel = data.PCSecurityLevel + 1
	local cost = deps.GameData.PCSecurityUpgrades[nextLevel].Cost

	if data.Money < cost then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. cost .. " RC.")
		return
	end

	data.Money = data.Money - cost
	data.PCSecurityLevel = nextLevel

	local homeNet = deps.getNetwork(data.HomeNetwork, player.UserId)
	if homeNet then
		for _, device in ipairs(homeNet.Devices) do
			if device.IsPlayerComputer then
				device.Security = deps.GameData.PCSecurityUpgrades[nextLevel].SecurityRating
				break
			end
		end
	end

	deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)

	local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
	deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
	deps.Events.SendSystemData:FireClient(player, {
		Money = data.Money, CPULevel = data.CPULevel, RAMLevel = data.RAMLevel,
		NetworkLevel = data.NetworkLevel, PCSecurityLevel = data.PCSecurityLevel,
		HomeAdminTier = data.HomeAdminTier, OwnedGamepasses = data.OwnedGamepasses
	})
	deps.Events.NotifyPlayer:FireClient(player, "Success", "PC Security upgraded to level " .. nextLevel .. "!")
end

function HardwareManager.OnUpgradeHomeAdmin(player)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	if data.OwnedGamepasses and data.OwnedGamepasses.UltimateNetworkSecurity then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "You already own the Ultimate Network Security gamepass!")
		return
	end

	if data.HomeAdminTier >= 5 then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Home Admin is already at maximum tier!")
		return
	end

	local nextTier = data.HomeAdminTier + 1
	local cost = deps.GameData.HomeAdminCosts[nextTier].Cost

	if data.Money < cost then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. cost .. " RC.")
		return
	end

	data.Money = data.Money - cost
	data.HomeAdminTier = nextTier

	local homeNet = deps.getNetwork(data.HomeNetwork, player.UserId)
	if homeNet then
		homeNet.AdminTier = nextTier
		homeNet.HasAdmin = nextTier > 0
		homeNet.Security = nextTier > 0 and math.min(5, 1 + nextTier) or 1
	end

	deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)

	local clientNetworks = deps.prepareNetworksForClient(data.Networks, player.UserId)
	deps.Events.SendNetworkData:FireClient(player, clientNetworks, data.CurrentNetwork, data.LoggedInNetwork, data.LoggedInDevice)
	deps.Events.SendSystemData:FireClient(player, {
		Money = data.Money, CPULevel = data.CPULevel, RAMLevel = data.RAMLevel,
		NetworkLevel = data.NetworkLevel, PCSecurityLevel = data.PCSecurityLevel,
		HomeAdminTier = data.HomeAdminTier, OwnedGamepasses = data.OwnedGamepasses
	})
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Home Admin upgraded to tier " .. nextTier .. "!")
end

function HardwareManager.OnPurchaseItem(player, itemData, clientPrice, itemType)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	local price
	if itemType == "exploit" then
		-- Handled by Exploit logic usually, but kept here for compatibility
		if not itemData or not itemData.Library then return end
		local exploitInfo = deps.ExploitData.GetExploit and deps.ExploitData.GetExploit(itemData.Library, itemData.Version)
		if not exploitInfo then return end

		price = exploitInfo.Price or 5000
		if data.Money < price then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. price .. " RC.")
			return
		end

		data.Money = data.Money - price
		data.OwnedExploits = data.OwnedExploits or {}
		data.OwnedExploits[itemData.Library .. "_" .. itemData.Version] = itemData

		deps.queuePlayerSave(player.UserId)
		deps.Events.NotifyPlayer:FireClient(player, "Success", "Purchased " .. itemData.Name .. " for " .. price .. " RC!")
		deps.Events.ExploitPurchased:FireClient(player, itemData)
		deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)
	else
		-- PC Part purchase
		local inventoryIndex = itemData
		local inventory = PlayerShopInventory[player.UserId]
		if not inventory or not inventory.Items or not inventory.Items[inventoryIndex] then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Item not found in shop! Please refresh.")
			return
		end

		local shopItem = inventory.Items[inventoryIndex]
		local part = shopItem.Part
		price = shopItem.Price

		if data.Money < price then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Not enough RoCoin! Need " .. price .. " RC.")
			return
		end

		data.Money = data.Money - price

		local newPart = {
			PartId = deps.HttpService:GenerateGUID(false),
			Type = part.Type, Name = part.Name, Rating = part.Rating,
			Quality = part.Quality or 50, Health = part.Health or 100,
			Performance = part.Performance, NETSpeed = part.NETSpeed,
			Storage = part.Storage, Power = part.Power,
			SocketType = part.SocketType, RAMType = part.RAMType, Slots = part.Slots
		}

		HardwareManager.EnsurePartHasId(newPart, player.UserId)
		table.insert(data.OwnedParts, newPart)
		deps.queuePlayerSave(player.UserId)

		deps.Events.SendPCPartsData:FireClient(player, {
			OwnedParts = data.OwnedParts, EquippedParts = data.EquippedParts, Motherboard = data.Motherboard
		})
		deps.Events.NotifyPlayer:FireClient(player, "Success", "Purchased " .. newPart.Name .. " for " .. price .. " RC!")
		deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)
	end
end

function HardwareManager.OnSellPCPart(player, partId)
	local data = deps.PlayerData[player.UserId]
	if not data or not partId then return end

	local partIndex, partToSell = nil, nil
	for i, part in ipairs(data.OwnedParts) do
		if part.PartId == partId then
			if part.IsStartingPart then
				deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot sell starting parts!")
				return
			end
			partIndex = i
			partToSell = part
			break
		end
	end

	if not partToSell then return end

	if partToSell.Type == "MOBO" and data.Motherboard and data.Motherboard.PartId == partId then
		deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot sell equipped motherboard! Unequip it first.")
		return
	end
	for _, equippedPart in pairs(data.EquippedParts) do
		if equippedPart and equippedPart.PartId == partId then
			deps.Events.NotifyPlayer:FireClient(player, "Error", "Cannot sell equipped part! Unequip it first.")
			return
		end
	end

	local basePrices = {[0]=0.1, [1]=0.5, [2]=2, [3]=5, [4]=15, [5]=40, [6]=100, [7]=250, [8]=500, [9]=750, [10]=5000}
	local sellPrice = math.floor((basePrices[partToSell.Rating] or 0.5) * 0.6 * 1000) / 1000

	table.remove(data.OwnedParts, partIndex)
	data.Money = data.Money + sellPrice
	deps.EconomyManager.CheckAndResetPlayerRC(player.UserId)

	deps.queuePlayerSave(player.UserId)
	deps.EconomyManager.UpdateMoney(player.UserId, data.Money, player)

	deps.Events.SendPCPartsData:FireClient(player, {
		OwnedParts = data.OwnedParts, EquippedParts = data.EquippedParts, Motherboard = data.Motherboard
	})
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Sold " .. partToSell.Name .. " for " .. sellPrice .. " RC!")
end

function HardwareManager.OnRefreshShop(player)
	PlayerShopInventory[player.UserId] = nil
	deps.Events.NotifyPlayer:FireClient(player, "Success", "Shop inventory refreshed!")
end

function HardwareManager.OnRequestShopInventory(player)
