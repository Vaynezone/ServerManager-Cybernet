	-- [ SECURITY DETECTION REGISTRATION ]
	local SecurityDetectionEvent = programBindables:FindFirstChild("SecurityDetectionEvent") or Instance.new("BindableEvent")
	SecurityDetectionEvent.Name = "SecurityDetectionEvent"
	SecurityDetectionEvent.Parent = programBindables

