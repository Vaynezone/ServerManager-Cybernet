function ProgressionManager.CheckMilestoneRewards(player, milestoneType, value)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	data.MilestoneRewards = data.MilestoneRewards or {}

	local milestones = {
		FirstScan = {value = 1, reward = 0, key = "FirstScan"},
		FirstHack = {value = 1, reward = 0, key = "FirstHack"},
		Scans25 = {value = 25, reward = 0.1, key = "Scans25"},
		Scans100 = {value = 100, reward = 0.1, key = "Scans100"},
		Scans250 = {value = 250, reward = 0.2, key = "Scans250"},
		Scans1000 = {value = 1000, reward = 0.3, key = "Scans1000"},
		Hacks25 = {value = 25, reward = 0.1, key = "Hacks25"},
		Hacks100 = {value = 100, reward = 0.1, key = "Hacks100"},
		Hacks250 = {value = 250, reward = 0.2, key = "Hacks250"},
		Hacks1000 = {value = 1000, reward = 0.3, key = "Hacks1000"},
		PlayersHacked25 = {value = 25, reward = 0.1, key = "PlayersHacked25"},
		PlayersHacked100 = {value = 100, reward = 0.2, key = "PlayersHacked100"},
		Level15 = {value = 15, reward = 0.1, key = "Level15"},
		Level30 = {value = 30, reward = 0.2, key = "Level30"},
		Level60 = {value = 60, reward = 0.3, key = "Level60"}
	}

	local milestone = milestones[milestoneType]
	if not milestone or data.MilestoneRewards[milestone.key] then return end

	local currentValue = 0
	if milestoneType == "FirstScan" or milestoneType:find("Scans") then currentValue = data.Stats.ScansCompleted or 0
	elseif milestoneType == "FirstHack" or milestoneType:find("Hacks") then currentValue = data.Stats.HacksCompleted or 0
	elseif milestoneType:find("PlayersHacked") then currentValue = data.Stats.PlayersHacked or 0
	elseif milestoneType:find("Level") then currentValue = data.Level or 0 end

	if currentValue >= milestone.value and currentValue > 0 and milestone.value > 0 then
		data.MilestoneRewards[milestone.key] = true
		data.PendingSkillPoints = (data.PendingSkillPoints or 0) + milestone.reward

		local skillPointsAwarded = math.floor(data.PendingSkillPoints)
		data.PendingSkillPoints = data.PendingSkillPoints - skillPointsAwarded

		if skillPointsAwarded > 0 then
			data.SkillPoints = (data.SkillPoints or 0) + skillPointsAwarded
			local maxSkillPoints = deps.GameData.SkillTree.MaxSkillPoints or 50
			if data.SkillPoints > maxSkillPoints then data.SkillPoints = maxSkillPoints end
		end

		local milestoneName = milestoneType:gsub("([A-Z])", " %1"):gsub("^%l", string.upper)
		local rewardText = skillPointsAwarded > 0 and ("+" .. skillPointsAwarded .. " Skill Point" .. (skillPointsAwarded > 1 and "s" or "")) or string.format("+%.1f SP (pending)", data.PendingSkillPoints > 0 and data.PendingSkillPoints or milestone.reward)

		deps.Events.NotifyPlayer:FireClient(player, "Success", "Milestone: " .. milestoneName .. "! " .. rewardText .. "!")

		if deps.Events.SendSkillTree then
			deps.Events.SendSkillTree:FireClient(player, {SkillPoints = data.SkillPoints, UnlockedSkills = data.UnlockedSkills or {}})
		end
		deps.queuePlayerSave(player.UserId)
	end
end

function ProgressionManager.AwardExperience(player, amount, reason)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	local expWithMultiplier = math.floor(amount * ProgressionManager.GetXPMultiplier(player.UserId))
	data.Experience = data.Experience + expWithMultiplier

	local expNeeded = (data.Level + 1) * 100
	local levelsGained = 0
	while data.Experience >= expNeeded do
		data.Experience = data.Experience - expNeeded
		data.Level = data.Level + 1
		levelsGained = levelsGained + 1
		expNeeded = (data.Level + 1) * 100
	end

	if levelsGained > 0 then
		local skillPointsPerLevel = deps.GameData.SkillTree.SkillPointsPerLevel or 0.5
		data.PendingSkillPoints = (data.PendingSkillPoints or 0) + (levelsGained * skillPointsPerLevel)

		local skillPointsAwarded = math.floor(data.PendingSkillPoints)
		data.PendingSkillPoints = data.PendingSkillPoints - skillPointsAwarded

		if skillPointsAwarded > 0 then
			data.SkillPoints = (data.SkillPoints or 0) + skillPointsAwarded
			local maxSkillPoints = deps.GameData.SkillTree.MaxSkillPoints or 50
			if data.SkillPoints > maxSkillPoints then data.SkillPoints = maxSkillPoints end

			deps.Events.NotifyPlayer:FireClient(player, "Success", "LEVEL UP! You are now level " .. data.Level .. "! +" .. skillPointsAwarded .. " Skill Points!")
			if deps.Events.SendSkillTree then
				deps.Events.SendSkillTree:FireClient(player, {SkillPoints = data.SkillPoints, UnlockedSkills = data.UnlockedSkills or {}})
			end
		else
			deps.Events.NotifyPlayer:FireClient(player, "Success", "LEVEL UP! You are now level " .. data.Level .. "!")
		end

		ProgressionManager.CheckMilestoneRewards(player, "Level15", data.Level)
		ProgressionManager.CheckMilestoneRewards(player, "Level30", data.Level)
		ProgressionManager.CheckMilestoneRewards(player, "Level60", data.Level)

		if deps.checkLevelRewards then deps.checkLevelRewards(player, data.Level) end
		deps.queuePlayerSave(player.UserId)
	end

	deps.Events.UpdateExperience:FireClient(player, data.Level, data.Experience)
end

function ProgressionManager.AdjustReputation(player, amount, reason)
	local data = deps.PlayerData[player.UserId]
	if not data then return end

	local oldRep = data.Reputation
	data.Reputation = math.clamp(data.Reputation + amount, -100, 100)

	local formattedAmount = string.format("%.2f", amount)
	if amount > 0 then
		deps.Events.NotifyPlayer:FireClient(player, "Info", "+" .. formattedAmount .. " REP")
	elseif amount < 0 then
		deps.Events.NotifyPlayer:FireClient(player, "Info", formattedAmount .. " REP")
	end

	deps.Events.UpdateReputation:FireClient(player, data.Reputation)
end

