	if not data then return end
	local inGroup, rank = checkGroupMembership(player)
	local onCooldown, remaining = getGroupRewardCooldownState(data)
	Events.SendGroupRewardStatus:FireClient(player, {InGroup = inGroup, Rank = rank, OnCooldown = onCooldown, CooldownRemaining = remaining})
end)

Events.ClaimGroupReward.OnServerEvent:Connect(function(player)
	local data = PlayerData[player.UserId]
	if not data then return end
	local inGroup, rank = checkGroupMembership(player)
	if not inGroup then Events.NotifyPlayer:FireClient(player, "Error", "You must be a member of the group to claim rewards!") return end
	local onCooldown, remaining = getGroupRewardCooldownState(data)
	if onCooldown then Events.NotifyPlayer:FireClient(player, "Error", "Daily group reward is still on cooldown! Next in " .. math.ceil(remaining/60) .. " minute(s).") return end

	local rewards = GroupRewardsConfig.Rewards or {}
	local rewardsGiven = {}

	if rewards.Money then
		data.Money = (data.Money or 0) + rewards.Money
		Events.UpdateMoney:FireClient(player, data.Money)
		table.insert(rewardsGiven, rewards.Money .. " RC")
		pcall(function() DataStoreManager.SetPlayerMoney(player.UserId, data.Money) end)
	end
	if rewards.SkillPoints then
		data.PendingSkillPoints = (data.PendingSkillPoints or 0) + rewards.SkillPoints
		local spAwarded = math.floor(data.PendingSkillPoints)
		data.PendingSkillPoints = data.PendingSkillPoints - spAwarded
		if spAwarded > 0 then
			data.SkillPoints = math.min((GameData.SkillTree.MaxSkillPoints or 50), (data.SkillPoints or 0) + spAwarded)
			table.insert(rewardsGiven, spAwarded .. " SP")
		end
		Events.SendSkillTree:FireClient(player, {SkillPoints = data.SkillPoints or 0, UnlockedSkills = data.UnlockedSkills or {}})
	end
	if rewards.Experience then
		pcall(function() ProgressionManager.AwardExperience(player, rewards.Experience, "Group Reward") end)
		table.insert(rewardsGiven, rewards.Experience .. " XP")
	end

	data.GroupRewardClaimed = {LastClaimTime = os.time(), ClaimCount = (data.GroupRewardClaimed and data.GroupRewardClaimed.ClaimCount or 0) + 1}
	DataSaveManager.QueuePlayerSave(player.UserId)
	DataSaveManager.MarkPlayerDirty(player.UserId)
	local oc, r = getGroupRewardCooldownState(data)
	Events.SendGroupRewardStatus:FireClient(player, {InGroup = true, Rank = rank, OnCooldown = oc, CooldownRemaining = r})
	Events.NotifyPlayer:FireClient(player, "Success", "Claimed: " .. table.concat(rewardsGiven, ", "))
end)

local PurchaseMusic = RemoteEvents:FindFirstChild("PurchaseMusic")
if PurchaseMusic then
	PurchaseMusic.OnServerEvent:Connect(function(player, trackIndex)
		local data = DataStoreManager.GetPlayerData(player) 
		if not data then return end
		local TRACK_COST = 500
		if not data.OwnedMusic then data.OwnedMusic = {[1] = true} end
		if data.OwnedMusic[trackIndex] or data.OwnedMusic[tostring(trackIndex)] then return end
		if data.Money >= TRACK_COST then
			data.Money = data.Money - TRACK_COST
			data.OwnedMusic[tostring(trackIndex)] = true
			DataStoreManager.SavePlayerData(player)
			RemoteEvents:FindFirstChild("UpdateOwnedMusic"):FireClient(player, trackIndex)
			Events.UpdateMoney:FireClient(player, data.Money)
		else
			Events.NotifyPlayer:FireClient(player, "Error", "Insufficient RC!")
		end
	end)
end

local ServerStorage = game:GetService("ServerStorage")
local AddMoneySignal = ServerStorage:FindFirstChild("AddPlayerMoney") or Instance.new("BindableEvent", ServerStorage)
AddMoneySignal.Name = "AddPlayerMoney"
AddMoneySignal.Event:Connect(function(player, amount, xp)
	if PlayerData[player.UserId] then
		PlayerData[player.UserId].Money = (PlayerData[player.UserId].Money or 0) + amount
		PlayerData[player.UserId].Experience = (PlayerData[player.UserId].Experience or 0) + xp
		PlayerData[player.UserId].Stats = PlayerData[player.UserId].Stats or {}
		PlayerData[player.UserId].Stats.MoneyStolen = (PlayerData[player.UserId].Stats.MoneyStolen or 0) + amount
		Events.UpdateMoney:FireClient(player, PlayerData[player.UserId].Money)
	end
end)

_G.AwardTaskReward = function(player, amount, xp)
	local data = PlayerData[player.UserId]
	if not data then return false end
	data.Money = (data.Money or 0) + amount
	Events.UpdateMoney:FireClient(player, data.Money)
	pcall(function() ProgressionManager.AwardExperience(player, xp, "Task Reward") end)
	DataSaveManager.QueuePlayerSave(player.UserId)
	DataSaveManager.MarkPlayerDirty(player.UserId)
	return true
end
