local function initializePlayer(player)
	OperationManager.CleanupStaleOperations(player.UserId)
	if ActiveOperations[player.UserId] then ActiveOperations[player.UserId] = {} end
	if PlayerResourceUsage[player.UserId] then PlayerResourceUsage[player.UserId] = {CPU = 0, RAM = 0, NET = 0} end

	local savedData = DataSaveManager.LoadAllPlayerData(player.UserId)
	if DataStoreManager.DidDataLoadFail(player.UserId) then
		Events.NotifyPlayer:FireClient(player, "Error", "Failed to load data. Rejoin.")
		task.wait(3); player:Kick("Data failed to load."); return
	end

	local playerIP = NetworkSetupManager.GetPlayerIP(player.UserId)
	
	PlayerData[player.UserId] = {
		Money = savedData and savedData.Money or GameData.StartingMoney, IP = playerIP, CurrentNetwork = nil, LoggedInNetwork = nil, LoggedInDevice = nil, HomeNetwork = nil, PositiveRep = 0, NegativeRep = 0, Reputation = savedData and savedData.Reputation or 0, Level = savedData and savedData.Level or 0, Experience = savedData and savedData.Experience or 0, CPULevel = 1, RAMLevel = 1, NetworkLevel = 1, PCSecurityLevel = savedData and savedData.PCSecurityLevel or 1, HomeAdminTier = 0, BankBalance = savedData and savedData.BankBalance or 0, ScannedNetworks = {}, TracedBy = {}, LockedNetworks = {}, NetworkValue = {}, Networks = {}, ActiveOperationsCount = 0, OwnedParts = savedData and savedData.OwnedParts or {}, EquippedParts = savedData and savedData.EquippedParts or {CPU = nil, GPU = nil, RAM1 = nil, RAM2 = nil, RAM3 = nil, RAM4 = nil, PSU = nil, HDD = nil, NET = nil}, Motherboard = savedData and savedData.Motherboard or nil, BaseResourceUsage = {CPU = 5, RAM = 10, NET = 5}, Settings = savedData and savedData.Settings or DataStoreManager.GetDefaultSettings(), Stats = savedData and savedData.Stats or {ScansCompleted = 0, HacksCompleted = 0, TimesHacked = 0, TimesTraced = 0, PlayersHacked = 0, HighestRC = 0}, OwnedGamepasses = {}, ActiveBoosts = {}, Guild = savedData and savedData.Guild or nil, SkillPoints = savedData and savedData.SkillPoints or 0, UnlockedSkills = savedData and savedData.UnlockedSkills or {}, MilestoneRewards = savedData and savedData.MilestoneRewards or {}, PendingSkillPoints = savedData and savedData.PendingSkillPoints or 0, GroupRewardClaimed = savedData and savedData.GroupRewardClaimed or nil, LevelRewards = savedData and savedData.LevelRewards or {}, LastInterestTime = savedData and savedData.LastSave or os.time(), TutorialCompleted = savedData and savedData.TutorialCompleted or false, ShopLastRefresh = savedData and savedData.ShopLastRefresh or 0, DarkMarketLastRefresh = savedData and savedData.DarkMarketLastRefresh or 0, StolenFromGoodNetworks = savedData and savedData.StolenFromGoodNetworks or 0, OwnedExploits = savedData and savedData.OwnedExploits or {}, SpecialItems = savedData and savedData.SpecialItems or {}, NetworkScannerLevel = savedData and savedData.NetworkScannerLevel or 1, NetworkHackingLevel = savedData and savedData.NetworkHackingLevel or 1, ScriptingAreaUnlocked = savedData and savedData.ScriptingAreaUnlocked or false, UnlockedScriptBlocks = savedData and savedData.UnlockedScriptBlocks or {}, ProtocolLockoutUntil = savedData and savedData.ProtocolLockoutUntil or 0
	}

	if PlayerData[player.UserId].Guild and Guilds[PlayerData[player.UserId].Guild] then
		GuildServerManager.SaveGuildData(PlayerData[player.UserId].Guild, false)
	end

	AccessCodeSystem.InitializePlayerLogs(player.UserId)

	task.spawn(function()
		task.wait(2)
		if SecurityValidator and PlayerData[player.UserId] then
			for _, part in ipairs(PlayerData[player.UserId].OwnedParts or {}) do
				local suspicious, suspReason = SecurityValidator.IsPartSuspicious(part)
				if suspicious then
					if ExploitLogger then ExploitLogger.Log(player.UserId, "SuspiciousPart", "Found suspicious part: " .. tostring(part.Name or "Unknown") .. " - " .. tostring(suspReason), "Critical") end
					if AutoModeration then AutoModeration.BanPlayer(player.UserId, "Suspicious PC part detected", ExploitLogger) end
					return
				end
			end
		end
		if AutoModeration and ExploitLogger and PlayerData[player.UserId] then AutoModeration.RunAutoModOnPlayer(player.UserId, PlayerData, ExploitLogger) end
	end)

	if not savedData or not savedData.OwnedParts or #PlayerData[player.UserId].OwnedParts == 0 then
		local startingParts, startingMobo = HardwareManager.GenerateStartingParts()
		PlayerData[player.UserId].OwnedParts = startingParts
		PlayerData[player.UserId].Motherboard = startingMobo
		PlayerData[player.UserId].EquippedParts = { CPU = startingParts[1], RAM1 = startingParts[2], PSU = startingParts[3], HDD = startingParts[4], NET = startingParts[5] }
	else
		HardwareManager.FixDuplicatePartIds(player.UserId)
	end

	local playerNetworks = NetworkSetupManager.GenerateNetworksForPlayer(player, playerIP)
	PlayerData[player.UserId].Networks = playerNetworks

	if savedData and savedData.HomeNetwork then
		local hn = PlayerData[player.UserId].Networks[1]
		if hn then
			hn.Security = savedData.HomeNetwork.Security or hn.Security
			hn.AdminTier = savedData.HomeNetwork.AdminTier or hn.AdminTier
			hn.Firewall = NetworkStateManager.SanitizeFirewall(savedData.HomeNetwork.Firewall)
		end
	end

	PlayerData[player.UserId].HomeNetwork = PlayerData[player.UserId].Networks[1].Id
	PlayerData[player.UserId].CurrentNetwork = PlayerData[player.UserId].HomeNetwork
	PlayerData[player.UserId].Networks[1].Scanned = true
	PlayerData[player.UserId].Networks[1].Hacked = true

	if ServerNetworkViewerData[player.UserId] then
		local savedViewerData = ServerNetworkViewerData[player.UserId]
		for _, savedNet in ipairs(savedViewerData.Networks) do
			if savedNet.Id ~= PlayerData[player.UserId].HomeNetwork then
				table.insert(PlayerData[player.UserId].Networks, savedNet)
			end
		end
		ServerNetworkViewerData[player.UserId] = nil
	end

	Events.UpdateMoney:FireClient(player, PlayerData[player.UserId].Money)
	Events.SendShopRefreshTimes:FireClient(player, PlayerData[player.UserId].ShopLastRefresh, PlayerData[player.UserId].DarkMarketLastRefresh)
	Events.SendSystemData:FireClient(player, { Money = PlayerData[player.UserId].Money, CPULevel = PlayerData[player.UserId].CPULevel, RAMLevel = PlayerData[player.UserId].RAMLevel, NetworkLevel = PlayerData[player.UserId].NetworkLevel, PCSecurityLevel = PlayerData[player.UserId].PCSecurityLevel, HomeAdminTier = PlayerData[player.UserId].HomeAdminTier, OwnedGamepasses = PlayerData[player.UserId].OwnedGamepasses, ScriptingAreaUnlocked = PlayerData[player.UserId].ScriptingAreaUnlocked or false, UnlockedScriptBlocks = PlayerData[player.UserId].UnlockedScriptBlocks or {}, NetworkScannerLevel = PlayerData[player.UserId].NetworkScannerLevel or 1, NetworkHackingLevel = PlayerData[player.UserId].NetworkHackingLevel or 1, SkillPoints = PlayerData[player.UserId].SkillPoints or 0, UnlockedSkills = PlayerData[player.UserId].UnlockedSkills or {}})

	HardwareManager.EnsureStartingPartsMarked(player.UserId)
	Events.SendPCPartsData:FireClient(player, { OwnedParts = PlayerData[player.UserId].OwnedParts, EquippedParts = PlayerData[player.UserId].EquippedParts, Motherboard = PlayerData[player.UserId].Motherboard })

	local clientNetworks = NetworkStateManager.PrepareNetworksForClient(PlayerData[player.UserId].Networks, player.UserId)
	pcall(function() Events.SendNetworkData:FireClient(player, clientNetworks, PlayerData[player.UserId].CurrentNetwork, PlayerData[player.UserId].LoggedInNetwork, PlayerData[player.UserId].LoggedInDevice) end)
	Events.SendSettings:FireClient(player, PlayerData[player.UserId].Settings)

	OperationManager.UpdatePlayerResourceUsage(player.UserId)
	NetworkStateManager.BroadcastPlayerPositions(player)

	if not PlayerData[player.UserId].TutorialCompleted then
		if not savedData then MailManager.SendWelcomeMail(player.UserId) end
		task.wait(0.5)
		Events.StartTutorial:FireClient(player)
	end

	EconomyManager.CheckAndResetPlayerRC(player.UserId)
	if PlayerData[player.UserId].Guild then EconomyManager.CheckAndResetGuildRC(PlayerData[player.UserId].Guild) end
	DataSaveManager.MarkPlayerDirty(player.UserId)
end

