				end
			end
		end

		DataSaveManager.FlushPlayerData(player.UserId)
		DataStoreManager.CleanupPlayer(player.UserId)

		for networkId, connections in pairs(PlayerHomeConnections) do
			if connections[player.UserId] then connections[player.UserId] = nil end
		end

		for otherUserId, otherData in pairs(PlayerData) do
			if otherUserId ~= player.UserId and otherData.Networks then
				for i = #otherData.Networks, 1, -1 do
					if otherData.Networks[i].IsOtherPlayerHome and otherData.Networks[i].OriginalOwnerId == player.UserId then
						table.remove(otherData.Networks, i)
					end
				end
				local otherPlayer = Players:GetPlayerByUserId(otherUserId)
				if otherPlayer then
					local clientNetworks = NetworkStateManager.PrepareNetworksForClient(otherData.Networks, otherUserId)
					Events.SendNetworkData:FireClient(otherPlayer, clientNetworks, otherData.CurrentNetwork, otherData.LoggedInNetwork, otherData.LoggedInDevice)
				end
			end
		end

		if PlayerData[player.UserId].Guild and Guilds[PlayerData[player.UserId].Guild] then
			GuildServerManager.SaveGuildData(PlayerData[player.UserId].Guild, true)
		end

		PlayerData[player.UserId] = nil
		ActiveOperations[player.UserId] = nil
		PlayerResourceUsage[player.UserId] = nil
		TraceManager.CleanupPlayerTraces(player.UserId)
		NetworkStateManager.BroadcastPlayerPositions(nil)
	end
end)

