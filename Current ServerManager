		local playerIP = PlayerData[player.UserId].IP
		NetworkGenerator.ReleaseIP(playerIP)

		ServerNetworkViewerData[player.UserId] = { Networks = {}, SavedAt = time(), LoginStatus = {}, HackTimers = {}, StealTimers = {} }
		if AccessCodeSystem.LoggedInNetworks[player.UserId] then ServerNetworkViewerData[player.UserId].LoginStatus = AccessCodeSystem.LoggedInNetworks[player.UserId] end
		if AccessCodeSystem.HackTimers[player.UserId] then ServerNetworkViewerData[player.UserId].HackTimers = AccessCodeSystem.HackTimers[player.UserId] end
		if AccessCodeSystem.StealTimers[player.UserId] then ServerNetworkViewerData[player.UserId].StealTimers = AccessCodeSystem.StealTimers[player.UserId] end

		if PlayerData[player.UserId].Networks then
			for _, network in ipairs(PlayerData[player.UserId].Networks) do
				if network then
					local savedDevices = {}
					if network.Devices then
						for _, device in ipairs(network.Devices) do
							table.insert(savedDevices, { Id = device.Id, Scanned = device.Scanned, Hacked = device.Hacked, RelativePosition = device.RelativePosition, ParentMainframe = device.ParentMainframe, SubDevices = device.SubDevices, IsMainframe = device.IsMainframe, IsSpecialDevice = device.IsSpecialDevice })
